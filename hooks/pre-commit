#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
LOCAL_CHECK_SCRIPT="$(cd "$SCRIPT_DIR/.." && pwd)/scripts/check-gate.sh"

# Find workspace root
find_workspace_root() {
  local dir="$PWD"
  while [ "$dir" != "/" ]; do
    if [ -f "$dir/.codespec/codespec" ]; then
      printf '%s\n' "$dir"
      return
    fi
    dir="$(dirname "$dir")"
  done
  return 1
}

repo_meta_paths() {
  git -C "$GIT_ROOT" ls-files -co --exclude-standard -- 'meta.yaml' '*/meta.yaml' 2>/dev/null |
    grep -vE '(^|/)(\.codespec|versions|project-docs)/' |
    sort -u
}

project_root_for_meta_path() {
  local meta_path="$1"
  local meta_dir
  meta_dir="$(dirname "$meta_path")"
  if [ "$meta_dir" = "." ]; then
    printf '%s\n' "$GIT_ROOT"
  else
    (cd "$GIT_ROOT/$meta_dir" && pwd)
  fi
}

best_meta_for_file() {
  local file="$1"
  local best="" best_len=-1 meta_path meta_dir len
  while IFS= read -r meta_path; do
    [ -n "$meta_path" ] || continue
    meta_dir="$(dirname "$meta_path")"
    if [ "$meta_dir" = "." ]; then
      len=0
      if [ "$len" -gt "$best_len" ]; then
        best="$meta_path"
        best_len="$len"
      fi
      continue
    fi
    case "$file" in
      "$meta_dir"|"$meta_dir"/*)
        len="${#meta_dir}"
        if [ "$len" -gt "$best_len" ]; then
          best="$meta_path"
          best_len="$len"
        fi
        ;;
    esac
  done < <(repo_meta_paths)
  [ -n "$best" ] && printf '%s\n' "$best"
}

# Find project root
find_project_root() {
  if [ -n "${CODESPEC_PROJECT_ROOT:-}" ]; then
    (cd "$CODESPEC_PROJECT_ROOT" && pwd)
    return
  fi

  local dir
  dir="$PWD"
  while [ "$dir" != "/" ]; do
    if [ -f "$dir/meta.yaml" ]; then
      printf '%s\n' "$dir"
      return
    fi
    dir="$(dirname "$dir")"
  done

  local metas=() changed=() candidates=() file meta_path
  mapfile -t metas < <(repo_meta_paths)
  if [ "${#metas[@]}" -eq 0 ]; then
    return 1
  fi
  if [ "${#metas[@]}" -eq 1 ]; then
    project_root_for_meta_path "${metas[0]}"
    return
  fi

  mapfile -t changed < <(git -C "$GIT_ROOT" diff --cached --name-only --diff-filter=ACMRD)
  for file in "${changed[@]}"; do
    meta_path="$(best_meta_for_file "$file" || true)"
    [ -n "$meta_path" ] || continue
    candidates+=("$meta_path")
  done

  if [ "${#candidates[@]}" -eq 0 ]; then
    return 1
  fi

  mapfile -t candidates < <(printf '%s\n' "${candidates[@]}" | sort -u)
  if [ "${#candidates[@]}" -gt 1 ]; then
    printf 'ERROR: multiple codespec dossiers changed in one commit; split the commit or set CODESPEC_PROJECT_ROOT\n' >&2
    exit 1
  fi

  project_root_for_meta_path "${candidates[0]}"
}

project_git_prefix() {
  local project_root="$1"
  if git -C "$project_root" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    git -C "$project_root" rev-parse --show-prefix | sed 's:/$::'
  fi
}

WORKSPACE_ROOT="$(find_workspace_root || echo "")"
GIT_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
PROJECT_ROOT="$(find_project_root || true)"
[ -n "$PROJECT_ROOT" ] || {
  printf 'WARNING: no codespec dossier touched, skipping codespec checks\n' >&2
  exit 0
}
PROJECT_PREFIX="$(project_git_prefix "$PROJECT_ROOT")"
if [ -n "$PROJECT_PREFIX" ]; then
  META_GIT_PATH="$PROJECT_PREFIX/meta.yaml"
else
  META_GIT_PATH="meta.yaml"
fi
STAGED_REPO_ROOT=""
STAGED_PROJECT_ROOT=""

cleanup() {
  if [ -n "$STAGED_REPO_ROOT" ]; then
    rm -rf "$STAGED_REPO_ROOT"
  fi
}
trap cleanup EXIT

if [ -n "$WORKSPACE_ROOT" ] && [ -x "$WORKSPACE_ROOT/.codespec/scripts/check-gate.sh" ]; then
  CHECK_SCRIPT="$WORKSPACE_ROOT/.codespec/scripts/check-gate.sh"
elif [ -x "$LOCAL_CHECK_SCRIPT" ]; then
  CHECK_SCRIPT="$LOCAL_CHECK_SCRIPT"
else
  CHECK_SCRIPT="$PROJECT_ROOT/.codespec/scripts/check-gate.sh"
fi

[ -x "$CHECK_SCRIPT" ] || {
  printf 'ERROR: missing %s\n' "$CHECK_SCRIPT" >&2
  exit 1
}

gate_map_file() {
  local candidate
  if [ -n "$WORKSPACE_ROOT" ]; then
    candidate="$WORKSPACE_ROOT/.codespec/templates/gate-map.yaml"
    [ -f "$candidate" ] && {
      printf '%s\n' "$candidate"
      return
    }
  fi
  candidate="$(cd "$(dirname "$CHECK_SCRIPT")/.." && pwd)/templates/gate-map.yaml"
  [ -f "$candidate" ] || {
    printf 'ERROR: missing gate map: templates/gate-map.yaml\n' >&2
    exit 1
  }
  printf '%s\n' "$candidate"
}

transition_for_target_phase() {
  local target_phase="$1"
  TARGET_PHASE="$target_phase" yq eval -r '.transitions | to_entries[] | select(.value.target_phase == strenv(TARGET_PHASE)) | .key' "$(gate_map_file)" | head -1
}

transition_gate_rows() {
  local transition="$1"
  TRANSITION="$transition" yq eval -r '
    .transitions[strenv(TRANSITION)].gates[]
    | [.gate, ((.env // {}) | to_entries | map(.key + "=" + .value) | join(" "))]
    | @tsv
  ' "$(gate_map_file)"
}

STAGED_REPO_ROOT="$(mktemp -d /tmp/codespec-staged-XXXXXX)"
if [ -n "$PROJECT_PREFIX" ]; then
  STAGED_PROJECT_ROOT="$STAGED_REPO_ROOT/$PROJECT_PREFIX"
else
  STAGED_PROJECT_ROOT="$STAGED_REPO_ROOT"
fi
git -C "$GIT_ROOT" checkout-index -a --prefix="$STAGED_REPO_ROOT/" >/dev/null 2>&1 || {
  printf 'ERROR: failed to build staged snapshot for codespec checks\n' >&2
  exit 1
}

print_recovery_hint() {
  local gate="$1"
  local staged_phase head_phase changed_files
  staged_phase="$(yq eval '.phase' "$STAGED_PROJECT_ROOT/meta.yaml" 2>/dev/null || true)"
  head_phase="$(git show "HEAD:$META_GIT_PATH" 2>/dev/null | yq eval '.phase' - 2>/dev/null || true)"
  changed_files="$(git -C "$GIT_ROOT" diff --cached --name-only --diff-filter=ACMRD | paste -sd ', ' -)"

  printf '\nCodespec recovery hint:\n' >&2
  if [ -n "$head_phase" ] && [ -n "$staged_phase" ] && [ "$head_phase" != "$staged_phase" ]; then
    printf '%s\n' "- staged meta.yaml changes phase ${head_phase} -> ${staged_phase}; make sure the authority docs required by ${staged_phase} are staged in the same snapshot." >&2
  fi
  printf '%s\n' "- staged files: ${changed_files:-none}" >&2
  case "$gate" in
    design-quality|implementation-ready|trace-consistency|verification|deployment-plan-ready|deployment-readiness|promotion-criteria)
      printf '%s\n' "- if this gate found an upstream authority gap after Implementation/Testing/Deployment has begun, use \`codespec authority-repair begin ${gate} --paths <minimal-authority-paths> --reason \"<why>\"\`, then close it after the gate and smoke pass." >&2
      ;;
    phase-capability|scope)
      printf '%s\n' '- if the file is a legitimate upstream authority repair, enter authority repair mode first; otherwise switch phase or keep the change inside the implementation boundary defined in design.md §4.' >&2
      ;;
    *)
      printf '%s\n' '- fix the reported gate failure, then re-stage the affected files and retry commit.' >&2
      ;;
  esac
}

run_gate() {
  local output status gate
  gate="$1"
  set +e
  output="$(CODESPEC_PROJECT_ROOT="$STAGED_PROJECT_ROOT" CODESPEC_GIT_ROOT="$GIT_ROOT" CODESPEC_PROJECT_PREFIX="$PROJECT_PREFIX" CODESPEC_CHECK_CONTEXT=staged-snapshot "$CHECK_SCRIPT" "$@" 2>&1)"
  status=$?
  set -e
  if [ -n "$output" ]; then
    printf '%s\n' "$output"
  fi
  if [ "$status" -ne 0 ]; then
    print_recovery_hint "$gate"
    return "$status"
  fi
}

run_gate_with_env() {
  local gate="$1"
  local envs="${2:-}"
  (
    local pair
    for pair in $envs; do
      [ -n "$pair" ] || continue
      export "$pair"
    done
    run_gate "$gate"
  )
}

run_transition_gate_as_head_phase() {
  local gate="$1"
  local envs="${2:-}"
  local transition_root head_phase status yq_expr env_args=()
  local pair
  transition_root="$(mktemp -d /tmp/codespec-transition-XXXXXX)"
  cp -R "$STAGED_PROJECT_ROOT/." "$transition_root/"
  head_phase="$(git show "HEAD:$META_GIT_PATH" 2>/dev/null | yq eval '.phase' - 2>/dev/null || true)"
  if [ -z "$head_phase" ] || [ "$head_phase" = "null" ]; then
    head_phase="$(yq eval '.phase' "$transition_root/meta.yaml" 2>/dev/null || true)"
  fi

  yq_expr=".phase = \"$head_phase\""
  yq eval "$yq_expr" -i "$transition_root/meta.yaml"
  for pair in $envs; do
    [ -n "$pair" ] || continue
    env_args+=("$pair")
  done
  set +e
  env CODESPEC_PROJECT_ROOT="$transition_root" CODESPEC_GIT_ROOT="$GIT_ROOT" CODESPEC_PROJECT_PREFIX="$PROJECT_PREFIX" CODESPEC_CHECK_CONTEXT=staged-snapshot "${env_args[@]}" "$CHECK_SCRIPT" "$gate"
  status=$?
  set -e
  rm -rf "$transition_root"
  return "$status"
}

run_testing_transition_verification() {
  run_transition_gate_as_head_phase verification
}

# Check if meta.yaml exists in the staged snapshot
if [ ! -f "$STAGED_PROJECT_ROOT/meta.yaml" ]; then
  printf 'WARNING: meta.yaml not found, skipping codespec checks\n' >&2
  exit 0
fi

run_transition_gates_if_phase_changes() {
  command -v yq >/dev/null 2>&1 || return 0
  git diff --cached --name-only -- "$META_GIT_PATH" | grep -Fxq "$META_GIT_PATH" || return 0

  local staged_phase head_phase transition rows=()
  local row gate envs
  staged_phase="$(yq eval '.phase' "$STAGED_PROJECT_ROOT/meta.yaml" 2>/dev/null || true)"
  head_phase="$(git show "HEAD:$META_GIT_PATH" 2>/dev/null | yq eval '.phase' - 2>/dev/null || true)"

  [ -n "$head_phase" ] || return 0
  [ -n "$staged_phase" ] || return 0
  [ "$staged_phase" != "$head_phase" ] || return 0

  transition="$(transition_for_target_phase "$staged_phase")"
  [ -n "$transition" ] || return 0
  mapfile -t rows < <(transition_gate_rows "$transition")

  for row in "${rows[@]}"; do
    IFS=$'\t' read -r gate envs <<< "$row"
    [ -n "$gate" ] || continue
    case "$staged_phase:$gate" in
      Testing:verification|Testing:semantic-handoff|Deployment:trace-consistency|Deployment:verification|Deployment:semantic-handoff)
        run_transition_gate_as_head_phase "$gate" "$envs"
        ;;
      *)
        run_gate_with_env "$gate" "$envs"
        ;;
    esac
  done
}

run_completion_gates_if_status_completes() {
  command -v yq >/dev/null 2>&1 || return 0
  git diff --cached --name-only -- "$META_GIT_PATH" | grep -Fxq "$META_GIT_PATH" || return 0

  local staged_phase head_phase staged_status head_status
  staged_phase="$(yq eval '.phase' "$STAGED_PROJECT_ROOT/meta.yaml" 2>/dev/null || true)"
  head_phase="$(git show "HEAD:$META_GIT_PATH" 2>/dev/null | yq eval '.phase' - 2>/dev/null || true)"
  staged_status="$(yq eval '.status' "$STAGED_PROJECT_ROOT/meta.yaml" 2>/dev/null || true)"
  head_status="$(git show "HEAD:$META_GIT_PATH" 2>/dev/null | yq eval '.status' - 2>/dev/null || true)"

  [ "$head_phase" = "Deployment" ] || return 0
  [ "$staged_phase" = "Deployment" ] || return 0
  [ "$head_status" != "completed" ] || return 0
  [ "$staged_status" = "completed" ] || return 0

  local rows=()
  local row gate envs
  mapfile -t rows < <(transition_gate_rows complete-change)
  for row in "${rows[@]}"; do
    IFS=$'\t' read -r gate envs <<< "$row"
    [ -n "$gate" ] || continue
    run_gate_with_env "$gate" "$envs"
  done
}

run_transition_gates_if_phase_changes
run_completion_gates_if_status_completes

# Run standard gates (hard enforcement)
run_gate metadata-consistency
run_gate phase-capability
run_gate scope
run_gate contract-boundary

printf '✓ pre-commit checks passed\n'
