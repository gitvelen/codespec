#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
LOCAL_CHECK_SCRIPT="$(cd "$SCRIPT_DIR/.." && pwd)/scripts/check-gate.sh"

if [ -n "${CODESPEC_PROJECT_ROOT:-}" ] && [ -x "${CODESPEC_PROJECT_ROOT}/.codespec/scripts/check-gate.sh" ]; then
  PROJECT_ROOT="$CODESPEC_PROJECT_ROOT"
  CHECK_SCRIPT="$PROJECT_ROOT/.codespec/scripts/check-gate.sh"
elif [ -x "$LOCAL_CHECK_SCRIPT" ]; then
  PROJECT_ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"
  CHECK_SCRIPT="$LOCAL_CHECK_SCRIPT"
else
  PROJECT_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
  CHECK_SCRIPT="$PROJECT_ROOT/.codespec/scripts/check-gate.sh"
fi

[ -x "$CHECK_SCRIPT" ] || {
  printf 'ERROR: missing %s\n' "$CHECK_SCRIPT" >&2
  exit 1
}

CODESPEC_PROJECT_ROOT="$PROJECT_ROOT" "$CHECK_SCRIPT" scope
CODESPEC_PROJECT_ROOT="$PROJECT_ROOT" "$CHECK_SCRIPT" boundary

printf '✓ pre-commit checks passed\n'
