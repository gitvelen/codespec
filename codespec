migrate_remove_wi() {
  require_yq
  local project_root="${1:?usage: codespec migrate-remove-wi <project_root> [--apply]}"
  shift || true

  local apply_mode=false
  local reset_stale_contracts=false
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --apply)
        apply_mode=true
        ;;
      --reset-stale-contracts)
        reset_stale_contracts=true
        ;;
      *)
        die "unknown migrate-remove-wi option: $1"
        ;;
    esac
    shift || true
  done

  [ -d "$project_root" ] || die "project_root does not exist: $project_root"
  project_root="$(cd "$project_root" && pwd)"
  local meta="$project_root/meta.yaml"
  [ -f "$meta" ] || die "missing meta.yaml in $project_root"

  local phase
  phase="$(yaml_scalar "$meta" phase)"

  if [ "$apply_mode" = false ]; then
    log "=== DRY RUN ==="
    log "project_root: $project_root"
    log "current phase: $phase"
    log ""
  fi

  case "$phase" in
    Requirement|Design)
      if [ "$apply_mode" = false ]; then
        log "Phase is $phase - migration can proceed automatically."
      fi
      ;;
    Implementation|Testing|Deployment)
      if [ "$apply_mode" = true ]; then
        die "Cannot auto-migrate project in $phase phase. Please complete the current loop or migrate manually."
      else
        log "WARNING: Phase is $phase - automatic migration is not allowed."
        log "  Please complete the current loop or migrate manually."
        return 0
      fi
      ;;
    *)
      die "Unknown phase: $phase"
      ;;
  esac

  # Step 1: Backup work-items/ if it exists
  if [ -d "$project_root/work-items" ]; then
    local backup_dir
    backup_dir="$(project_migration_backup_root "$project_root")/work-items.bak.$(date +%Y%m%d%H%M%S)"
    if [ "$apply_mode" = false ]; then
      log "Would backup: work-items/ -> $backup_dir/"
      # Show WI summary
      local wi_file wi_id
      for wi_file in "$project_root/work-items"/WI-*.yaml; do
        [ -f "$wi_file" ] || continue
        wi_id="$(basename "$wi_file" .yaml)"
        local allowed forbidden
        allowed="$(yaml_list "$wi_file" allowed_paths | tr '\n' ',' | sed 's/,$//')"
        forbidden="$(yaml_list "$wi_file" forbidden_paths | tr '\n' ',' | sed 's/,$//')"
        log "  $wi_id: allowed_paths=$allowed, forbidden_paths=$forbidden"
      done
    else
      backup_project_directory "$project_root" work-items work-items.bak
    fi
  else
    if [ "$apply_mode" = false ]; then
      log "No work-items/ directory found - nothing to backup."
    fi
  fi

  # Step 2: Clean meta.yaml
  local fields_to_remove=(focus_work_item active_work_items execution_group execution_branch feature_branch)
  local field
  for field in "${fields_to_remove[@]}"; do
    local current_value
    current_value="$(yq eval ".${field} // \"absent\"" "$meta")"
    if [ "$current_value" != 'absent' ]; then
      if [ "$apply_mode" = false ]; then
        log "Would remove from meta.yaml: $field (current: $current_value)"
      else
        yq eval "del(.${field})" -i "$meta"
        log "removed from meta.yaml: $field"
      fi
    fi
  done

  # Step 3: Clean legacy WI wording from project entry files using exact old-template replacements.
  local entry_file entry_output
  for entry_file in "$project_root/AGENTS.md" "$project_root/CLAUDE.md" "$project_root/AI_INSTRUCTIONS.md"; do
    [ -f "$entry_file" ] || continue
    entry_output="$(migrate_remove_wi_entry_file "$entry_file" "$apply_mode")"
    [ -n "$entry_output" ] || continue
    if [ "$apply_mode" = false ]; then
      log "Would update entry file: $entry_output"
    else
      log "updated entry file: $entry_output"
    fi
  done

  # Step 4: Optionally reset stale contracts that still encode the removed WI model.
  if [ "$reset_stale_contracts" = true ]; then
    if [ -d "$project_root/contracts" ]; then
      if [ "$apply_mode" = false ]; then
        log "Would backup and reset: contracts/ -> $(project_migration_backup_root "$project_root")/contracts.bak.<timestamp>/"
      else
        backup_project_directory "$project_root" contracts contracts.bak
        mkdir -p "$project_root/contracts"
      fi
    elif [ "$apply_mode" = false ]; then
      log "No contracts/ directory found - nothing to reset."
    else
      mkdir -p "$project_root/contracts"
    fi
  fi

  if [ "$apply_mode" = false ]; then
    log ""
    log "Run with --apply to execute."
  else
    log "migration applied"
  fi

  local records blocking
  records="$(legacy_wi_audit_records "$project_root" true)"
  blocking="$(printf '%s\n' "$records" | awk -F '\t' '$1 == "blocking"')"
  log ""
  print_legacy_wi_audit_records "$records"
  if [ "$apply_mode" = true ] && [ -n "$blocking" ]; then
    die "legacy WI migration still has blocking residue; rerun with --reset-stale-contracts when contract reset is intended"
  fi
}

migrate_testing_legacy_section() {
  local file="$1"
  local marker="$2"
  awk -v marker="$marker" '
    function is_current_heading(line) {
      if (marker == "CASES") return line ~ /^## 1\. /
      if (marker == "RUNS") return line ~ /^## 2\. /
      if (marker == "RISKS") return line ~ /^## 3\. /
      if (marker == "HANDOFFS") return line ~ /^## 4\. /
      return 0
    }
    $0 == "<!-- CODESPEC:TESTING:" marker " -->" {
      capture = 1
      next
    }
    is_current_heading($0) {
      capture = 1
      next
    }
    capture && /^<!-- CODESPEC:TESTING:LEDGER -->/ {
      exit
    }
    capture && /^<!-- CODESPEC:TESTING:/ {
      exit
    }
    capture && /^## / && is_current_heading($0) {
      next
    }
    capture && /^## / {
      exit
    }
    capture {
      print
    }
  ' "$file"
}

migrate_testing_legacy_section_json() {
  local file="$1"
  local marker="$2"
  local section
  section="$(migrate_testing_legacy_section "$file" "$marker")"
  if ! grep -qE '^[[:space:]]*-[[:space:]]*' <<<"$section"; then
    printf '[]\n'
    return
  fi
  printf '%s\n' "$section" | yq eval -o=json '.' -
}

migrate_testing_structured_yaml() {
  local file="$1"
  local tmpdir
  tmpdir="$(mktemp -d)"

  migrate_testing_legacy_section_json "$file" CASES >"$tmpdir/cases.json"
  migrate_testing_legacy_section_json "$file" RUNS >"$tmpdir/runs.json"
  migrate_testing_legacy_section_json "$file" HANDOFFS >"$tmpdir/handoffs.json"

  python3 - "$tmpdir/cases.json" "$tmpdir/runs.json" "$tmpdir/handoffs.json" <<'PY' | yq eval -P '.' -
import json
import sys

def load(path):
    with open(path, encoding="utf-8") as handle:
        value = json.load(handle)
    if value is None:
        return []
    if isinstance(value, list):
        return value
    return [value]

def indexed(items, id_key):
    result = {}
    for item in items:
        if not isinstance(item, dict):
            continue
        ident = item.get(id_key)
        if not ident:
            continue
        body = {key: value for key, value in item.items() if key != id_key}
        result[str(ident)] = body
    return result

ledger = {
    "schema_version": 1,
    "test_cases": indexed(load(sys.argv[1]), "tc_id"),
    "runs": indexed(load(sys.argv[2]), "run_id"),
    "handoffs": indexed(load(sys.argv[3]), "handoff_id"),
}
print(json.dumps(ledger, ensure_ascii=False))
PY
  rm -rf "$tmpdir"
}

