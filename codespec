usage() {
  cat <<'EOF'
Usage:
  codespec start-design
  codespec start-implementation
  codespec reopen-implementation
  codespec reopen-testing
  codespec authority-repair <begin|close|status>
  codespec start-testing
  codespec start-deployment
  codespec deploy
  codespec complete-change <stable-version>
  codespec submit-pr <stable-version> [--base <branch>] [--draft]
  codespec scaffold-project-docs <version>
  codespec generate-project-docs <version>
  codespec reset-to-requirement [--keep-contracts] [--force]
  codespec install-hooks
  codespec check-gate <name>
  codespec status
  codespec completion-report [--handoff-template]
  codespec gate-sequence <transition> [--json]
  codespec scaffold-review <target-phase>
  codespec review-gates <target-phase> [--write]
  codespec readset
  codespec materialize-deployment
  codespec promote-version <stable-version>
  codespec list-versions [--json]
  codespec migrate-requirement-phase <project_root> [--apply]
  codespec audit-legacy-wi <project_root> [--strict] [--json]
  codespec migrate-remove-wi <project_root> [--apply] [--reset-stale-contracts]
  codespec migrate-testing-ledger [--write]

Installation:
  /path/to/.codespec/scripts/install-workspace.sh <workspace_root>
  /path/to/.codespec/scripts/init-dossier.sh

Version lifecycle:
  deploy -> execute the project deploy hook and refresh deployment evidence
  complete-change -> archive accepted stable version and mark the Deployment change completed
  submit-pr -> complete an accepted Deployment change, push the current branch, and open a GitHub PR
  completion-report -> print the current phase handoff obligations and unfinished disclosure requirement
  completion-report --handoff-template -> print a draft HANDOFF-* record for testing.md
  gate-sequence -> print the canonical gate sequence for a lifecycle transition
  scaffold-review -> create a pending review record scaffold for a target phase
  review-gates -> run target phase objective gates and optionally write structured gate_evidence
  scaffold-project-docs -> scaffold project document shells from dossier artifacts
  generate-project-docs -> deprecated compatibility alias for scaffold-project-docs
  promote-version -> compatibility alias for complete-change <stable-version>
  reset-to-requirement -> reset dossier to Requirement phase for next version
  list-versions -> list all archived versions
  migrate-requirement-phase -> migrate Proposal/Requirements projects to Requirement with dry-run default
  audit-legacy-wi -> classify active legacy WI residue before/after migration
  migrate-remove-wi -> migrate project from WI model to design.md authority model
  migrate-testing-ledger -> generate structured testing.md ledger from legacy TC/RUN/HANDOFF sections

Gate views:
  requirement-complete -> Requirement dossier is structurally complete and fully traceable
  spec-quality -> spec.md is self-contained and free of template placeholders
  test-plan-complete -> every ACC has planned TC-* coverage before Design
  design-structure-complete -> design artifacts are structurally complete and aligned with slice derivation
  design-quality -> design.md covers architecture, contracts/data, security, environment, verification, and traceability
  design-readiness -> alias of design-quality
  review-quality -> review record is dated, scoped to existing files, and includes approved verdict, findings, and required gate evidence
  implementation-ready -> design-quality + implementation-start, including full REQ/ACC/VO/TC design coverage
  scope -> staged changes stay within design.md §4 allowed paths / outside forbidden paths; start-testing rechecks the full Implementation span
  contract-boundary -> contract refs resolve, frozen contracts stay unchanged, and frozen contracts require freeze review evidence
  trace-consistency -> REQ->ACC->VO->TC->RUN coverage in Testing/Deployment
  verification -> TC pass checks; testing/deployment use the latest matching RUN record
  semantic-handoff -> R15 active unfinished disclosure and wording guard
  deployment-plan-ready -> deployment.md plan, date, checklist, rollback, and monitoring are non-placeholder before deploy
  promotion -> metadata-consistency + deployment-readiness + promotion-criteria (promotion-criteria internally checks trace-consistency and testing-coverage)

Lifecycle commands:
  start-design -> Requirement -> Design
  start-implementation -> Design -> Implementation
  reopen-implementation -> Testing/Deployment -> Implementation for failed verification follow-up
  reopen-testing -> Deployment -> Testing for re-running failed deployment verification
  authority-repair -> audited temporary path for repairing upstream authority gaps
  start-testing -> Implementation -> Testing (rechecks the full Implementation span; requires implementation review)
  start-deployment -> Testing -> Deployment (or Deployment completed -> Deployment active reopen; auto-materializes deployment.md if missing)
  deploy -> check deployment-plan-ready gate, run scripts/codespec-deploy, and refresh deployment.md evidence
  complete-change -> archive an accepted stable version and mark Deployment completed
  submit-pr -> complete/push/create PR for an accepted Deployment change

Review rule:
  check-gate pass != semantic review pass; phase advancement still requires the review record required by phase-review-policy/rfr

Internal gates:
  metadata-consistency
  review-verdict-present | review-quality
  requirement-complete | spec-quality | test-plan-complete
  design-structure-complete | design-quality (alias: design-readiness)
  implementation-ready | implementation-start
  legacy-wi-clean | phase-capability | scope | contract-boundary
  trace-consistency | verification | testing-coverage
  semantic-handoff
  deployment-plan-ready | deployment-readiness | promotion-criteria | policy-consistency
EOF
}

main() {
  local cmd="${1:-help}"
  shift || true

  case "$cmd" in
    install)
      install_cmd "$@"
