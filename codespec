print_legacy_wi_audit_records() {
  local records="$1"
  local max_lines="${2:-80}"
  [ -n "$records" ] || {
    log "No legacy WI references found."
    return 0
  }

  local blocking info total
  blocking="$(printf '%s\n' "$records" | awk -F '\t' '$1 == "blocking"')"
  info="$(printf '%s\n' "$records" | awk -F '\t' '$1 == "info"')"

  if [ -n "$blocking" ]; then
    log "Blocking legacy WI residue:"
    printf '%s\n' "$blocking" | awk -F '\t' '{ printf "- [%s] %s: %s\n", $2, $3, $4 }' | sed -n "1,${max_lines}p"
    total="$(printf '%s\n' "$blocking" | wc -l | tr -d ' ')"
    if [ "$total" -gt "$max_lines" ]; then
      log "... ($total blocking matches)"
    fi
  else
    log "Blocking legacy WI residue: none"
  fi

  if [ -n "$info" ]; then
    log ""
    log "Informational legacy WI references:"
    printf '%s\n' "$info" | awk -F '\t' '{ printf "- [%s] %s\n", $2, $3 }' | sed -n "1,${max_lines}p"
    total="$(printf '%s\n' "$info" | wc -l | tr -d ' ')"
    if [ "$total" -gt "$max_lines" ]; then
      log "... ($total informational matches)"
    fi
  fi
}

