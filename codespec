#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
FRAMEWORK_ROOT="$SCRIPT_DIR"

log() {
  printf '%s\n' "$*"
}

die() {
  printf 'ERROR: %s\n' "$*" >&2
  exit 1
}

require_yq() {
  command -v yq >/dev/null 2>&1 || die "yq is required"
}

yaml_scalar() {
  local file="$1"
  local key="$2"
  yq eval ".${key}" "$file"
}

yaml_list() {
  local file="$1"
  local key="$2"
  yq eval ".${key}[]" "$file" 2>/dev/null || true
}

json_string_array() {
  local first=1
  printf '['
  while [ "$#" -gt 0 ]; do
    if [ "$first" -eq 0 ]; then
      printf ', '
    fi
    printf '%s' "$1" | python3 -c 'import json,sys; print(json.dumps(sys.stdin.read()), end="")'
    first=0
    shift
  done
  printf ']'
}

json_object() {
  printf '{'
  local first=1
  while [ "$#" -gt 0 ]; do
    local key="$1"
    local value="$2"
    if [ "$first" -eq 0 ]; then
      printf ', '
    fi
    printf '%s' "$key" | python3 -c 'import json,sys; print(json.dumps(sys.stdin.read()), end="")'
    printf ': %s' "$value"
    first=0
    shift 2
  done
  printf '}'
}

json_quote() {
  printf '%s' "$1" | python3 -c 'import json,sys; print(json.dumps(sys.stdin.read()), end="")'
}

json_path_entry_object() {
  local path="$1"
  local when_clause="${2:-}"
  local read_hint="${3:-}"
  local args=("path" "$(json_quote "$path")")
  if [ -n "$when_clause" ]; then
    args+=("when" "$(json_quote "$when_clause")")
  fi
  if [ -n "$read_hint" ]; then
    args+=("read_hint" "$(json_quote "$read_hint")")
  fi
  json_object "${args[@]}"
}

json_path_entries() {
  local first=1
  printf '['
  while [ "$#" -gt 0 ]; do
    local path="$1"
    local when_clause="${2:-}"
    local read_hint="${3:-}"
    if [ "$first" -eq 0 ]; then
      printf ', '
    fi
    printf '%s' "$(json_path_entry_object "$path" "$when_clause" "$read_hint")"
    first=0
    shift 3
  done
  printf ']'
}

render_text_entry_line() {
  local path="$1"
  local read_hint="${2:-}"
  if [ -n "$read_hint" ]; then
    printf -- '- %s (%s)\n' "$path" "$read_hint"
  else
    printf -- '- %s\n' "$path"
  fi
}

render_text_triplets() {
  local -n entries_ref="$1"
  local idx
  for ((idx=0; idx<${#entries_ref[@]}; idx+=3)); do
    render_text_entry_line "${entries_ref[idx]}" "${entries_ref[idx+2]}"
  done
}

render_text_entry_choice() {
  local -n entries_ref="$1"
  local idx joined when_clause
  when_clause="${entries_ref[1]:-}"
  joined=""
  for ((idx=0; idx<${#entries_ref[@]}; idx+=3)); do
    if [ -n "$joined" ]; then
      joined+=" or "
    fi
    joined+="${entries_ref[idx]}"
  done
  printf -- '- %s (%s)\n' "$joined" "$when_clause"
}

render_text_string_list() {
  local -n items_ref="$1"
  local item
  for item in "${items_ref[@]}"; do
    printf -- '- %s\n' "$item"
  done
}

json_bool() {
  if [ "$1" = 'true' ]; then
    printf 'true'
  else
    printf 'false'
  fi
}

find_optional_arg() {
  local needle="$1"
  shift
  local arg
  for arg in "$@"; do
    if [ "$arg" = "$needle" ]; then
      return 0
    fi
  done
  return 1
}

find_workspace_root() {
  if [ -n "${CODESPEC_WORKSPACE_ROOT:-}" ] && [ -f "${CODESPEC_WORKSPACE_ROOT}/.codespec/codespec" ]; then
    printf '%s\n' "$CODESPEC_WORKSPACE_ROOT"
    return
  fi

  local candidate
  candidate="$(dirname "$FRAMEWORK_ROOT")"
  if [ -f "$candidate/.codespec/codespec" ]; then
    printf '%s\n' "$candidate"
    return
  fi

  local dir="$PWD"
  while [ "$dir" != "/" ]; do
    if [ -f "$dir/.codespec/codespec" ]; then
      printf '%s\n' "$dir"
      return
    fi
    dir="$(dirname "$dir")"
  done

  die "could not locate workspace root (directory containing .codespec/)"
}

find_project_root() {
  if [ -n "${CODESPEC_PROJECT_ROOT:-}" ]; then
    (cd "$CODESPEC_PROJECT_ROOT" && pwd)
    return
  fi

  local dir
  dir="$PWD"
  while [ "$dir" != "/" ]; do
    if [ -f "$dir/meta.yaml" ]; then
      printf '%s\n' "$dir"
      return
    fi
    dir="$(dirname "$dir")"
  done

  local git_root metas meta_dir
  if git_root="$(git rev-parse --show-toplevel 2>/dev/null)"; then
    if [ -f "$git_root/meta.yaml" ]; then
      printf '%s\n' "$git_root"
      return
    fi

    mapfile -t metas < <(
      git -C "$git_root" ls-files -co --exclude-standard -- 'meta.yaml' '*/meta.yaml' 2>/dev/null |
        grep -vE '(^|/)(\.codespec|versions|project-docs)/' |
        sort -u
    )
    if [ "${#metas[@]}" -eq 1 ]; then
      meta_dir="$(dirname "${metas[0]}")"
      if [ "$meta_dir" = "." ]; then
        printf '%s\n' "$git_root"
      else
        (cd "$git_root/$meta_dir" && pwd)
      fi
      return
    fi

    printf '%s\n' "$git_root"
    return
  fi

  printf '%s\n' "$PWD"
}

match_path() {
  local file="$1"
  local pattern="$2"
  [ -n "$pattern" ] || return 1
  case "$file" in
    "$pattern") return 0 ;;
    $pattern) return 0 ;;
    *) return 1 ;;
  esac
}

render_template() {
  local src="$1"
  local dest="$2"
  local content
  content="$(<"$src")"
  content="${content//__DATE__/${RENDER_DATE:-}}"
  content="${content//__CHANGE_ID__/${RENDER_CHANGE_ID:-}}"
  content="${content//__BASE_VERSION__/${RENDER_BASE_VERSION:-}}"
  content="${content//__FEATURE_BRANCH__/${RENDER_FEATURE_BRANCH:-}}"
  content="${content//__EXECUTION_GROUP__/${RENDER_EXECUTION_GROUP:-}}"
  content="${content//__EXECUTION_BRANCH__/${RENDER_EXECUTION_BRANCH:-}}"
  content="${content//__UPDATED_BY__/${RENDER_UPDATED_BY:-}}"
  content="${content//__PHASE__/${RENDER_PHASE:-}}"
  content="${content//__STATUS__/${RENDER_STATUS:-}}"
  content="${content//__FOCUS_WORK_ITEM__/${RENDER_FOCUS_WORK_ITEM:-}}"
  content="${content//__ACTIVE_WORK_ITEMS__/${RENDER_ACTIVE_WORK_ITEMS:-[]}}"
  content="${content//__IMPLEMENTATION_BASE_REVISION__/${RENDER_IMPLEMENTATION_BASE_REVISION:-null}}"
  content="${content//__WI_ID__/${RENDER_WI_ID:-}}"
  content="${content//__DERIVED_FROM__/${RENDER_DERIVED_FROM:-}}"
  printf '%s\n' "$content" > "$dest"
}

validate_work_item_id() {
  local wi_id="$1"
  [[ "$wi_id" =~ ^WI-[0-9]{3}$ ]] || die "Invalid work item ID format: '$wi_id' (expected WI-XXX where X is a digit)"
}

validate_stable_version() {
  local stable_version="$1"
  [ -n "$stable_version" ] || die 'Invalid stable version: empty value'
  [[ "$stable_version" =~ ^[A-Za-z0-9._-]+$ ]] || die "Invalid stable version: '$stable_version' (use letters, digits, dot, underscore, or dash)"
  [[ "$stable_version" != *..* ]] || die "Invalid stable version: '$stable_version' must not contain '..'"
}

copy_dir_contents() {
  local src="$1"
  local dest="$2"
  mkdir -p "$dest"
  if [ -d "$src" ]; then
    cp -R "$src/." "$dest/"
  fi
}

current_git_branch() {
  local project_root="$1"
  if git -C "$project_root" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    git -C "$project_root" symbolic-ref --quiet --short HEAD 2>/dev/null || printf 'detached'
    return
  fi
  printf 'none'
}

current_git_revision() {
  local project_root="$1"
  if git -C "$project_root" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    git -C "$project_root" rev-parse HEAD
    return
  fi
  printf 'null'
}

require_git_repo() {
  local project_root="$1"
  git -C "$project_root" rev-parse --is-inside-work-tree >/dev/null 2>&1 || die "git repository not found at $project_root"
}

validate_git_revision() {
  local project_root="$1"
  local revision="$2"
  [ -n "$revision" ] || return 1
  [ "$revision" != 'null' ] || return 1
  git -C "$project_root" rev-parse --verify "${revision}^{commit}" >/dev/null 2>&1
}

ensure_clean_git_worktree() {
  local project_root="$1"
  git -C "$project_root" diff --quiet --ignore-submodules -- || die 'submit-pr requires a clean git working tree'
  git -C "$project_root" diff --cached --quiet --ignore-submodules -- || die 'submit-pr requires a clean git working tree'
}

ensure_deployed_source_revision_current() {
  local project_root="$1"
  local deployment_file="$project_root/deployment.md"
  local source_revision file allowed_patterns=(
    "meta.yaml"
    "spec.md"
    "design.md"
    "deployment.md"
    "testing.md"
    "AGENTS.md"
    "CLAUDE.md"
    "work-items/**"
    "contracts/**"
    "spec-appendices/**"
    "design-appendices/**"
    "reviews/**"
    "scripts/codespec-deploy"
  )

  [ -f "$deployment_file" ] || die 'submit-pr requires deployment.md'
  source_revision="$(markdown_section_scalar "$deployment_file" '## Execution Evidence' 'source_revision')"
  is_placeholder_value "$source_revision" && die 'deployment.md source_revision is missing'
  validate_git_revision "$project_root" "$source_revision" || die "deployment.md source_revision is not a valid commit: $source_revision"

  while IFS= read -r file; do
    [ -n "$file" ] || continue
    local ok=0
    local pattern
    for pattern in "${allowed_patterns[@]}"; do
      if match_path "$file" "$pattern"; then
        ok=1
        break
      fi
    done
    [ "$ok" -eq 1 ] || die "submit-pr includes source changes after deployed source_revision: $file"
  done < <(git -C "$project_root" diff --name-only --diff-filter=ACMRD "$source_revision..HEAD")
}

resolve_default_branch() {
  local project_root="$1"
  local remote_head
  remote_head="$(git -C "$project_root" symbolic-ref --quiet --short refs/remotes/origin/HEAD 2>/dev/null || true)"
  if [ -n "$remote_head" ]; then
    printf '%s\n' "${remote_head#origin/}"
    return
  fi

  if git -C "$project_root" show-ref --verify --quiet refs/heads/main; then
    printf 'main\n'
    return
  fi

  if git -C "$project_root" show-ref --verify --quiet refs/heads/master; then
    printf 'master\n'
    return
  fi

  die 'could not resolve default branch; pass --base <branch>'
}

extract_markdown_section_text() {
  local file="$1"
  local header="$2"
  awk -v header="$header" '
    function is_header_alias(line, expected) {
      if (line == expected) return 1
      if (expected == "## Summary" && line == "## 1. 需求概览") return 1
      return 0
    }
    is_header_alias($0, header) {
      in_section = 1
      next
    }
    in_section && /^## / {
      exit
    }
    in_section {
      print
    }
  ' "$file"
}

submit_pr_body_file() {
  local project_root="$1"
  local stable_version="$2"
  local meta="$project_root/meta.yaml"
  local deployment="$project_root/deployment.md"
  local spec="$project_root/spec.md"
  local tmp summary acceptance_notes execution_ref deployed_revision source_revision
  tmp="$(mktemp)"
  summary="$(extract_markdown_section_text "$spec" '## Summary' | sed '/^[[:space:]]*$/d' | head -n 3)"
  acceptance_notes="$(markdown_section_scalar "$deployment" '## Acceptance Conclusion' 'notes')"
  execution_ref="$(markdown_section_scalar "$deployment" '## Execution Evidence' 'execution_ref')"
  deployed_revision="$(markdown_section_scalar "$deployment" '## Execution Evidence' 'deployed_revision')"
  source_revision="$(markdown_section_scalar "$deployment" '## Execution Evidence' 'source_revision')"
  cat > "$tmp" <<EOF
## Summary

change_id: $(yaml_scalar "$meta" change_id)
stable_version: $stable_version

${summary:-No summary captured.}

## Acceptance

$acceptance_notes

## Deployment Evidence

- execution_ref: $execution_ref
- deployed_revision: $deployed_revision
- source_revision: $source_revision
EOF
  printf '%s\n' "$tmp"
}

resolve_promoted_base_version() {
  local workspace_root="$1"
  local current_change_id="$2"
  local versions_dir="$workspace_root/versions"
  local direct_meta="$versions_dir/$current_change_id/meta.yaml"

  if [ -f "$direct_meta" ] && [ "$(yaml_scalar "$direct_meta" change_id)" = "$current_change_id" ]; then
    printf '%s\n' "$current_change_id"
    return
  fi

  [ -d "$versions_dir" ] || die "versions directory not found: $versions_dir"

  local candidate_lines=""
  local meta_file version_dir version_name archived_change_id promoted_at promoted_flag mtime
  while IFS= read -r -d '' meta_file; do
    version_dir="$(dirname "$meta_file")"
    version_name="$(basename "$version_dir")"
    archived_change_id="$(yaml_scalar "$meta_file" change_id)"
    [ "$archived_change_id" = "$current_change_id" ] || continue

    promoted_at="$(yq eval '.promoted_at // ""' "$meta_file")"
    promoted_flag=0
    if [ -n "$promoted_at" ]; then
      promoted_flag=1
    fi
    mtime="$(stat -c '%Y' "$version_dir")"

    candidate_lines+="$promoted_flag"$'\t'"$promoted_at"$'\t'"$mtime"$'\t'"$version_name"$'\n'
  done < <(find "$versions_dir" -mindepth 2 -maxdepth 2 -name meta.yaml -print0)

  [ -n "$candidate_lines" ] || die "current completed dossier has not been promoted yet (run complete-change <stable-version> first)"

  printf '%s' "$candidate_lines" \
    | sort -t $'\t' -k1,1nr -k2,2r -k3,3nr -k4,4r \
    | head -n 1 \
    | cut -f4
}

branch_alignment_status() {
  local project_root="$1"
  local expected_branch="$2"
  local actual_branch
  actual_branch="$(current_git_branch "$project_root")"

  if [ "$expected_branch" = "null" ]; then
    printf 'not_applicable'
    return
  fi

  [ "$actual_branch" = "$expected_branch" ] && printf 'aligned' || printf 'mismatch'
}

meta_update() {
  local meta_file="$1"
  shift
  TODAY="$(date +%F)" UPDATED_BY="codespec-cli" yq eval "$* | .updated_at = env(TODAY) | .updated_by = env(UPDATED_BY)" -i "$meta_file"
}

# Atomic meta update with postcondition verification.
# Backs up meta.yaml, applies updates, runs metadata-consistency, rolls back on failure.
atomic_meta_update() {
  local meta_file="$1"
  shift
  local project_root
  project_root="$(dirname "$meta_file")"
  local backup
  backup="$(mktemp)"
  cp "$meta_file" "$backup"

  set +e
  meta_update "$meta_file" "$@"
  local update_rc=$?
  if [ "$update_rc" -ne 0 ]; then
    cp "$backup" "$meta_file"
    rm -f "$backup"
    die "meta_update failed (rc=${update_rc})"
  fi

  local gate_output gate_rc
  gate_output="$(CODESPEC_PROJECT_ROOT="$project_root" "$FRAMEWORK_ROOT/scripts/check-gate.sh" metadata-consistency 2>&1)"
  gate_rc=$?
  set -e

  if [ "$gate_rc" -ne 0 ]; then
    cp "$backup" "$meta_file"
    rm -f "$backup"
    die "post-update metadata-consistency check failed, rolled back: $gate_output"
  fi
  rm -f "$backup"
}

trim_value() {
  local value="$1"
  value="${value#"${value%%[![:space:]]*}"}"
  value="${value%"${value##*[![:space:]]}"}"
  printf '%s' "$value"
}

is_placeholder_value() {
  local value normalized
  value="$(trim_value "$1")"
  [ -n "$value" ] || return 0

  normalized="$(printf '%s' "$value" | tr '[:upper:]' '[:lower:]' | tr -d "'\"")"
  case "$normalized" in
    null|pending|todo|tbd|placeholder|none|yyyy-mm-dd|待填写|待补充|待确认)
      return 0
      ;;
  esac

  [[ "$normalized" =~ ^\[[^]]+\]$ ]] && return 0
  return 1
}

markdown_section_scalar() {
  local file="$1"
  local header="$2"
  local key="$3"
  awk -v header="$header" -v key="$key" '
    function is_header_alias(line, expected) {
      if (line == expected) return 1
      if (expected == "## Deployment Plan" && line == "## 1. 发布对象与环境") return 1
      if (expected == "## Execution Evidence" && line == "## 3. 执行证据") return 1
      if (expected == "## Verification Results" && line == "## 4. 运行验证") return 1
      if (expected == "## Acceptance Conclusion" && line == "## 6. 人工验收与收口") return 1
      return 0
    }
    is_header_alias($0, header) {
      in_section = 1
      next
    }
    in_section && /^## / {
      exit
    }
    in_section && $0 ~ "^[[:space:]]*-?[[:space:]]*" key ":[[:space:]]*" {
      line = $0
      sub("^[[:space:]]*-?[[:space:]]*" key ":[[:space:]]*", "", line)
      sub(/[[:space:]]*$/, "", line)
      print line
      exit
    }
  ' "$file"
}

replace_markdown_section() {
  local file="$1"
  local header="$2"
  local replacement="$3"
  local tmp
  tmp="$(mktemp)"

  awk -v header="$header" -v replacement="$replacement" '
    function is_header_alias(line, expected) {
      if (line == expected) return 1
      if (expected == "## Execution Evidence" && line == "## 3. 执行证据") return 1
      if (expected == "## Verification Results" && line == "## 4. 运行验证") return 1
      if (expected == "## Acceptance Conclusion" && line == "## 6. 人工验收与收口") return 1
      return 0
    }
    BEGIN {
      in_section = 0
      replaced = 0
      replacement_lines = split(replacement, lines, /\n/)
    }
    is_header_alias($0, header) {
      print
      for (i = 1; i <= replacement_lines; i++) {
        print lines[i]
      }
      in_section = 1
      replaced = 1
      next
    }
    in_section && /^## / {
      in_section = 0
    }
    !in_section {
      print
    }
    END {
      if (!replaced) {
        exit 2
      }
    }
  ' "$file" > "$tmp" || {
    rm -f "$tmp"
    die "missing section ${header} in ${file}"
  }

  mv "$tmp" "$file"
}

archive_dossier() {
  local stable_version="$1"
  local project_root="$2"
  local workspace_root="$3"
  local target_root="$workspace_root/versions/$stable_version"
  [ ! -e "$target_root" ] || die "target version already exists: versions/$stable_version"

  mkdir -p "$target_root"
  cp "$project_root/meta.yaml" "$target_root/meta.yaml"
  cp "$project_root/spec.md" "$target_root/spec.md"
  cp "$project_root/design.md" "$target_root/design.md"
  [ -f "$project_root/testing.md" ] && cp "$project_root/testing.md" "$target_root/testing.md"
  [ -f "$project_root/deployment.md" ] && cp "$project_root/deployment.md" "$target_root/deployment.md"
  [ -f "$project_root/CLAUDE.md" ] && cp "$project_root/CLAUDE.md" "$target_root/CLAUDE.md"
  [ -f "$project_root/AGENTS.md" ] && cp "$project_root/AGENTS.md" "$target_root/AGENTS.md"
  copy_dir_contents "$project_root/work-items" "$target_root/work-items"
  copy_dir_contents "$project_root/reviews" "$target_root/reviews"
  copy_dir_contents "$project_root/contracts" "$target_root/contracts"
  copy_dir_contents "$project_root/spec-appendices" "$target_root/spec-appendices"
  copy_dir_contents "$project_root/design-appendices" "$target_root/design-appendices"
  if [ -f "$project_root/scripts/codespec-deploy" ]; then
    mkdir -p "$target_root/scripts"
    cp "$project_root/scripts/codespec-deploy" "$target_root/scripts/codespec-deploy"
  fi

  if [ -d "$project_root/src" ]; then
    copy_dir_contents "$project_root/src" "$target_root/src"
  fi

  TODAY="$(date +%F)" \
  STABLE_VERSION="$stable_version" \
  PROMOTED_AT="$(date -u +%Y-%m-%dT%H:%M:%S.%NZ)" \
    yq eval '.status = "completed" | .stable_version = strenv(STABLE_VERSION) | .focus_work_item = null | .updated_at = env(TODAY) | .updated_by = "codespec-complete" | .promoted_version = strenv(STABLE_VERSION) | .promoted_at = strenv(PROMOTED_AT)' -i "$target_root/meta.yaml"
}


assert_phase_transition() {
  local current_phase="$1"
  local target_phase="$2"
  local current_status="$3"

  case "$target_phase" in
    Design)
      [ "$current_phase" = 'Requirement' ] || die "cannot move from ${current_phase} to ${target_phase}"
      ;;
    Implementation)
      if [ "$current_phase" = 'Design' ] || [ "$current_phase" = 'Implementation' ]; then
        return
      fi
      die "cannot move from ${current_phase} to ${target_phase}"
      ;;
    Testing)
      [ "$current_phase" = 'Implementation' ] || die "cannot move from ${current_phase} to ${target_phase}"
      ;;
    Deployment)
      if [ "$current_phase" = 'Deployment' ] && [ "$current_status" = 'completed' ]; then
        return
      fi
      [ "$current_phase" = 'Testing' ] || die "cannot move from ${current_phase} to ${target_phase}"
      ;;
    *)
      die "unsupported target phase: ${target_phase}"
      ;;
  esac
}

parse_active_work_items_arg() {
  local raw="$1"
  if [ "$raw" = '[]' ]; then
    printf '[]'
    return
  fi

  local output='['
  local first=1
  local item
  IFS=',' read -r -a items <<< "$raw"
  for item in "${items[@]}"; do
    [ -n "$item" ] || continue
    # Validate WI ID format to prevent YAML injection
    if ! [[ "$item" =~ ^WI-[0-9]{3}$ ]]; then
      die "Invalid work item ID format: '$item' (expected WI-XXX where X is a digit)"
    fi
    if [ "$first" -eq 0 ]; then
      output+=', '
    fi
    output+="\"$item\""
    first=0
  done
  output+=']'
  printf '%s' "$output"
}

contains_exact_line() {
  local needle="$1"
  shift || true
  local item
  for item in "$@"; do
    [ "$item" = "$needle" ] && return 0
  done
  return 1
}

validate_authority_repair_gate() {
  local gate="$1"
  case "$gate" in
    design-quality|design-readiness|implementation-ready|implementation-start|active-work-items-complete|scope|contract-boundary|trace-consistency|verification|testing-coverage|deployment-plan-ready|deployment-readiness|promotion-criteria)
      ;;
    *)
      die "unsupported authority repair gate: $gate"
      ;;
  esac
}

validate_authority_repair_path() {
  local project_root="$1"
  local phase="$2"
  local path="$3"
  local meta="$project_root/meta.yaml"

  [ -n "$path" ] || die 'authority repair path must be non-empty'
  [[ "$path" != /* ]] || die "authority repair path must be relative: $path"
  [[ "$path" != *..* ]] || die "authority repair path must not contain '..': $path"

  case "$path" in
    meta.yaml|spec.md|src/**|src/*|Dockerfile|versions/**|versions/*|authority-repairs/**|authority-repairs/*)
      die "authority repair path is not allowed: $path"
      ;;
  esac

  case "$path" in
    design.md|testing.md)
      return 0
      ;;
    deployment.md)
      case "$phase" in
        Testing|Deployment) return 0 ;;
        *) die "deployment.md authority repair is only allowed in Testing/Deployment phase" ;;
      esac
      ;;
    contracts/*.md)
      if [ -f "$project_root/$path" ] && [ "$(grep '^status:' "$project_root/$path" | awk '{print $2}' || true)" = 'frozen' ]; then
        die "authority repair cannot modify frozen contract: $path"
      fi
      return 0
      ;;
  esac

  if [[ "$path" =~ ^work-items/(WI-[0-9]{3})\.yaml$ ]]; then
    local wi_id="${BASH_REMATCH[1]}"
    local active=()
    mapfile -t active < <(yaml_list "$meta" active_work_items | grep -vE '^(|null)$' || true)
    [ "${#active[@]}" -gt 0 ] || die 'authority repair work-item path requires active_work_items'
    contains_exact_line "$wi_id" "${active[@]}" || die "authority repair work-item path must reference an active work item: $path"
    [ -f "$project_root/$path" ] || die "authority repair work-item path does not exist: $path"
    return 0
  fi

  die "authority repair path is not allowed: $path"
}

parse_authority_repair_paths_arg() {
  local raw="$1"
  local project_root="$2"
  local phase="$3"
  [ -n "$raw" ] || die 'authority repair requires --paths'

  local item count=0
  IFS=',' read -r -a items <<< "$raw"
  for item in "${items[@]}"; do
    item="$(trim_value "$item")"
    [ -n "$item" ] || continue
    validate_authority_repair_path "$project_root" "$phase" "$item"
    printf '%s\n' "$item"
    count=$((count + 1))
  done
  [ "$count" -gt 0 ] || die 'authority repair requires at least one allowed path'
}

next_authority_repair_id() {
  local repair_dir="$1"
  local base candidate suffix
  base="REPAIR-$(date -u +%Y%m%d%H%M%S)"
  candidate="$base"
  suffix=1
  while [ -e "$repair_dir/$candidate.yaml" ]; do
    suffix=$((suffix + 1))
    candidate="${base}-${suffix}"
  done
  printf '%s\n' "$candidate"
}

active_authority_repair_id() {
  local meta="$1"
  yq eval '.active_authority_repair // "null"' "$meta"
}

authority_repair_begin() {
  require_yq
  local gate="${1:?usage: codespec authority-repair begin <gate> --paths <csv> --reason <reason>}"
  shift
  validate_authority_repair_gate "$gate"

  local paths_arg="" reason=""
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --paths)
        [ "$#" -ge 2 ] || die 'authority-repair begin --paths requires a value'
        paths_arg="$2"
        shift 2
        ;;
      --reason)
        [ "$#" -ge 2 ] || die 'authority-repair begin --reason requires a value'
        reason="$2"
        shift 2
        ;;
      *)
        die "unknown authority-repair begin option: $1"
        ;;
    esac
  done

  is_placeholder_value "$reason" && die 'authority repair reason is required'

  local project_root meta phase active repair_dir repair_id repair_file opened_at opened_revision paths=() path
  project_root="$(find_project_root)"
  meta="$project_root/meta.yaml"
  [ -f "$meta" ] || die "missing meta.yaml"
  phase="$(yaml_scalar "$meta" phase)"
  case "$phase" in
    Implementation|Testing|Deployment) ;;
    *) die "authority repair requires Implementation, Testing, or Deployment phase (got: $phase)" ;;
  esac

  active="$(active_authority_repair_id "$meta")"
  [ "$active" = 'null' ] || die "authority repair already active: $active"

  mapfile -t paths < <(parse_authority_repair_paths_arg "$paths_arg" "$project_root" "$phase")

  repair_dir="$project_root/authority-repairs"
  mkdir -p "$repair_dir"
  repair_id="$(next_authority_repair_id "$repair_dir")"
  repair_file="$repair_dir/$repair_id.yaml"
  opened_at="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
  opened_revision="$(current_git_revision "$project_root")"

  REPAIR_ID="$repair_id" \
  PHASE="$phase" \
  GATE="$gate" \
  REASON="$reason" \
  OPENED_AT="$opened_at" \
  OPENED_REVISION="$opened_revision" \
    yq eval -n '.repair_id = env(REPAIR_ID) | .status = "open" | .phase = env(PHASE) | .gate = env(GATE) | .reason = env(REASON) | .allowed_paths = [] | .opened_at = env(OPENED_AT) | .opened_revision = env(OPENED_REVISION) | .closed_at = null | .closed_revision = null | .evidence = null | .gate_result = null | .smoke_result = null' > "$repair_file"

  for path in "${paths[@]}"; do
    PATH_VALUE="$path" yq eval '.allowed_paths += [env(PATH_VALUE)]' -i "$repair_file"
  done

  set +e
  atomic_meta_update "$meta" ".active_authority_repair = \"$repair_id\""
  local update_rc=$?
  set -e
  if [ "$update_rc" -ne 0 ]; then
    rm -f "$repair_file"
    die "failed to activate authority repair: $repair_id"
  fi

  log "started authority repair: $repair_id"
  log "gate: $gate"
  log "allowed_paths: ${paths[*]}"
}

authority_repair_close() {
  require_yq
  local evidence=""
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --evidence)
        [ "$#" -ge 2 ] || die 'authority-repair close --evidence requires a value'
        evidence="$2"
        shift 2
        ;;
      *)
        die "unknown authority-repair close option: $1"
        ;;
    esac
  done
  is_placeholder_value "$evidence" && die 'authority repair close requires --evidence'

  local project_root meta repair_id repair_file gate gate_output smoke_output closed_at closed_revision backup_meta backup_repair metadata_output
  local gate_rc smoke_rc metadata_rc
  project_root="$(find_project_root)"
  meta="$project_root/meta.yaml"
  [ -f "$meta" ] || die "missing meta.yaml"
  repair_id="$(active_authority_repair_id "$meta")"
  [ "$repair_id" != 'null' ] || die 'no active authority repair'
  repair_file="$project_root/authority-repairs/$repair_id.yaml"
  [ -f "$repair_file" ] || die "missing authority repair record: authority-repairs/$repair_id.yaml"
  [ "$(yaml_scalar "$repair_file" status)" = 'open' ] || die "authority repair is not open: $repair_id"
  gate="$(yaml_scalar "$repair_file" gate)"
  validate_authority_repair_gate "$gate"

  set +e
  gate_output="$(CODESPEC_PROJECT_ROOT="$project_root" CODESPEC_AUTHORITY_REPAIR_CLOSING=1 "$FRAMEWORK_ROOT/scripts/check-gate.sh" "$gate" 2>&1)"
  gate_rc=$?
  set -e
  [ "$gate_rc" -eq 0 ] || die "authority repair close gate failed (${gate}): $gate_output"

  set +e
  smoke_output="$(CODESPEC_AUTHORITY_REPAIR_SMOKE_RUNNING=1 "$FRAMEWORK_ROOT/scripts/smoke.sh" 2>&1)"
  smoke_rc=$?
  set -e
  [ "$smoke_rc" -eq 0 ] || die "authority repair close smoke failed: $smoke_output"

  closed_at="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
  closed_revision="$(current_git_revision "$project_root")"
  backup_meta="$(mktemp)"
  backup_repair="$(mktemp)"
  cp "$meta" "$backup_meta"
  cp "$repair_file" "$backup_repair"

  set +e
  EVIDENCE="$evidence" CLOSED_AT="$closed_at" CLOSED_REVISION="$closed_revision" \
    yq eval '.status = "closed" | .closed_at = env(CLOSED_AT) | .closed_revision = env(CLOSED_REVISION) | .evidence = env(EVIDENCE) | .gate_result = "pass" | .smoke_result = "pass"' -i "$repair_file"
  metadata_rc=$?
  if [ "$metadata_rc" -eq 0 ]; then
    meta_update "$meta" '.active_authority_repair = null'
    metadata_rc=$?
  fi
  if [ "$metadata_rc" -eq 0 ]; then
    metadata_output="$(CODESPEC_PROJECT_ROOT="$project_root" "$FRAMEWORK_ROOT/scripts/check-gate.sh" metadata-consistency 2>&1)"
    metadata_rc=$?
  else
    metadata_output="authority repair close state update failed"
  fi
  set -e
  if [ "$metadata_rc" -ne 0 ]; then
    cp "$backup_meta" "$meta"
    cp "$backup_repair" "$repair_file"
    rm -f "$backup_meta" "$backup_repair"
    die "metadata-consistency failed while closing authority repair, rolled back: $metadata_output"
  fi

  rm -f "$backup_meta" "$backup_repair"
  log "closed authority repair: $repair_id"
}

authority_repair_status() {
  require_yq
  local project_root meta repair_id
  project_root="$(find_project_root)"
  meta="$project_root/meta.yaml"
  [ -f "$meta" ] || die "missing meta.yaml"
  repair_id="$(active_authority_repair_id "$meta")"
  printf 'active_authority_repair: %s\n' "$repair_id"
  if [ "$repair_id" != 'null' ] && [ -f "$project_root/authority-repairs/$repair_id.yaml" ]; then
    yq eval '.' "$project_root/authority-repairs/$repair_id.yaml"
  fi
}

authority_repair_cmd() {
  local subcmd="${1:-}"
  shift || true
  case "$subcmd" in
    begin)
      authority_repair_begin "$@"
      ;;
    close)
      authority_repair_close "$@"
      ;;
    status)
      authority_repair_status "$@"
      ;;
    *)
      die 'usage: codespec authority-repair <begin|close|status>'
      ;;
  esac
}



