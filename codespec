review_gates_cmd() {
  require_yq
  local target_phase="${1:?usage: codespec review-gates <target-phase> [--write]}"
  shift || true
  local write=false
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --write)
        write=true
        ;;
      *)
        die "unknown review-gates option: $1"
        ;;
    esac
    shift || true
  done

  case "$target_phase" in
    Design|Implementation|Testing) ;;
    *) die 'review-gates target-phase must be Design, Implementation, or Testing' ;;
  esac

  local project_root transition file from_phase review_file evidence_file rows=()
  local row gate envs command checked_at checked_revision output status result summary failures=0
  project_root="$(find_project_root)"
  transition="$(transition_for_target_phase "$target_phase")"
  [ -n "$transition" ] || die "no transition maps to target phase: $target_phase"
  file="$(gate_map_file)"
  from_phase="$(TRANSITION="$transition" yq eval -r '.transitions[strenv(TRANSITION)].from_phase' "$file")"
  review_file="$(review_file_path_for_transition "$project_root" "$transition")"
  evidence_file="$(mktemp)"
  printf 'gate_evidence: []\n' > "$evidence_file"

  mapfile -t rows < <(transition_gate_rows "$transition" no)
  for row in "${rows[@]}"; do
    IFS=$'\t' read -r gate envs <<< "$row"
    [ -n "$gate" ] || continue
    command="$(gate_command_string "$gate" "$envs")"
    checked_at="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
    checked_revision="$(current_git_revision "$project_root")"
    set +e
    output="$(run_mapped_gate "$project_root" "$gate" "$envs" 2>&1)"
    status=$?
    set -e
    if [ "$status" -eq 0 ]; then
      result=pass
    else
      result=fail
      failures=$((failures + 1))
    fi
    summary="$(printf '%s\n' "${output:-no output}" | tail -n 5 | tr '\n' '; ' | sed 's/[[:space:]]*;[[:space:]]*$//')"
    GATE="$gate" COMMAND="$command" RESULT="$result" CHECKED_AT="$checked_at" CHECKED_REVISION="$checked_revision" OUTPUT_SUMMARY="$summary" \
      yq eval '.gate_evidence += [{"gate": strenv(GATE), "command": strenv(COMMAND), "result": strenv(RESULT), "checked_at": strenv(CHECKED_AT), "checked_revision": strenv(CHECKED_REVISION), "output_summary": strenv(OUTPUT_SUMMARY)}]' -i "$evidence_file"
  done

  if [ "$write" = true ]; then
    mkdir -p "$(dirname "$review_file")"
    if [ ! -f "$review_file" ]; then
      {
        printf 'phase: %s\n' "$from_phase"
        printf 'verdict: pending\n'
        printf 'reviewed_by: pending\n'
        printf 'reviewed_at: pending\n'
        printf 'scope:\n'
        printf '  - spec.md\n'
        printf 'gate_evidence: []\n'
        printf 'findings:\n'
        printf '  - severity: none\n'
        printf '    summary: pending semantic review\n'
        printf 'residual_risk: pending\n'
        printf 'decision_notes: pending\n'
      } > "$review_file"
    fi
    yq eval-all 'select(fileIndex == 0).gate_evidence = select(fileIndex == 1).gate_evidence | select(fileIndex == 0)' "$review_file" "$evidence_file" > "$review_file.tmp"
    mv "$review_file.tmp" "$review_file"
    rm -f "$evidence_file"
    log "wrote gate evidence: ${review_file#$project_root/}"
  else
    cat "$evidence_file"
    rm -f "$evidence_file"
  fi

  [ "$failures" -eq 0 ] || die "$failures gate(s) failed while collecting review evidence"
}

