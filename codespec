migrate_requirement_phase() {
  require_yq
  local project_root="${1:?usage: codespec migrate-requirement-phase <project_root> [--apply]}"
  shift || true

  local apply_mode=false
  if find_optional_arg '--apply' "$@"; then
    apply_mode=true
  fi

  [ -d "$project_root" ] || die "project_root does not exist: $project_root"
  project_root="$(cd "$project_root" && pwd)"
  local meta="$project_root/meta.yaml"
  [ -f "$meta" ] || die "missing meta.yaml in $project_root"

  local phase
  phase="$(yaml_scalar "$meta" phase)"
  case "$phase" in
    Proposal|Requirements) ;;
    Requirement)
      log "project is already in Requirement phase"
      return
      ;;
    *)
      log "project is in $phase phase; no Requirement phase migration needed"
      return
      ;;
  esac

  if [ "$apply_mode" = false ]; then
    log "=== DRY RUN ==="
    log "project_root: $project_root"
    log "current phase: $phase"
    log "would update meta.yaml phase to Requirement"
    if [ -f "$project_root/reviews/requirements-review.yaml" ]; then
      log "would move reviews/requirements-review.yaml to reviews/design-review.yaml"
    fi
    log "run again with --apply to execute"
    return
  fi

  [ ! -f "$project_root/meta.yaml.bak" ] || die "backup already exists: meta.yaml.bak"
  cp "$meta" "$project_root/meta.yaml.bak"

  if [ -f "$project_root/reviews/requirements-review.yaml" ]; then
    [ ! -f "$project_root/reviews/design-review.yaml" ] || die "target review already exists: reviews/design-review.yaml"
    cp "$project_root/reviews/requirements-review.yaml" "$project_root/reviews/requirements-review.yaml.bak"
  fi

  yq eval '.phase = "Requirement"' -i "$meta"

  if [ -f "$project_root/reviews/requirements-review.yaml" ]; then
    sed -i 's/^phase: Proposal$/phase: Requirement/g; s/^phase: Requirements$/phase: Requirement/g' "$project_root/reviews/requirements-review.yaml"
    mv "$project_root/reviews/requirements-review.yaml" "$project_root/reviews/design-review.yaml"
  fi

  CODESPEC_PROJECT_ROOT="$project_root" "$FRAMEWORK_ROOT/scripts/check-gate.sh" metadata-consistency >/dev/null
  log "migrated project to Requirement phase"
}

reset_to_requirement() {
  require_yq
  local project_root workspace_root
  project_root="$(find_project_root)"
  workspace_root="$(find_workspace_root)"
  local meta="$project_root/meta.yaml"
  [ -f "$meta" ] || die "missing meta.yaml"

  local TODAY current_status current_phase change_id base_version
  TODAY="$(date +%F)"
  current_status="$(yaml_scalar "$meta" status)"
  current_phase="$(yaml_scalar "$meta" phase)"
  change_id="$(yaml_scalar "$meta" change_id)"

  [ "$current_status" = 'completed' ] || die 'reset-to-requirement requires completed status'
  [ "$current_phase" = 'Deployment' ] || die 'reset-to-requirement requires Deployment phase'
  base_version="$(resolve_promoted_base_version "$project_root" "$change_id")"

  local keep_contracts=false
  local force=false
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --reset-contracts)
        keep_contracts=false
        ;;
      --keep-contracts)
        keep_contracts=true
        ;;
      --force)
        force=true
        ;;
      *)
        die "unknown reset-to-requirement option: $1"
        ;;
    esac
    shift || true
  done

  if [ "$force" = false ]; then
    ensure_reset_worktree_clean "$project_root"
  fi

  local preserved_reviews=""
  if [ "$keep_contracts" = true ]; then
    local contract_blockers
    contract_blockers="$(legacy_wi_blocking_contract_records "$project_root")"
    if [ -n "$contract_blockers" ]; then
      printf '%s\n' "$contract_blockers" | sed -n '1,20p' >&2
      die "reset-to-requirement --keep-contracts requires contracts without legacy WI residue and valid freeze reviews"
    fi

    preserved_reviews="$(mktemp -d)"
    local contract freeze_review_ref
    if [ -d "$project_root/contracts" ]; then
      while IFS= read -r contract; do
        [ -f "$contract" ] || continue
        freeze_review_ref="$(legacy_wi_contract_scalar "$contract" freeze_review_ref)"
        [ -n "$freeze_review_ref" ] || continue
        [ "$freeze_review_ref" != "null" ] || continue
        [ -f "$project_root/$freeze_review_ref" ] || continue
        mkdir -p "$preserved_reviews/$(dirname "$freeze_review_ref")"
        cp "$project_root/$freeze_review_ref" "$preserved_reviews/$freeze_review_ref"
      done < <(find "$project_root/contracts" -maxdepth 1 -type f -name '*.md' -print 2>/dev/null | sort)
    fi
  fi

  log "resetting dossier to Requirement phase..."

  cp "$workspace_root/.codespec/templates/spec.md" "$project_root/spec.md"
  cp "$workspace_root/.codespec/templates/design.md" "$project_root/design.md"

  if [ -f "$workspace_root/.codespec/templates/testing.md" ]; then
    RENDER_PHASE="Requirement" \
      render_template "$workspace_root/.codespec/templates/testing.md" "$project_root/testing.md"
  else
    rm -f "$project_root/testing.md"
  fi
  rm -f "$project_root/deployment.md"

  rm -rf "$project_root/reviews"
  mkdir -p "$project_root/reviews"
  if [ -n "$preserved_reviews" ] && [ -d "$preserved_reviews/reviews" ]; then
    cp -R "$preserved_reviews/reviews/." "$project_root/reviews/"
  fi
  [ -z "$preserved_reviews" ] || rm -rf "$preserved_reviews"

  if [ "$keep_contracts" = false ]; then
    backup_project_directory "$project_root" contracts contracts.bak
    mkdir -p "$project_root/contracts"
  fi

  RENDER_DATE="$TODAY" \
  RENDER_CHANGE_ID="$base_version-next" \
  RENDER_BASE_VERSION="$base_version" \
  RENDER_PHASE="Requirement" \
  RENDER_STATUS="active" \
  RENDER_IMPLEMENTATION_BASE_REVISION="null" \
  RENDER_UPDATED_BY="codespec-reset" \
  render_template "$workspace_root/.codespec/templates/meta.yaml" "$project_root/meta.yaml"

  log "reset to Requirement phase"
  log "base_version: $base_version"
  log "new change_id: $base_version-next"
}

