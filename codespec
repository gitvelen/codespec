#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
FRAMEWORK_ROOT="$SCRIPT_DIR"

log() {
  printf '%s\n' "$*"
}

die() {
  printf 'ERROR: %s\n' "$*" >&2
  exit 1
}

require_yq() {
  command -v yq >/dev/null 2>&1 || die "yq is required"
}

yaml_scalar() {
  local file="$1"
  local key="$2"
  yq eval ".${key}" "$file"
}

yaml_list() {
  local file="$1"
  local key="$2"
  yq eval ".${key}[]" "$file" 2>/dev/null || true
}

json_string_array() {
  local first=1
  printf '['
  while [ "$#" -gt 0 ]; do
    if [ "$first" -eq 0 ]; then
      printf ', '
    fi
    printf '%s' "$1" | python3 -c 'import json,sys; print(json.dumps(sys.stdin.read()), end="")'
    first=0
    shift
  done
  printf ']'
}

json_object() {
  printf '{'
  local first=1
  while [ "$#" -gt 0 ]; do
    local key="$1"
    local value="$2"
    if [ "$first" -eq 0 ]; then
      printf ', '
    fi
    printf '%s' "$key" | python3 -c 'import json,sys; print(json.dumps(sys.stdin.read()), end="")'
    printf ': %s' "$value"
    first=0
    shift 2
  done
  printf '}'
}

json_quote() {
  printf '%s' "$1" | python3 -c 'import json,sys; print(json.dumps(sys.stdin.read()), end="")'
}

json_path_entry_object() {
  local path="$1"
  local when_clause="${2:-}"
  local read_hint="${3:-}"
  local args=("path" "$(json_quote "$path")")
  if [ -n "$when_clause" ]; then
    args+=("when" "$(json_quote "$when_clause")")
  fi
  if [ -n "$read_hint" ]; then
    args+=("read_hint" "$(json_quote "$read_hint")")
  fi
  json_object "${args[@]}"
}

json_path_entries() {
  local first=1
  printf '['
  while [ "$#" -gt 0 ]; do
    local path="$1"
    local when_clause="${2:-}"
    local read_hint="${3:-}"
    if [ "$first" -eq 0 ]; then
      printf ', '
    fi
    printf '%s' "$(json_path_entry_object "$path" "$when_clause" "$read_hint")"
    first=0
    shift 3
  done
  printf ']'
}

render_text_entry_line() {
  local path="$1"
  local read_hint="${2:-}"
  if [ -n "$read_hint" ]; then
    printf -- '- %s (%s)\n' "$path" "$read_hint"
  else
    printf -- '- %s\n' "$path"
  fi
}

render_text_triplets() {
  local -n entries_ref="$1"
  local idx
  for ((idx=0; idx<${#entries_ref[@]}; idx+=3)); do
    render_text_entry_line "${entries_ref[idx]}" "${entries_ref[idx+2]}"
  done
}

render_text_entry_choice() {
  local -n entries_ref="$1"
  local idx joined when_clause
  when_clause="${entries_ref[1]:-}"
  joined=""
  for ((idx=0; idx<${#entries_ref[@]}; idx+=3)); do
    if [ -n "$joined" ]; then
      joined+=" or "
    fi
    joined+="${entries_ref[idx]}"
  done
  printf -- '- %s (%s)\n' "$joined" "$when_clause"
}

render_text_string_list() {
  local -n items_ref="$1"
  local item
  for item in "${items_ref[@]}"; do
    printf -- '- %s\n' "$item"
  done
}

json_bool() {
  if [ "$1" = 'true' ]; then
    printf 'true'
  else
    printf 'false'
  fi
}

find_optional_arg() {
  local needle="$1"
  shift
  local arg
  for arg in "$@"; do
    if [ "$arg" = "$needle" ]; then
      return 0
    fi
  done
  return 1
}

find_workspace_root() {
  if [ -n "${CODESPEC_WORKSPACE_ROOT:-}" ] && [ -f "${CODESPEC_WORKSPACE_ROOT}/.codespec/codespec" ]; then
    printf '%s\n' "$CODESPEC_WORKSPACE_ROOT"
    return
  fi

  local candidate
  candidate="$(dirname "$FRAMEWORK_ROOT")"
  if [ -f "$candidate/.codespec/codespec" ]; then
    printf '%s\n' "$candidate"
    return
  fi

  local dir="$PWD"
  while [ "$dir" != "/" ]; do
    if [ -f "$dir/.codespec/codespec" ]; then
      printf '%s\n' "$dir"
      return
    fi
    dir="$(dirname "$dir")"
  done

  die "could not locate workspace root (directory containing .codespec/)"
}

find_project_root() {
  if [ -n "${CODESPEC_PROJECT_ROOT:-}" ]; then
    if git -C "$CODESPEC_PROJECT_ROOT" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
      git -C "$CODESPEC_PROJECT_ROOT" rev-parse --show-toplevel
      return
    fi
    printf '%s\n' "$CODESPEC_PROJECT_ROOT"
    return
  fi

  if git rev-parse --show-toplevel >/dev/null 2>&1; then
    git rev-parse --show-toplevel
    return
  fi

  printf '%s\n' "$PWD"
}

render_template() {
  local src="$1"
  local dest="$2"
  local content
  content="$(<"$src")"
  content="${content//__DATE__/${RENDER_DATE:-}}"
  content="${content//__CHANGE_ID__/${RENDER_CHANGE_ID:-}}"
  content="${content//__BASE_VERSION__/${RENDER_BASE_VERSION:-}}"
  content="${content//__FEATURE_BRANCH__/${RENDER_FEATURE_BRANCH:-}}"
  content="${content//__EXECUTION_GROUP__/${RENDER_EXECUTION_GROUP:-}}"
  content="${content//__EXECUTION_BRANCH__/${RENDER_EXECUTION_BRANCH:-}}"
  content="${content//__UPDATED_BY__/${RENDER_UPDATED_BY:-}}"
  content="${content//__PHASE__/${RENDER_PHASE:-}}"
  content="${content//__STATUS__/${RENDER_STATUS:-}}"
  content="${content//__FOCUS_WORK_ITEM__/${RENDER_FOCUS_WORK_ITEM:-}}"
  content="${content//__ACTIVE_WORK_ITEMS__/${RENDER_ACTIVE_WORK_ITEMS:-[]}}"
  content="${content//__WI_ID__/${RENDER_WI_ID:-}}"
  content="${content//__DERIVED_FROM__/${RENDER_DERIVED_FROM:-}}"
  printf '%s\n' "$content" > "$dest"
}

copy_dir_contents() {
  local src="$1"
  local dest="$2"
  mkdir -p "$dest"
  if [ -d "$src" ]; then
    cp -R "$src/." "$dest/"
  fi
}

current_git_branch() {
  local project_root="$1"
  if git -C "$project_root" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    git -C "$project_root" symbolic-ref --quiet --short HEAD 2>/dev/null || printf 'detached'
    return
  fi
  printf 'none'
}

branch_alignment_status() {
  local project_root="$1"
  local expected_branch="$2"
  local actual_branch
  actual_branch="$(current_git_branch "$project_root")"

  if [ "$expected_branch" = "null" ]; then
    printf 'not_applicable'
    return
  fi

  [ "$actual_branch" = "$expected_branch" ] && printf 'aligned' || printf 'mismatch'
}

meta_update() {
  local meta_file="$1"
  shift
  TODAY="$(date +%F)" UPDATED_BY="codespec-cli" yq eval "$* | .updated_at = env(TODAY) | .updated_by = env(UPDATED_BY)" -i "$meta_file"
}


assert_phase_transition() {
  local current_phase="$1"
  local target_phase="$2"
  local current_status="$3"

  case "$target_phase" in
    Requirements)
      [ "$current_phase" = 'Proposal' ] || die "cannot move from ${current_phase} to ${target_phase}"
      ;;
    Design)
      [ "$current_phase" = 'Requirements' ] || die "cannot move from ${current_phase} to ${target_phase}"
      ;;
    Implementation)
      if [ "$current_phase" = 'Design' ] || [ "$current_phase" = 'Implementation' ]; then
        return
      fi
      die "cannot move from ${current_phase} to ${target_phase}"
      ;;
    Testing)
      [ "$current_phase" = 'Implementation' ] || die "cannot move from ${current_phase} to ${target_phase}"
      ;;
    Deployment)
      if [ "$current_phase" = 'Deployment' ] && [ "$current_status" = 'completed' ]; then
        return
      fi
      [ "$current_phase" = 'Testing' ] || die "cannot move from ${current_phase} to ${target_phase}"
      ;;
    *)
      die "unsupported target phase: ${target_phase}"
      ;;
  esac
}

parse_active_work_items_arg() {
  local raw="$1"
  if [ "$raw" = '[]' ]; then
    printf '[]'
    return
  fi

  local output='['
  local first=1
  local item
  IFS=',' read -r -a items <<< "$raw"
  for item in "${items[@]}"; do
    [ -n "$item" ] || continue
    # Validate WI ID format to prevent YAML injection
    if ! [[ "$item" =~ ^WI-[0-9]{3}$ ]]; then
      die "Invalid work item ID format: '$item' (expected WI-XXX where X is a digit)"
    fi
    if [ "$first" -eq 0 ]; then
      output+=', '
    fi
    output+="\"$item\""
    first=0
  done
  output+=']'
  printf '%s' "$output"
}



add_work_item() {
  require_yq
  local wi_id="${1:?usage: codespec add-work-item <WI-ID>}"
  local project_root
  project_root="$(find_project_root)"
  local wi_file="$project_root/work-items/$wi_id.yaml"
  [ ! -f "$wi_file" ] || die "work item already exists: $wi_id"

  RENDER_WI_ID="$wi_id" \
  RENDER_DERIVED_FROM="design.md#work-item-derivation" \
  render_template "$FRAMEWORK_ROOT/templates/work-item.yaml" "$wi_file"

  log "created work item: work-items/$wi_id.yaml"
}

materialize_deployment() {
  require_yq
  local project_root
  project_root="$(find_project_root)"
  local target="$project_root/deployment.md"
  [ ! -f "$target" ] || die "deployment.md already exists"
  cp "$FRAMEWORK_ROOT/templates/deployment.md" "$target"
  log "created deployment file: deployment.md"
}

start_requirements() {
  require_yq
  local project_root
  project_root="$(find_project_root)"
  local meta="$project_root/meta.yaml"
  [ -f "$meta" ] || die "missing meta.yaml"

  local current_phase current_status
  current_phase="$(yaml_scalar "$meta" phase)"
  current_status="$(yaml_scalar "$meta" status)"
  assert_phase_transition "$current_phase" 'Requirements' "$current_status"

  CODESPEC_PROJECT_ROOT="$project_root" CODESPEC_TARGET_PHASE='Requirements' "$FRAMEWORK_ROOT/scripts/check-gate.sh" proposal-maturity >/dev/null
  CODESPEC_PROJECT_ROOT="$project_root" CODESPEC_TARGET_PHASE='Requirements' "$FRAMEWORK_ROOT/scripts/check-gate.sh" review-verdict-present >/dev/null

  meta_update "$meta" '.phase = "Requirements" | .status = "active"'
  log "started Requirements phase"
}

start_design() {
  require_yq
  local project_root
  project_root="$(find_project_root)"
  local meta="$project_root/meta.yaml"
  [ -f "$meta" ] || die "missing meta.yaml"

  local current_phase current_status
  current_phase="$(yaml_scalar "$meta" phase)"
  current_status="$(yaml_scalar "$meta" status)"
  assert_phase_transition "$current_phase" 'Design' "$current_status"

  CODESPEC_PROJECT_ROOT="$project_root" CODESPEC_TARGET_PHASE='Design' "$FRAMEWORK_ROOT/scripts/check-gate.sh" requirements-approval >/dev/null
  CODESPEC_PROJECT_ROOT="$project_root" CODESPEC_TARGET_PHASE='Design' "$FRAMEWORK_ROOT/scripts/check-gate.sh" review-verdict-present >/dev/null

  meta_update "$meta" '.phase = "Design" | .status = "active"'
  log "started Design phase"
}

start_implementation() {
  require_yq
  local wi_id="${1:?usage: codespec start-implementation <WI-ID>}"
  local project_root
  project_root="$(find_project_root)"
  local meta="$project_root/meta.yaml"
  [ -f "$meta" ] || die "missing meta.yaml"
  [ -f "$project_root/work-items/$wi_id.yaml" ] || die "missing work item: work-items/$wi_id.yaml"

  local current_phase current_status active_count
  current_phase="$(yaml_scalar "$meta" phase)"
  current_status="$(yaml_scalar "$meta" status)"
  assert_phase_transition "$current_phase" 'Implementation' "$current_status"

  CODESPEC_PROJECT_ROOT="$project_root" CODESPEC_FOCUS_WI="$wi_id" CODESPEC_TARGET_PHASE='Implementation' "$FRAMEWORK_ROOT/scripts/check-gate.sh" implementation-ready >/dev/null
  CODESPEC_PROJECT_ROOT="$project_root" CODESPEC_TARGET_PHASE='Implementation' "$FRAMEWORK_ROOT/scripts/check-gate.sh" review-verdict-present >/dev/null

  active_count="$(yq eval '.active_work_items | length' "$meta")"
  if [ "$active_count" = '0' ]; then
    meta_update "$meta" ".phase = \"Implementation\" | .status = \"active\" | .focus_work_item = \"$wi_id\" | .active_work_items = [\"$wi_id\"]"
  else
    if ! yq eval '.active_work_items[]' "$meta" 2>/dev/null | grep -Fxq "$wi_id"; then
      meta_update "$meta" ".phase = \"Implementation\" | .status = \"active\" | .focus_work_item = \"$wi_id\" | .active_work_items += [\"$wi_id\"]"
    else
      meta_update "$meta" ".phase = \"Implementation\" | .status = \"active\" | .focus_work_item = \"$wi_id\""
    fi
  fi
  log "started Implementation phase: focus=$wi_id"
}

start_testing() {
  require_yq
  local project_root
  project_root="$(find_project_root)"
  local meta="$project_root/meta.yaml"
  [ -f "$meta" ] || die "missing meta.yaml"

  local current_phase current_status
  current_phase="$(yaml_scalar "$meta" phase)"
  current_status="$(yaml_scalar "$meta" status)"
  assert_phase_transition "$current_phase" 'Testing' "$current_status"

  CODESPEC_PROJECT_ROOT="$project_root" "$FRAMEWORK_ROOT/scripts/check-gate.sh" metadata-consistency >/dev/null
  CODESPEC_PROJECT_ROOT="$project_root" "$FRAMEWORK_ROOT/scripts/check-gate.sh" scope >/dev/null
  CODESPEC_PROJECT_ROOT="$project_root" "$FRAMEWORK_ROOT/scripts/check-gate.sh" contract-boundary >/dev/null
  CODESPEC_PROJECT_ROOT="$project_root" "$FRAMEWORK_ROOT/scripts/check-gate.sh" verification >/dev/null

  meta_update "$meta" '.phase = "Testing" | .status = "active" | .focus_work_item = null | .execution_branch = null | .execution_group = null'
  log "started Testing phase"
}

start_deployment() {
  require_yq
  local project_root
  project_root="$(find_project_root)"
  local meta="$project_root/meta.yaml"
  [ -f "$meta" ] || die "missing meta.yaml"

  local current_phase current_status deployment_file
  current_phase="$(yaml_scalar "$meta" phase)"
  current_status="$(yaml_scalar "$meta" status)"
  assert_phase_transition "$current_phase" 'Deployment' "$current_status"

  CODESPEC_PROJECT_ROOT="$project_root" "$FRAMEWORK_ROOT/scripts/check-gate.sh" trace-consistency >/dev/null
  CODESPEC_PROJECT_ROOT="$project_root" "$FRAMEWORK_ROOT/scripts/check-gate.sh" verification >/dev/null

  deployment_file="$project_root/deployment.md"
  if [ ! -f "$deployment_file" ]; then
    cp "$FRAMEWORK_ROOT/templates/deployment.md" "$deployment_file"
  fi

  meta_update "$meta" '.phase = "Deployment" | .status = "active" | .focus_work_item = null'
  log "started Deployment phase"
}

complete_change() {
  require_yq
  local project_root
  project_root="$(find_project_root)"
  local meta="$project_root/meta.yaml"
  [ -f "$meta" ] || die "missing meta.yaml"

  local current_phase
  current_phase="$(yaml_scalar "$meta" phase)"
  [ "$current_phase" = 'Deployment' ] || die 'complete-change requires Deployment phase'

  CODESPEC_PROJECT_ROOT="$project_root" "$FRAMEWORK_ROOT/scripts/check-gate.sh" promotion-criteria >/dev/null

  meta_update "$meta" '.status = "completed" | .focus_work_item = null | .active_work_items = []'
  log "completed change"
}

