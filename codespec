    atomic_meta_update "$meta" ".phase = \"Implementation\" | .status = \"active\" | .focus_work_item = \"$wi_id\" | .implementation_base_revision = \"$implementation_base_revision\" | .active_work_items = [\"$wi_id\"] | .gate_evidence.implementation_entry = {\"gate\": \"design-quality\", \"status\": \"pass\", \"checked_at\": \"$design_quality_checked_at\", \"checked_revision\": \"$design_quality_revision\", \"focus_work_item\": \"$wi_id\"}"
  else
