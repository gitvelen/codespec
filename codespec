reset_to_proposal() {
  require_yq
  local project_root workspace_root
  project_root="$(find_project_root)"
  workspace_root="$(find_workspace_root)"
  local meta="$project_root/meta.yaml"
  [ -f "$meta" ] || die "missing meta.yaml"

  local current_status current_phase change_id
  current_status="$(yaml_scalar "$meta" status)"
  current_phase="$(yaml_scalar "$meta" phase)"
  change_id="$(yaml_scalar "$meta" change_id)"

  [ "$current_status" = 'completed' ] || die 'reset-to-proposal requires completed status'
  [ "$current_phase" = 'Deployment' ] || die 'reset-to-proposal requires Deployment phase'

  [ -d "$workspace_root/versions/$change_id" ] || die "version $change_id not found in versions/ (run promote-version first)"

  local keep_contracts=false
  if find_optional_arg '--keep-contracts' "$@"; then
    keep_contracts=true
  fi

  log "resetting dossier to Proposal phase..."

  cp "$workspace_root/.codespec/templates/spec.md" "$project_root/spec.md"
  cp "$workspace_root/.codespec/templates/design.md" "$project_root/design.md"

  rm -f "$project_root/testing.md"
  rm -f "$project_root/deployment.md"
  rm -rf "$project_root/work-items"
  mkdir -p "$project_root/work-items"

  rm -rf "$project_root/reviews"
  mkdir -p "$project_root/reviews"
  TODAY="$(date +%F)"
  cat > "$project_root/reviews/requirements-review.yaml" <<EOF
phase: Proposal
verdict: approved
reviewed_by: codespec-reset
reviewed_at: $TODAY
EOF

  if [ "$keep_contracts" = false ]; then
    rm -rf "$project_root/contracts"
    mkdir -p "$project_root/contracts"
  fi

  RENDER_DATE="$TODAY" \
  RENDER_CHANGE_ID="$change_id-next" \
  RENDER_BASE_VERSION="$change_id" \
  RENDER_FEATURE_BRANCH="$(current_git_branch "$project_root")" \
  RENDER_EXECUTION_GROUP="null" \
  RENDER_EXECUTION_BRANCH="null" \
  RENDER_PHASE="Proposal" \
  RENDER_STATUS="active" \
  RENDER_FOCUS_WORK_ITEM="null" \
  RENDER_ACTIVE_WORK_ITEMS="[]" \
  RENDER_UPDATED_BY="codespec-reset" \
  render_template "$workspace_root/.codespec/templates/meta.yaml" "$project_root/meta.yaml"

  log "reset to Proposal phase"
  log "base_version: $change_id"
  log "new change_id: $change_id-next"
}

set_active_work_items() {
  require_yq
  local raw="${1:?usage: codespec set-active-work-items <WI-001,WI-002|[]>}"
  local project_root
  project_root="$(find_project_root)"
  local meta="$project_root/meta.yaml"
  [ -f "$meta" ] || die "missing meta.yaml"

  local yaml_array item
  yaml_array="$(parse_active_work_items_arg "$raw")"

  local phase focus_wi
  phase="$(yaml_scalar "$meta" phase)"
  focus_wi="$(yaml_scalar "$meta" focus_work_item)"

  if [ "$phase" = 'Implementation' ] && [ "$yaml_array" = '[]' ] && [ "$focus_wi" != 'null' ]; then
    die 'cannot clear active_work_items while focus_work_item is set in Implementation phase'
  fi
  if [ "$phase" = 'Implementation' ] && [ "$focus_wi" != 'null' ] && [ "$yaml_array" != '[]' ]; then
    printf '%s\n' "$raw" | tr ',' '\n' | grep -Fxq "$focus_wi" || die "focus_work_item ${focus_wi} must be included in active_work_items"
  fi

  meta_update "$meta" ".active_work_items = ${yaml_array}"
  log "updated active work items"
}

promote_version() {
  require_yq
  local stable_version="${1:?usage: codespec promote-version <stable-version>}"
  local workspace_root project_root
  workspace_root="$(find_workspace_root)"
  project_root="$(find_project_root)"
  local meta="$project_root/meta.yaml"
  [ -f "$meta" ] || die "missing meta.yaml"

  CODESPEC_PROJECT_ROOT="$project_root" "$FRAMEWORK_ROOT/scripts/check-gate.sh" promotion >/dev/null

  local target_root="$workspace_root/versions/$stable_version"
  [ ! -e "$target_root" ] || die "target version already exists: versions/$stable_version"

  mkdir -p "$target_root"
  cp "$project_root/meta.yaml" "$target_root/meta.yaml"
  cp "$project_root/spec.md" "$target_root/spec.md"
  cp "$project_root/design.md" "$target_root/design.md"
  [ -f "$project_root/testing.md" ] && cp "$project_root/testing.md" "$target_root/testing.md"
  [ -f "$project_root/deployment.md" ] && cp "$project_root/deployment.md" "$target_root/deployment.md"
  [ -f "$project_root/CLAUDE.md" ] && cp "$project_root/CLAUDE.md" "$target_root/CLAUDE.md"
  [ -f "$project_root/AGENTS.md" ] && cp "$project_root/AGENTS.md" "$target_root/AGENTS.md"
  copy_dir_contents "$project_root/work-items" "$target_root/work-items"
  copy_dir_contents "$project_root/contracts" "$target_root/contracts"
  copy_dir_contents "$project_root/spec-appendices" "$target_root/spec-appendices"
  copy_dir_contents "$project_root/design-appendices" "$target_root/design-appendices"

  if [ -d "$project_root/src" ]; then
    copy_dir_contents "$project_root/src" "$target_root/src"
  fi

  TODAY="$(date +%F)" yq eval '.status = "completed" | .focus_work_item = null | .active_work_items = [] | .updated_at = env(TODAY) | .updated_by = "codespec-promote"' -i "$target_root/meta.yaml"

  log "promoted dossier"
  log "source: $project_root"
  log "target: versions/$stable_version"
}

list_versions() {
  require_yq
  local workspace_root
  workspace_root="$(find_workspace_root)"
  local versions_dir="$workspace_root/versions"

  [ -d "$versions_dir" ] || die "versions directory not found: $versions_dir"

  local output_json=false
  if find_optional_arg '--json' "$@"; then
    output_json=true
  fi

  if [ "$output_json" = true ]; then
    printf '[\n'
    local first=1
    for version_dir in "$versions_dir"/*; do
      [ -d "$version_dir" ] || continue
      local version_name
      version_name="$(basename "$version_dir")"
      local meta_file="$version_dir/meta.yaml"
      [ -f "$meta_file" ] || continue

      if [ "$first" -eq 0 ]; then
        printf ',\n'
      fi

      local change_id status base_version created_at
      change_id="$(yaml_scalar "$meta_file" change_id)"
      status="$(yaml_scalar "$meta_file" status)"
      base_version="$(yaml_scalar "$meta_file" base_version)"
      created_at="$(yaml_scalar "$meta_file" created_at)"

      printf '  {\n'
      printf '    "version": %s,\n' "$(json_quote "$version_name")"
      printf '    "change_id": %s,\n' "$(json_quote "$change_id")"
      printf '    "status": %s,\n' "$(json_quote "$status")"
      printf '    "base_version": %s,\n' "$(json_quote "$base_version")"
      printf '    "created_at": %s\n' "$(json_quote "$created_at")"
      printf '  }'

      first=0
    done
    printf '\n]\n'
  else
    printf 'Version\t\tCreated\t\tStatus\t\tBase Version\n'
    printf -- '-------\t\t-------\t\t------\t\t------------\n'
    for version_dir in "$versions_dir"/*; do
      [ -d "$version_dir" ] || continue
      local version_name
      version_name="$(basename "$version_dir")"
      local meta_file="$version_dir/meta.yaml"
      [ -f "$meta_file" ] || continue

      local change_id status base_version created_at
      change_id="$(yaml_scalar "$meta_file" change_id)"
      status="$(yaml_scalar "$meta_file" status)"
      base_version="$(yaml_scalar "$meta_file" base_version)"
      created_at="$(yaml_scalar "$meta_file" created_at)"

      printf '%s\t%s\t%s\t%s\n' "$version_name" "$created_at" "$status" "$base_version"
    done
  fi
}

install_hooks() {
  local project_root
  project_root="$(find_project_root)"
  "$FRAMEWORK_ROOT/scripts/install-hooks.sh" "$project_root"
}

status_cmd() {
  require_yq
  local project_root
  project_root="$(find_project_root)"
  local meta="$project_root/meta.yaml"
  [ -f "$meta" ] || die "missing meta.yaml"

  build_readset_model "$project_root"

  local git_branch execution_branch branch_alignment
  git_branch="$(current_git_branch "$project_root")"
  execution_branch="$(yaml_scalar "$meta" execution_branch)"
  branch_alignment="$(branch_alignment_status "$project_root" "$execution_branch")"

  printf 'project_root: %s\n' "$project_root"
  printf 'phase: %s\n' "$(yaml_scalar "$meta" phase)"
  printf 'status: %s\n' "$(yaml_scalar "$meta" status)"
  printf 'focus_work_item: %s\n' "$(yaml_scalar "$meta" focus_work_item)"
  printf 'feature_branch: %s\n' "$(yaml_scalar "$meta" feature_branch)"
  printf 'execution_group: %s\n' "$(yaml_scalar "$meta" execution_group)"
  printf 'execution_branch: %s\n' "$execution_branch"
  printf 'git_branch: %s\n' "$git_branch"
  printf 'branch_alignment: %s\n' "$branch_alignment"
  printf 'phase_capabilities.allowed:\n'
  render_text_string_list READSET_MODEL_PHASE_CAP_ALLOWED
  printf 'phase_capabilities.forbidden:\n'
  render_text_string_list READSET_MODEL_PHASE_CAP_FORBIDDEN
  printf 'authority.phase_policy: %s\n' "$READSET_MODEL_PHASE_POLICY"
}

build_readset_model() {
  local project_root="$1"
  local meta="$project_root/meta.yaml"
  [ -f "$meta" ] || die "missing meta.yaml"

  READSET_MODEL_PHASE="$(yaml_scalar "$meta" phase)"
  READSET_MODEL_FOCUS_WI="$(yaml_scalar "$meta" focus_work_item)"
  READSET_MODEL_WORK_ITEM_PATH='null'
  READSET_MODEL_PHASE_POLICY='../phase-review-policy.md'
  READSET_MODEL_PHASE_CAP_ALLOWED=()
  READSET_MODEL_PHASE_CAP_FORBIDDEN=()

  READSET_MODEL_ENTRY_FILES=(
    "AGENTS.md" "read exactly one" ""
    "CLAUDE.md" "read exactly one" ""
  )
  READSET_MODEL_MINIMAL_READSET=(
    "../lessons_learned.md" "" ""
    "../phase-review-policy.md" "" ""
    "meta.yaml" "" ""
    "spec.md" "" "read to <!-- SKELETON-END --> first"
    "design.md" "" "read Default Read Layer first"
  )
  READSET_MODEL_WORK_ITEM_ENTRY=()
  READSET_MODEL_CONTRACT_REFS=()
  READSET_MODEL_PHASE_DOCS=()
  READSET_MODEL_APPENDIX_SPEC=("spec-appendices/*" "only when default layer is insufficient" "")
  READSET_MODEL_APPENDIX_DESIGN=("design-appendices/*" "only when current slice requires drill-down" "")

  case "$READSET_MODEL_PHASE" in
    Proposal)
      READSET_MODEL_MINIMAL_READSET=(
        "../lessons_learned.md" "" ""
        "../phase-review-policy.md" "" ""
        "meta.yaml" "" ""
        "spec.md" "" "read to <!-- SKELETON-END --> first"
      )
      READSET_MODEL_PHASE_CAP_ALLOWED=(
        "authoritative dossier edits"
      )
      READSET_MODEL_PHASE_CAP_FORBIDDEN=(
        "src/** and Dockerfile only"
      )
      ;;
    Requirements)
      READSET_MODEL_PHASE_CAP_ALLOWED=(
        "authoritative dossier edits"
      )
      READSET_MODEL_PHASE_CAP_FORBIDDEN=(
        "src/** and Dockerfile only"
      )
      ;;
  esac

  if [ "$READSET_MODEL_FOCUS_WI" != "null" ] && [ -f "$project_root/work-items/$READSET_MODEL_FOCUS_WI.yaml" ]; then
    READSET_MODEL_WORK_ITEM_PATH="work-items/$READSET_MODEL_FOCUS_WI.yaml"
    READSET_MODEL_WORK_ITEM_ENTRY=("$READSET_MODEL_WORK_ITEM_PATH" "when focus_work_item is set" "")
    while IFS= read -r ref; do
      [ -n "$ref" ] || continue
      [ "$ref" != "null" ] || continue
      READSET_MODEL_CONTRACT_REFS+=("$ref" "when current work item contract_refs is non-empty" "")
    done < <(yaml_list "$project_root/work-items/$READSET_MODEL_FOCUS_WI.yaml" contract_refs)
  fi

  case "$READSET_MODEL_PHASE" in
    Testing)
      READSET_MODEL_PHASE_DOCS+=("testing.md" "during Testing phase" "")
      READSET_MODEL_PHASE_DOCS+=("work-items/*.yaml" "during Testing phase" "")
      ;;
    Deployment)
      READSET_MODEL_PHASE_DOCS+=("testing.md" "during Deployment phase" "")
      READSET_MODEL_PHASE_DOCS+=("deployment.md" "during Deployment phase" "")
      ;;
  esac
}

render_readset_json() {
  printf '{\n'
  printf '  "phase": %s,\n' "$(json_quote "$READSET_MODEL_PHASE")"
  printf '  "entry_files": %s,\n' "$(json_path_entries "${READSET_MODEL_ENTRY_FILES[@]}")"
  printf '  "read_one_entry_file": %s,\n' "$(json_bool true)"
  printf '  "minimal_readset": %s,\n' "$(json_path_entries "${READSET_MODEL_MINIMAL_READSET[@]}")"
  printf '  "phase_capabilities": {\n'
  printf '    "allowed": %s,\n' "$(json_string_array "${READSET_MODEL_PHASE_CAP_ALLOWED[@]}")"
  printf '    "forbidden": %s\n' "$(json_string_array "${READSET_MODEL_PHASE_CAP_FORBIDDEN[@]}")"
  printf '  },\n'
  printf '  "authority": {\n'
  printf '    "phase_policy": %s\n' "$(json_quote "$READSET_MODEL_PHASE_POLICY")"
  printf '  },\n'
  printf '  "focus_work_item": '
  if [ "$READSET_MODEL_FOCUS_WI" = 'null' ]; then
    printf 'null'
  else
    printf '%s' "$(json_quote "$READSET_MODEL_FOCUS_WI")"
  fi
  printf ',\n'
  printf '  "work_item": '
  if [ "$READSET_MODEL_WORK_ITEM_PATH" = 'null' ]; then
    printf 'null'
  else
    printf '%s' "$(json_path_entry_object "${READSET_MODEL_WORK_ITEM_ENTRY[0]}" "${READSET_MODEL_WORK_ITEM_ENTRY[1]}" "${READSET_MODEL_WORK_ITEM_ENTRY[2]}")"
  fi
  printf ',\n'
  printf '  "contract_refs": %s,\n' "$(json_path_entries "${READSET_MODEL_CONTRACT_REFS[@]}")"
  printf '  "phase_docs": %s,\n' "$(json_path_entries "${READSET_MODEL_PHASE_DOCS[@]}")"
  printf '  "appendix_rules": {\n'
  printf '    "spec": %s,\n' "$(json_path_entry_object "${READSET_MODEL_APPENDIX_SPEC[0]}" "${READSET_MODEL_APPENDIX_SPEC[1]}" "${READSET_MODEL_APPENDIX_SPEC[2]}")"
  printf '    "design": %s\n' "$(json_path_entry_object "${READSET_MODEL_APPENDIX_DESIGN[0]}" "${READSET_MODEL_APPENDIX_DESIGN[1]}" "${READSET_MODEL_APPENDIX_DESIGN[2]}")"
  printf '  }\n'
  printf '}\n'
}

render_readset_text() {
  printf 'readset:\n'
  render_text_entry_choice READSET_MODEL_ENTRY_FILES
  render_text_triplets READSET_MODEL_MINIMAL_READSET
  printf 'phase_capabilities.allowed:\n'
  render_text_string_list READSET_MODEL_PHASE_CAP_ALLOWED
  printf 'phase_capabilities.forbidden:\n'
  render_text_string_list READSET_MODEL_PHASE_CAP_FORBIDDEN
  printf 'authority.phase_policy: %s\n' "$READSET_MODEL_PHASE_POLICY"
  if [ "$READSET_MODEL_WORK_ITEM_PATH" != 'null' ]; then
    render_text_triplets READSET_MODEL_WORK_ITEM_ENTRY
    render_text_triplets READSET_MODEL_CONTRACT_REFS
  fi
  render_text_triplets READSET_MODEL_PHASE_DOCS
  render_text_triplets READSET_MODEL_APPENDIX_SPEC
  render_text_triplets READSET_MODEL_APPENDIX_DESIGN
}

readset_cmd() {
  require_yq
  local project_root
  project_root="$(find_project_root)"
  local output_json=false
  if find_optional_arg '--json' "$@"; then
    output_json=true
  fi

  build_readset_model "$project_root"

  if [ "$output_json" = true ]; then
    render_readset_json
    return
  fi

  render_readset_text
}

check_gate_cmd() {
  require_yq
  local gate="${1:?usage: codespec check-gate <name>}"
  exec "$FRAMEWORK_ROOT/scripts/check-gate.sh" "$gate"
}

install_cmd() {
  cat >&2 <<'EOF'
ERROR: The 'install' command has been removed in v2.0.

Please use the new two-step installation:

1. Install workspace (shared resources):
   /path/to/.codespec/scripts/install-workspace.sh /path/to/workspace

2. Initialize dossier (in project directory):
   cd /path/to/workspace/project
   /path/to/workspace/.codespec/scripts/init-dossier.sh

See README.md for details.
EOF
  exit 1
}

usage() {
  cat <<'EOF'
Usage:
  codespec add-work-item <WI-ID>
  codespec start-requirements
  codespec start-design
  codespec start-implementation <WI-ID>
  codespec set-active-work-items <WI-001,WI-002|[]>
  codespec start-testing
  codespec start-deployment
  codespec complete-change
  codespec generate-project-docs <version>
  codespec reset-to-proposal [--keep-contracts]
  codespec install-hooks
  codespec check-gate <name>
  codespec status
  codespec readset
  codespec materialize-deployment
  codespec promote-version <stable-version>
  codespec list-versions [--json]

Installation:
  /path/to/.codespec/scripts/install-workspace.sh <workspace_root>
  /path/to/.codespec/scripts/init-dossier.sh

Version lifecycle:
  complete-change -> mark Deployment change completed
  generate-project-docs -> generate project documentation from dossier
  promote-version -> archive dossier to versions/<version>
  reset-to-proposal -> reset dossier to Proposal phase for next version
  list-versions -> list all archived versions

Gate views:
  spec-completeness -> proposal-maturity + requirements-approval
  design-structure-complete -> design artifacts are structurally complete and aligned with work item derivation
  design-readiness -> alias of design-structure-complete
  implementation-ready -> design-structure-complete + implementation-start
  scope -> staged changes stay within allowed_paths / outside forbidden_paths
  contract-boundary -> contract refs resolve and frozen contracts stay unchanged
  trace-consistency -> REQ->ACC->VO, ACC->WI, approved ACC testing records in Testing/Deployment
  verification -> dependency/current WI pass checks; adds testing-coverage in Testing/Deployment
  promotion -> deployment-readiness + promotion-criteria

Lifecycle commands:
  start-requirements -> Proposal -> Requirements
  start-design -> Requirements -> Design
  start-implementation -> Design -> Implementation or Implementation -> Implementation, and set/switch focus_work_item
  set-active-work-items -> update active_work_items explicitly (design/manual branch execution set; runtime does not provide complete multi-WI union enforcement)
  start-testing -> Implementation -> Testing (preserves active_work_items for verification gate)
  start-deployment -> Testing -> Deployment (or Deployment completed -> Deployment in_progress reopen; auto-materializes deployment.md if missing)
  complete-change -> mark Deployment change completed

Review rule:
  check-gate pass != semantic review pass; phase advancement still requires phase-review-policy/rfr approval

Internal gates:
  metadata-consistency
  proposal-maturity | requirements-approval | design-structure-complete (alias: design-readiness)
  implementation-ready | implementation-start
  testing-coverage | deployment-readiness | promotion-criteria
EOF
}

main() {
  local cmd="${1:-help}"
  shift || true

  case "$cmd" in
    install)
      install_cmd "$@"
      ;;
    add-work-item)
      add_work_item "$@"
      ;;
    start-requirements)
      start_requirements "$@"
      ;;
    start-design)
      start_design "$@"
      ;;
    start-implementation)
      start_implementation "$@"
      ;;
    set-active-work-items)
      set_active_work_items "$@"
      ;;
    start-testing)
      start_testing "$@"
      ;;
    start-deployment)
      start_deployment "$@"
      ;;
    complete-change)
      complete_change "$@"
      ;;
    generate-project-docs)
      generate_project_docs "$@"
      ;;
    reset-to-proposal)
      reset_to_proposal "$@"
      ;;
    list-versions)
      list_versions "$@"
      ;;
    install-hooks)
      install_hooks "$@"
      ;;
    check-gate)
      check_gate_cmd "$@"
      ;;
    status)
      status_cmd "$@"
      ;;
    readset)
      readset_cmd "$@"
      ;;
    materialize-deployment)
      materialize_deployment "$@"
      ;;
    promote-version)
      promote_version "$@"
      ;;
    render-template)
      render_template "$@"
      ;;
    help|-h|--help)
      usage
      ;;
    *)
      die "unknown command: $cmd"
      ;;
  esac
}

main "$@"
