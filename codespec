    /<!-- CODESPEC:DESIGN:SLICES -->/ { in_slices = 1; next }
    /<!-- CODESPEC:DESIGN:SLICES_END -->/ { in_slices = 0; next }
    !in_slices { next }
    /^[[:space:]]*-[[:space:]]*slice_id:[[:space:]]*SLICE-/ {
      line = $0
      sub(/^[[:space:]]*-[[:space:]]*slice_id:[[:space:]]*/, "", line)
      sub(/[[:space:]]*$/, "", line)
      print line
    }
  ' "$design_file" | sort -u
}

completion_report_latest_level_for_tc() {
  local testing_file="$1"
  local tc="$2"
  [ -f "$testing_file" ] || return 0
  codespec_testing_ledger_text "$testing_file" | awk -v tc="$tc" '
    function reset_record() {
      in_record = 0
      record_tc = ""
      record_result = ""
      record_level = ""
    }

    function flush_record() {
      if (!in_record) return
      if (record_tc == tc && record_result == "pass" && record_level != "") {
        latest = record_level
      }
    }

    BEGIN {
      reset_record()
    }

    /^[[:space:]]*-[[:space:]]*run_id:[[:space:]]*RUN-[A-Za-z0-9._-]+[[:space:]]*$/ {
      flush_record()
      reset_record()
      in_record = 1
      next
    }

    /^[[:space:]]*-[[:space:]]*(tc_id|handoff_id|residual_risk):[[:space:]]*/ {
      flush_record()
      reset_record()
      next
    }

    !in_record { next }

    /^[[:space:]]*test_case_ref:[[:space:]]*/ {
      line = $0
      sub(/^[[:space:]]*test_case_ref:[[:space:]]*/, "", line)
      sub(/[[:space:]]*$/, "", line)
      record_tc = line
      next
    }

    /^[[:space:]]*result:[[:space:]]*/ {
      line = $0
      sub(/^[[:space:]]*result:[[:space:]]*/, "", line)
      sub(/[[:space:]]*$/, "", line)
      record_result = line
      next
    }

    /^[[:space:]]*completion_level:[[:space:]]*/ {
      line = $0
      sub(/^[[:space:]]*completion_level:[[:space:]]*/, "", line)
      sub(/[[:space:]]*$/, "", line)
      record_level = line
      next
    }

    END {
      flush_record()
      if (latest != "") print latest
    }
  '
}

completion_report_all_passed_levels() {
  local testing_file="$1"
  [ -f "$testing_file" ] || return 0
  codespec_testing_ledger_text "$testing_file" | awk '
    function reset_record() {
      in_record = 0
      record_result = ""
      record_level = ""
    }

    function flush_record() {
      if (!in_record) return
      if (record_result == "pass" && record_level != "") {
        print record_level
      }
    }

    BEGIN {
      reset_record()
    }

    /^[[:space:]]*-[[:space:]]*run_id:[[:space:]]*RUN-[A-Za-z0-9._-]+[[:space:]]*$/ {
      flush_record()
      reset_record()
      in_record = 1
      next
    }

    /^[[:space:]]*-[[:space:]]*(tc_id|handoff_id|residual_risk):[[:space:]]*/ {
      flush_record()
      reset_record()
      next
    }

    !in_record { next }

    /^[[:space:]]*result:[[:space:]]*/ {
      line = $0
      sub(/^[[:space:]]*result:[[:space:]]*/, "", line)
      sub(/[[:space:]]*$/, "", line)
      record_result = line
      next
    }

    /^[[:space:]]*completion_level:[[:space:]]*/ {
      line = $0
      sub(/^[[:space:]]*completion_level:[[:space:]]*/, "", line)
      sub(/[[:space:]]*$/, "", line)
      record_level = line
      next
    }

    END {
      flush_record()
    }
  '
}

completion_report_highest_level() {
  local project_root="$1"
  local phase="$2"
  local highest_rank=1
  local rank

  if [ "$phase" = 'Implementation' ]; then
    local design_file="$project_root/design.md"
    local testing_file="$project_root/testing.md"
    if [ -f "$design_file" ]; then
      local tc_ref slice_rank
      while IFS= read -r tc_ref; do
        [ -n "$tc_ref" ] || continue
        local run_level
        if [ -f "$testing_file" ]; then
          run_level="$(completion_report_latest_level_for_tc "$testing_file" "$tc_ref" || true)"
        fi
        if [ -n "$run_level" ]; then
          slice_rank="$(codespec_completion_level_rank "$run_level")" || slice_rank=1
        else
          slice_rank=1
        fi
        [ "$slice_rank" -gt "$highest_rank" ] && highest_rank="$slice_rank"
      done < <(completion_report_design_test_cases "$design_file")
    fi
  elif [ -f "$project_root/testing.md" ]; then
    local item
    while IFS= read -r item; do
      [ -n "$item" ] || continue
      rank="$(codespec_completion_level_rank "$item")" || rank=1
      [ "$rank" -gt "$highest_rank" ] && highest_rank="$rank"
    done < <(completion_report_all_passed_levels "$project_root/testing.md")
  fi

  codespec_completion_level_for_rank "$highest_rank"
}

completion_report_unfinished_required() {
  local project_root="$1"
  local phase="$2"
  local highest="$3"
  local rank

  case "$phase" in
    Implementation)
      rank="$(codespec_completion_level_rank "$highest")" || rank=1
      [ "$rank" -lt "$(codespec_completion_level_rank integrated_runtime)" ] && {
        printf 'yes\n'
        return
      }
      ;;
    Testing|Deployment)
      if ! CODESPEC_PROJECT_ROOT="$project_root" "$FRAMEWORK_ROOT/scripts/check-gate.sh" verification >/dev/null 2>&1; then
        printf 'yes\n'
        return
      fi
      if [ "$phase" = 'Deployment' ] && ! CODESPEC_PROJECT_ROOT="$project_root" "$FRAMEWORK_ROOT/scripts/check-gate.sh" deployment-readiness >/dev/null 2>&1; then
        printf 'yes\n'
        return
      fi
      ;;
  esac
  printf 'no\n'
}

completion_report_handoff_template() {
  local project_root="$1"
  local phase="$2"
  local highest="$3"
  local unfinished_required="$4"
  local timestamp first_tc slice_refs=()

  timestamp="$(date +%Y%m%d-%H%M%S)"
  first_tc="$(completion_report_design_test_cases "$project_root/design.md" | head -1 || true)"
  [ -n "$first_tc" ] || first_tc='TC-000'
  mapfile -t slice_refs < <(completion_report_design_slices "$project_root/design.md")

  printf -- '- handoff_id: HANDOFF-%s\n' "$timestamp"
  printf '  phase: %s\n' "$phase"
  if [ "$phase" = 'Implementation' ] && [ "${#slice_refs[@]}" -gt 0 ]; then
    printf '  slice_refs: [%s]\n' "$(IFS=,; printf '%s' "${slice_refs[*]}")"
  fi
  printf '  highest_completion_level: %s\n' "$highest"
  printf '  current_completion_level: %s\n' "$highest"
  printf '  evidence_refs:\n'
  printf '    - testing.md#RUN-...\n'
  printf '  unfinished_items:\n'
  if [ "$unfinished_required" = 'yes' ]; then
    printf '    - source_ref: testing.md#%s\n' "$first_tc"
    printf '      priority: P0\n'
    printf '      current_completion_level: %s\n' "$highest"
    printf '      target_completion_level: integrated_runtime\n'
    printf '      blocker: pending higher-level verification evidence\n'
    printf '      next_step: run the missing verification and append RUN evidence\n'
  else
    printf '    - none\n'
  fi
  printf '  fixture_or_fallback_paths:\n'
  if codespec_completion_level_rank "$highest" >/dev/null 2>&1 && [ "$(codespec_completion_level_rank "$highest")" -lt "$(codespec_completion_level_rank integrated_runtime)" ]; then
    printf '    - surface: current verified surface\n'
    printf '      completion_level: %s\n' "$highest"
    printf '      real_api_verified: false\n'
    printf '      visible_failure_state: false\n'
    printf '      trace_retry_verified: false\n'
  else
    printf '    - none\n'
  fi
  printf '  wording_guard: "Report only the verified completion level; do not claim owner_verified unless owner evidence exists."\n'
}

completion_report_cmd() {
  require_yq
  local project_root meta phase status highest unfinished_required mode
  mode="${1:-summary}"
  case "$mode" in
    summary|'') ;;
    --handoff-template) ;;
    *) die "unknown completion-report option: $mode" ;;
  esac

  project_root="$(find_project_root)"
  meta="$project_root/meta.yaml"
  [ -f "$meta" ] || die "missing meta.yaml"

  phase="$(yaml_scalar "$meta" phase)"
  status="$(yaml_scalar "$meta" status)"
  highest="$(completion_report_highest_level "$project_root" "$phase")"
  unfinished_required="$(completion_report_unfinished_required "$project_root" "$phase" "$highest")"

  if [ "$mode" = '--handoff-template' ]; then
    completion_report_handoff_template "$project_root" "$phase" "$highest" "$unfinished_required"
    return
  fi

  printf 'phase: %s\n' "$phase"
  printf 'status: %s\n' "$status"
  printf 'highest_completion_level: %s\n' "$highest"
  printf 'unfinished_items.required: %s\n' "$unfinished_required"
  printf 'required_report_sections:\n'
  printf -- '- completed_evidence\n'
  printf -- '- unfinished_items\n'
  printf -- '- blockers\n'
  printf -- '- next_steps\n'
  printf -- '- wording_guard\n'
  printf 'semantic_handoff_gate: codespec check-gate semantic-handoff\n'
}

design_contract_refs() {
  local design_file="$1"
  [ -f "$design_file" ] || return 0
  awk '
    BEGIN { in_contracts = 0 }
    /<!-- CODESPEC:DESIGN:CONTRACTS -->/ {
      in_contracts = 1
      next
    }
    /^## 5\. 契约设计/ || /^## Contracts$/ {
      in_contracts = 1
      next
    }
    in_contracts && /<!-- CODESPEC:DESIGN:/ && $0 !~ /CONTRACTS/ {
      exit
    }
    in_contracts && /^## [0-9]+\. / && $0 !~ /^## 5\. / {
      exit
    }
    in_contracts && /^[[:space:]]*-[[:space:]]*contract_ref:[[:space:]]*/ {
      line = $0
      sub(/^[[:space:]]*-[[:space:]]*contract_ref:[[:space:]]*/, "", line)
      sub(/[[:space:]]*$/, "", line)
      if (line != "" && line != "none" && line != "null" && line !~ /^\[/) print line
      next
    }
    in_contracts && /^[[:space:]]*contract_ref:[[:space:]]*/ {
      line = $0
      sub(/^[[:space:]]*contract_ref:[[:space:]]*/, "", line)
      sub(/[[:space:]]*$/, "", line)
      if (line != "" && line != "none" && line != "null" && line !~ /^\[/) print line
      next
    }
  ' "$design_file" | sort -u
}

build_readset_model() {
  local project_root="$1"
  local meta="$project_root/meta.yaml"
  [ -f "$meta" ] || die "missing meta.yaml"

  READSET_MODEL_PHASE="$(yaml_scalar "$meta" phase)"
  READSET_MODEL_PHASE_POLICY='../phase-review-policy.md'
  READSET_MODEL_PHASE_CAP_ALLOWED=()
  READSET_MODEL_PHASE_CAP_FORBIDDEN=()

  READSET_MODEL_ENTRY_FILES=(
    "AGENTS.md" "read exactly one" ""
    "CLAUDE.md" "read exactly one" ""
  )
  READSET_MODEL_MINIMAL_READSET=(
    "../lessons_learned.md" "" ""
    "../phase-review-policy.md" "" ""
    "meta.yaml" "" ""
  )
  READSET_MODEL_CONTRACT_REFS=()
  READSET_MODEL_PHASE_DOCS=()
  READSET_MODEL_APPENDIX_SPEC=("spec-appendices/*" "only when default layer is insufficient" "")
  READSET_MODEL_APPENDIX_DESIGN=("design-appendices/*" "only when current slice requires drill-down" "")

  case "$READSET_MODEL_PHASE" in
    Requirement)
      READSET_MODEL_MINIMAL_READSET+=("inputs/*" "optional convention during Requirement authoring when present" "source material for drafting spec/testing")
      READSET_MODEL_MINIMAL_READSET+=("docs/inputs/*" "optional convention during Requirement authoring when present" "source material for drafting spec/testing")
      READSET_MODEL_MINIMAL_READSET+=("spec.md" "" "draft or review self-contained requirements")
      READSET_MODEL_MINIMAL_READSET+=("testing.md" "" "draft or review planned TC-* before Design")
      READSET_MODEL_PHASE_CAP_ALLOWED=(
        "authoritative dossier edits"
      )
      READSET_MODEL_PHASE_CAP_FORBIDDEN=(
        "src/** and Dockerfile only"
      )
      ;;
    Design)
      READSET_MODEL_MINIMAL_READSET+=("spec.md" "" "approved requirements authority")
      READSET_MODEL_MINIMAL_READSET+=("testing.md" "" "planned TC-* to drive design verification")
      READSET_MODEL_MINIMAL_READSET+=("design.md" "" "draft architecture/design authority")
      READSET_MODEL_PHASE_CAP_ALLOWED=(
        "design.md, contracts/*.md draft, testing.md plan refinement"
      )
      READSET_MODEL_PHASE_CAP_FORBIDDEN=(
        "src/** and Dockerfile until Implementation"
      )
      ;;
    Implementation)
      READSET_MODEL_MINIMAL_READSET+=("design.md" "" "implementation authority")
      READSET_MODEL_MINIMAL_READSET+=("testing.md" "" "read TC-* obligations")
      READSET_MODEL_MINIMAL_READSET+=("spec.md" "only when design is ambiguous or reopen is needed" "requirement authority fallback")
      READSET_MODEL_PHASE_CAP_ALLOWED=(
        "design.md §4 allowed paths and testing.md RUN evidence"
      )
      READSET_MODEL_PHASE_CAP_FORBIDDEN=(
        "design.md §4 forbidden paths, frozen contracts, unapproved scope expansion"
      )
      ;;
    Testing)
      READSET_MODEL_MINIMAL_READSET+=("testing.md" "" "verify TC-* with full-integration RUN-* evidence")
      READSET_MODEL_MINIMAL_READSET+=("design.md" "" "verification design and boundaries")
      READSET_MODEL_PHASE_CAP_ALLOWED=(
        "testing.md evidence recording and test execution"
      )
      READSET_MODEL_PHASE_CAP_FORBIDDEN=(
        "src/**, Dockerfile, spec.md, design.md, contracts/**, deployment.md"
      )
      ;;
    Deployment)
      READSET_MODEL_MINIMAL_READSET+=("deployment.md" "" "release evidence and manual acceptance")
      READSET_MODEL_MINIMAL_READSET+=("testing.md" "" "deployment/manual TC evidence")
      READSET_MODEL_PHASE_CAP_ALLOWED=(
        "deployment.md evidence, runtime verification, manual acceptance records"
      )
      READSET_MODEL_PHASE_CAP_FORBIDDEN=(
        "src/**, Dockerfile, spec.md, design.md, contracts/**"
      )
      ;;
  esac

  case "$READSET_MODEL_PHASE" in
    Testing)
      READSET_MODEL_PHASE_DOCS+=("testing.md" "during Testing phase" "verify every required TC has full-integration evidence")
      ;;
    Deployment)
      READSET_MODEL_PHASE_DOCS+=("testing.md" "during Deployment phase" "check deployment/manual TC evidence")
      READSET_MODEL_PHASE_DOCS+=("deployment.md" "during Deployment phase" "record release evidence and manual acceptance")
      ;;
  esac

  local contract_refs=()
  local contract_ref
  mapfile -t contract_refs < <(design_contract_refs "$project_root/design.md")
  for contract_ref in "${contract_refs[@]}"; do
    READSET_MODEL_CONTRACT_REFS+=("$contract_ref" "" "contract referenced by design.md §5")
    case "$READSET_MODEL_PHASE" in
      Design|Implementation|Testing|Deployment)
        READSET_MODEL_MINIMAL_READSET+=("$contract_ref" "" "contract referenced by design.md §5")
        ;;
    esac
  done
}

render_readset_json() {
  local on_demand_entries=("${READSET_MODEL_APPENDIX_SPEC[@]}" "${READSET_MODEL_APPENDIX_DESIGN[@]}" "${READSET_MODEL_CONTRACT_REFS[@]}")
  printf '{\n'
  printf '  "phase": %s,\n' "$(json_quote "$READSET_MODEL_PHASE")"
  printf '  "entry_files": %s,\n' "$(json_path_entries "${READSET_MODEL_ENTRY_FILES[@]}")"
  printf '  "read_one_entry_file": %s,\n' "$(json_bool true)"
  printf '  "minimal_readset": %s,\n' "$(json_path_entries "${READSET_MODEL_MINIMAL_READSET[@]}")"
  printf '  "layered_readset": {\n'
  printf '    "default": %s,\n' "$(json_path_entries "${READSET_MODEL_MINIMAL_READSET[@]}")"
  printf '    "phase": %s,\n' "$(json_path_entries "${READSET_MODEL_PHASE_DOCS[@]}")"
  printf '    "on_demand": %s\n' "$(json_path_entries "${on_demand_entries[@]}")"
  printf '  },\n'
  printf '  "phase_capabilities": {\n'
  printf '    "allowed": %s,\n' "$(json_string_array "${READSET_MODEL_PHASE_CAP_ALLOWED[@]}")"
  printf '    "forbidden": %s\n' "$(json_string_array "${READSET_MODEL_PHASE_CAP_FORBIDDEN[@]}")"
  printf '  },\n'
  printf '  "authority": {\n'
  printf '    "phase_policy": %s\n' "$(json_quote "$READSET_MODEL_PHASE_POLICY")"
  printf '  },\n'
  printf '  "contract_refs": %s,\n' "$(json_path_entries "${READSET_MODEL_CONTRACT_REFS[@]}")"
  printf '  "phase_docs": %s,\n' "$(json_path_entries "${READSET_MODEL_PHASE_DOCS[@]}")"
  printf '  "appendix_rules": {\n'
  printf '    "spec": %s,\n' "$(json_path_entry_object "${READSET_MODEL_APPENDIX_SPEC[0]}" "${READSET_MODEL_APPENDIX_SPEC[1]}" "${READSET_MODEL_APPENDIX_SPEC[2]}")"
  printf '    "design": %s\n' "$(json_path_entry_object "${READSET_MODEL_APPENDIX_DESIGN[0]}" "${READSET_MODEL_APPENDIX_DESIGN[1]}" "${READSET_MODEL_APPENDIX_DESIGN[2]}")"
  printf '  }\n'
  printf '}\n'
}

render_readset_text() {
  printf 'readset:\n'
  render_text_entry_choice READSET_MODEL_ENTRY_FILES
  printf 'layered_readset.default:\n'
  render_text_triplets READSET_MODEL_MINIMAL_READSET
  printf 'layered_readset.phase:\n'
  render_text_triplets READSET_MODEL_PHASE_DOCS
  printf 'layered_readset.on_demand:\n'
  render_text_triplets READSET_MODEL_APPENDIX_SPEC
  render_text_triplets READSET_MODEL_APPENDIX_DESIGN
  render_text_triplets READSET_MODEL_CONTRACT_REFS
  printf 'phase_capabilities.allowed:\n'
  render_text_string_list READSET_MODEL_PHASE_CAP_ALLOWED
  printf 'phase_capabilities.forbidden:\n'
  render_text_string_list READSET_MODEL_PHASE_CAP_FORBIDDEN
  printf 'authority.phase_policy: %s\n' "$READSET_MODEL_PHASE_POLICY"
}

readset_cmd() {
  require_yq
  local project_root
  project_root="$(find_project_root)"
  local output_json=false
  if find_optional_arg '--json' "$@"; then
    output_json=true
  fi

  build_readset_model "$project_root"

  if [ "$output_json" = true ]; then
    render_readset_json
    return
  fi

  render_readset_text
}

check_gate_cmd() {
