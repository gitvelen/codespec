completion_report_highest_level() {
  local project_root="$1"
  local phase="$2"
  local meta="$project_root/meta.yaml"
  local highest_rank=1
  local item rank wi_file

  if [ "$phase" = 'Implementation' ]; then
    while IFS= read -r item; do
      [ -n "$item" ] || continue
      [ "$item" != 'null' ] || continue
      wi_file="$project_root/work-items/$item.yaml"
      [ -f "$wi_file" ] || continue
      rank="$(codespec_completion_level_rank "$(yaml_scalar "$wi_file" completion_level)")" || rank=1
      [ "$rank" -gt "$highest_rank" ] && highest_rank="$rank"
    done < <(yaml_list "$meta" active_work_items)
  elif [ -f "$project_root/testing.md" ]; then
    while IFS= read -r item; do
      [ -n "$item" ] || continue
      rank="$(codespec_completion_level_rank "$item")" || rank=1
      [ "$rank" -gt "$highest_rank" ] && highest_rank="$rank"
    done < <(grep -E '^[[:space:]]*completion_level:[[:space:]]*' "$project_root/testing.md" | sed -E 's/^[[:space:]]*completion_level:[[:space:]]*//' || true)
  fi

  codespec_completion_level_for_rank "$highest_rank"
}

completion_report_unfinished_required() {
  local project_root="$1"
  local phase="$2"
  local highest="$3"
  local rank

  case "$phase" in
    Implementation)
      rank="$(codespec_completion_level_rank "$highest")" || rank=1
      [ "$rank" -lt "$(codespec_completion_level_rank integrated_runtime)" ] && {
        printf 'yes\n'
        return
      }
      ;;
    Testing|Deployment)
      if ! CODESPEC_PROJECT_ROOT="$project_root" "$FRAMEWORK_ROOT/scripts/check-gate.sh" verification >/dev/null 2>&1; then
        printf 'yes\n'
        return
      fi
      if [ "$phase" = 'Deployment' ] && ! CODESPEC_PROJECT_ROOT="$project_root" "$FRAMEWORK_ROOT/scripts/check-gate.sh" deployment-readiness >/dev/null 2>&1; then
        printf 'yes\n'
        return
      fi
      ;;
  esac
  printf 'no\n'
}

completion_report_cmd() {
  require_yq
  local project_root meta phase status focus highest unfinished_required active=()
  project_root="$(find_project_root)"
  meta="$project_root/meta.yaml"
  [ -f "$meta" ] || die "missing meta.yaml"

  phase="$(yaml_scalar "$meta" phase)"
  status="$(yaml_scalar "$meta" status)"
  focus="$(yaml_scalar "$meta" focus_work_item)"
  highest="$(completion_report_highest_level "$project_root" "$phase")"
  unfinished_required="$(completion_report_unfinished_required "$project_root" "$phase" "$highest")"
  mapfile -t active < <(yaml_list "$meta" active_work_items | grep -vE '^(|null)$' || true)

  printf 'phase: %s\n' "$phase"
  printf 'status: %s\n' "$status"
  printf 'focus_work_item: %s\n' "$focus"
  printf 'active_work_items:\n'
  if [ "${#active[@]}" -eq 0 ]; then
    printf -- '- none\n'
  else
    printf '%s\n' "${active[@]}" | sed 's/^/- /'
  fi
  printf 'highest_completion_level: %s\n' "$highest"
  printf 'unfinished_items.required: %s\n' "$unfinished_required"
  printf 'required_report_sections:\n'
  printf -- '- completed_evidence\n'
  printf -- '- unfinished_items\n'
  printf -- '- blockers\n'
  printf -- '- next_steps\n'
  printf -- '- wording_guard\n'
  printf 'semantic_handoff_gate: codespec check-gate semantic-handoff\n'
}

build_readset_model() {
  local project_root="$1"
  local meta="$project_root/meta.yaml"
  [ -f "$meta" ] || die "missing meta.yaml"

  READSET_MODEL_PHASE="$(yaml_scalar "$meta" phase)"
  READSET_MODEL_FOCUS_WI="$(yaml_scalar "$meta" focus_work_item)"
  READSET_MODEL_WORK_ITEM_PATH='null'
  READSET_MODEL_PHASE_POLICY='../phase-review-policy.md'
  READSET_MODEL_PHASE_CAP_ALLOWED=()
  READSET_MODEL_PHASE_CAP_FORBIDDEN=()

  READSET_MODEL_ENTRY_FILES=(
    "AGENTS.md" "read exactly one" ""
    "CLAUDE.md" "read exactly one" ""
  )
  READSET_MODEL_MINIMAL_READSET=(
    "../lessons_learned.md" "" ""
    "../phase-review-policy.md" "" ""
    "meta.yaml" "" ""
  )
  READSET_MODEL_WORK_ITEM_ENTRY=()
  READSET_MODEL_CONTRACT_REFS=()
  READSET_MODEL_PHASE_DOCS=()
  READSET_MODEL_APPENDIX_SPEC=("spec-appendices/*" "only when default layer is insufficient" "")
  READSET_MODEL_APPENDIX_DESIGN=("design-appendices/*" "only when current slice requires drill-down" "")

  case "$READSET_MODEL_PHASE" in
    Requirement)
      READSET_MODEL_MINIMAL_READSET+=("inputs/*" "optional convention during Requirement authoring when present" "source material for drafting spec/testing")
      READSET_MODEL_MINIMAL_READSET+=("docs/inputs/*" "optional convention during Requirement authoring when present" "source material for drafting spec/testing")
      READSET_MODEL_MINIMAL_READSET+=("spec.md" "" "draft or review self-contained requirements")
      READSET_MODEL_MINIMAL_READSET+=("testing.md" "" "draft or review planned TC-* before Design")
      READSET_MODEL_PHASE_CAP_ALLOWED=(
        "authoritative dossier edits"
      )
      READSET_MODEL_PHASE_CAP_FORBIDDEN=(
        "src/** and Dockerfile only"
      )
      ;;
    Design)
      READSET_MODEL_MINIMAL_READSET+=("spec.md" "" "approved requirements authority")
      READSET_MODEL_MINIMAL_READSET+=("testing.md" "" "planned TC-* to drive design verification")
      READSET_MODEL_MINIMAL_READSET+=("design.md" "" "draft architecture/design authority")
      READSET_MODEL_PHASE_CAP_ALLOWED=(
        "design.md, work-items/*.yaml, contracts/*.md draft, testing.md plan refinement"
      )
      READSET_MODEL_PHASE_CAP_FORBIDDEN=(
        "src/** and Dockerfile until Implementation"
      )
      ;;
    Implementation)
      READSET_MODEL_MINIMAL_READSET+=("design.md" "" "implementation authority")
      READSET_MODEL_MINIMAL_READSET+=("testing.md" "" "read current WI TC-* obligations")
      READSET_MODEL_MINIMAL_READSET+=("spec.md" "only when design/WI is ambiguous or reopen is needed" "requirement authority fallback")
      READSET_MODEL_PHASE_CAP_ALLOWED=(
        "current work item allowed_paths and testing.md RUN evidence"
      )
      READSET_MODEL_PHASE_CAP_FORBIDDEN=(
        "current work item forbidden_paths, frozen contracts, unapproved scope expansion"
      )
      ;;
    Testing)
      READSET_MODEL_MINIMAL_READSET+=("testing.md" "" "verify TC-* with full-integration RUN-* evidence")
      READSET_MODEL_MINIMAL_READSET+=("work-items/*.yaml" "" "trace active work item coverage")
      READSET_MODEL_MINIMAL_READSET+=("design.md" "" "verification design and boundaries")
      READSET_MODEL_PHASE_CAP_ALLOWED=(
        "testing.md evidence recording and test execution"
      )
      READSET_MODEL_PHASE_CAP_FORBIDDEN=(
        "src/**, Dockerfile, spec.md, design.md, work-items/**, contracts/**, deployment.md"
      )
      ;;
    Deployment)
      READSET_MODEL_MINIMAL_READSET+=("deployment.md" "" "release evidence and manual acceptance")
      READSET_MODEL_MINIMAL_READSET+=("testing.md" "" "deployment/manual TC evidence")
      READSET_MODEL_PHASE_CAP_ALLOWED=(
        "deployment.md evidence, runtime verification, manual acceptance records"
      )
      READSET_MODEL_PHASE_CAP_FORBIDDEN=(
        "src/**, Dockerfile, spec.md, design.md, work-items/**, contracts/**"
      )
      ;;
  esac

  if [ "$READSET_MODEL_FOCUS_WI" != "null" ] && [ -f "$project_root/work-items/$READSET_MODEL_FOCUS_WI.yaml" ]; then
    READSET_MODEL_WORK_ITEM_PATH="work-items/$READSET_MODEL_FOCUS_WI.yaml"
    READSET_MODEL_WORK_ITEM_ENTRY=("$READSET_MODEL_WORK_ITEM_PATH" "when focus_work_item is set" "implementation authority for current slice")
    while IFS= read -r ref; do
      [ -n "$ref" ] || continue
      [ "$ref" != "null" ] || continue
      READSET_MODEL_CONTRACT_REFS+=("$ref" "when current work item contract_refs is non-empty" "")
    done < <(yaml_list "$project_root/work-items/$READSET_MODEL_FOCUS_WI.yaml" contract_refs)
  fi

  case "$READSET_MODEL_PHASE" in
    Testing)
      READSET_MODEL_PHASE_DOCS+=("testing.md" "during Testing phase" "verify every required TC has full-integration evidence")
      READSET_MODEL_PHASE_DOCS+=("work-items/*.yaml" "during Testing phase" "trace TC/ACC coverage for all active work items")
      ;;
    Deployment)
      READSET_MODEL_PHASE_DOCS+=("testing.md" "during Deployment phase" "check deployment/manual TC evidence")
      READSET_MODEL_PHASE_DOCS+=("deployment.md" "during Deployment phase" "record release evidence and manual acceptance")
      ;;
  esac
}

render_readset_json() {
  local on_demand_entries=("${READSET_MODEL_APPENDIX_SPEC[@]}" "${READSET_MODEL_APPENDIX_DESIGN[@]}" "${READSET_MODEL_CONTRACT_REFS[@]}")
  printf '{\n'
  printf '  "phase": %s,\n' "$(json_quote "$READSET_MODEL_PHASE")"
  printf '  "entry_files": %s,\n' "$(json_path_entries "${READSET_MODEL_ENTRY_FILES[@]}")"
  printf '  "read_one_entry_file": %s,\n' "$(json_bool true)"
  printf '  "minimal_readset": %s,\n' "$(json_path_entries "${READSET_MODEL_MINIMAL_READSET[@]}")"
  printf '  "layered_readset": {\n'
  printf '    "default": %s,\n' "$(json_path_entries "${READSET_MODEL_MINIMAL_READSET[@]}")"
  if [ "$READSET_MODEL_WORK_ITEM_PATH" = 'null' ]; then
    printf '    "work_item": [],\n'
  else
    printf '    "work_item": %s,\n' "$(json_path_entries "${READSET_MODEL_WORK_ITEM_ENTRY[@]}")"
  fi
  printf '    "phase": %s,\n' "$(json_path_entries "${READSET_MODEL_PHASE_DOCS[@]}")"
  printf '    "on_demand": %s\n' "$(json_path_entries "${on_demand_entries[@]}")"
  printf '  },\n'
  printf '  "phase_capabilities": {\n'
  printf '    "allowed": %s,\n' "$(json_string_array "${READSET_MODEL_PHASE_CAP_ALLOWED[@]}")"
  printf '    "forbidden": %s\n' "$(json_string_array "${READSET_MODEL_PHASE_CAP_FORBIDDEN[@]}")"
  printf '  },\n'
  printf '  "authority": {\n'
  printf '    "phase_policy": %s\n' "$(json_quote "$READSET_MODEL_PHASE_POLICY")"
  printf '  },\n'
  printf '  "focus_work_item": '
  if [ "$READSET_MODEL_FOCUS_WI" = 'null' ]; then
    printf 'null'
  else
    printf '%s' "$(json_quote "$READSET_MODEL_FOCUS_WI")"
  fi
  printf ',\n'
  printf '  "work_item": '
  if [ "$READSET_MODEL_WORK_ITEM_PATH" = 'null' ]; then
    printf 'null'
  else
    printf '%s' "$(json_path_entry_object "${READSET_MODEL_WORK_ITEM_ENTRY[0]}" "${READSET_MODEL_WORK_ITEM_ENTRY[1]}" "${READSET_MODEL_WORK_ITEM_ENTRY[2]}")"
  fi
  printf ',\n'
  printf '  "contract_refs": %s,\n' "$(json_path_entries "${READSET_MODEL_CONTRACT_REFS[@]}")"
  printf '  "phase_docs": %s,\n' "$(json_path_entries "${READSET_MODEL_PHASE_DOCS[@]}")"
  printf '  "appendix_rules": {\n'
  printf '    "spec": %s,\n' "$(json_path_entry_object "${READSET_MODEL_APPENDIX_SPEC[0]}" "${READSET_MODEL_APPENDIX_SPEC[1]}" "${READSET_MODEL_APPENDIX_SPEC[2]}")"
  printf '    "design": %s\n' "$(json_path_entry_object "${READSET_MODEL_APPENDIX_DESIGN[0]}" "${READSET_MODEL_APPENDIX_DESIGN[1]}" "${READSET_MODEL_APPENDIX_DESIGN[2]}")"
  printf '  }\n'
  printf '}\n'
}

render_readset_text() {
  printf 'readset:\n'
  render_text_entry_choice READSET_MODEL_ENTRY_FILES
  printf 'layered_readset.default:\n'
  render_text_triplets READSET_MODEL_MINIMAL_READSET
  printf 'layered_readset.work_item:\n'
  if [ "$READSET_MODEL_WORK_ITEM_PATH" != 'null' ]; then
    render_text_triplets READSET_MODEL_WORK_ITEM_ENTRY
    render_text_triplets READSET_MODEL_CONTRACT_REFS
  fi
  printf 'layered_readset.phase:\n'
  render_text_triplets READSET_MODEL_PHASE_DOCS
  printf 'layered_readset.on_demand:\n'
  render_text_triplets READSET_MODEL_APPENDIX_SPEC
  render_text_triplets READSET_MODEL_APPENDIX_DESIGN
  printf 'phase_capabilities.allowed:\n'
  render_text_string_list READSET_MODEL_PHASE_CAP_ALLOWED
  printf 'phase_capabilities.forbidden:\n'
  render_text_string_list READSET_MODEL_PHASE_CAP_FORBIDDEN
  printf 'authority.phase_policy: %s\n' "$READSET_MODEL_PHASE_POLICY"
}

readset_cmd() {
  require_yq
  local project_root
  project_root="$(find_project_root)"
  local output_json=false
  if find_optional_arg '--json' "$@"; then
    output_json=true
  fi

  build_readset_model "$project_root"

  if [ "$output_json" = true ]; then
    render_readset_json
    return
  fi

  render_readset_text
}

check_gate_cmd() {
  require_yq
  local gate="${1:?usage: codespec check-gate <name>}"
  exec "$FRAMEWORK_ROOT/scripts/check-gate.sh" "$gate"
}

install_cmd() {
  cat >&2 <<'EOF'
ERROR: The 'install' command has been removed in v2.0.

Please use the new two-step installation:

1. Install workspace (shared resources):
   /path/to/.codespec/scripts/install-workspace.sh /path/to/workspace

2. Initialize dossier (in project directory):
   cd /path/to/workspace/project
   /path/to/workspace/.codespec/scripts/init-dossier.sh

See README.md for details.
EOF
  exit 1
}

usage() {
  cat <<'EOF'
Usage:
  codespec add-work-item <WI-ID>
  codespec start-design
  codespec start-implementation <WI-ID>
  codespec reopen-implementation <WI-ID>
  codespec authority-repair <begin|close|status>
  codespec set-active-work-items <WI-001,WI-002|[]>
  codespec set-execution-context <single|parallel> <feature-branch> [execution-group]
  codespec start-testing
  codespec start-deployment
  codespec deploy
  codespec complete-change <stable-version>
  codespec submit-pr <stable-version> [--base <branch>] [--draft]
  codespec scaffold-project-docs <version>
  codespec generate-project-docs <version>
  codespec reset-to-requirement [--keep-contracts]
  codespec install-hooks
  codespec check-gate <name>
  codespec status
  codespec completion-report
  codespec readset
  codespec materialize-deployment
  codespec promote-version <stable-version>
  codespec list-versions [--json]

Installation:
  /path/to/.codespec/scripts/install-workspace.sh <workspace_root>
  /path/to/.codespec/scripts/init-dossier.sh

Version lifecycle:
  deploy -> execute the project deploy hook and refresh deployment evidence
  complete-change -> archive accepted stable version and mark the Deployment change completed
  submit-pr -> complete an accepted Deployment change, push the current branch, and open a GitHub PR
  completion-report -> print the current phase handoff obligations and unfinished disclosure requirement
  scaffold-project-docs -> scaffold project document shells from dossier artifacts
  generate-project-docs -> deprecated compatibility alias for scaffold-project-docs
  promote-version -> compatibility alias for complete-change <stable-version>
  reset-to-requirement -> reset dossier to Requirement phase for next version
  list-versions -> list all archived versions

Gate views:
  requirement-complete -> Requirement dossier is structurally complete and fully traceable
  spec-quality -> spec.md is self-contained and free of template placeholders
  test-plan-complete -> every ACC has planned TC-* coverage before Design
  design-structure-complete -> design artifacts are structurally complete and aligned with work item derivation
  design-quality -> design.md covers architecture, contracts/data, security, environment, verification, and traceability
  design-readiness -> alias of design-quality
  review-quality -> review artifact is approved, dated, and non-placeholder
  implementation-ready -> design-quality + implementation-start
  active-work-items-complete -> active_work_items covers every design-derived WI before Testing
  scope -> staged changes stay within allowed_paths / outside forbidden_paths; start-testing rechecks the full Implementation span
  contract-boundary -> contract refs resolve, frozen contracts stay unchanged, and frozen contracts require freeze review evidence
  trace-consistency -> REQ->ACC->VO->TC->WI->RUN coverage in Testing/Deployment
  verification -> dependency/current WI TC pass checks; testing/deployment use the latest matching RUN record
  semantic-handoff -> R15 active unfinished disclosure and wording guard
  deployment-plan-ready -> deployment.md plan, date, checklist, rollback, and monitoring are non-placeholder before deploy
  promotion -> trace-consistency + deployment-readiness + promotion-criteria

Lifecycle commands:
  start-design -> Requirement -> Design
  start-implementation -> Design -> Implementation or Implementation -> Implementation, and set/switch focus_work_item
  reopen-implementation -> Testing/Deployment -> Implementation for failed verification follow-up
  authority-repair -> audited temporary path for repairing upstream authority gaps
  set-active-work-items -> update active_work_items explicitly; before Testing it must cover every design-derived WI
  set-execution-context -> write the runtime branch-execution context into meta.yaml without hand-editing it
  start-testing -> Implementation -> Testing (requires complete active_work_items and rechecks the full Implementation span)
  start-deployment -> Testing -> Deployment (or Deployment completed -> Deployment active reopen; auto-materializes deployment.md if missing)
  deploy -> run scripts/codespec-deploy and refresh deployment.md evidence
  complete-change -> archive an accepted stable version and mark Deployment completed
  submit-pr -> complete/push/create PR for an accepted Deployment change

Review rule:
  check-gate pass != semantic review pass; phase advancement still requires phase-review-policy/rfr approval

Internal gates:
  metadata-consistency
  review-verdict-present | review-quality
  requirement-complete | spec-quality | test-plan-complete
  design-structure-complete | design-quality (alias: design-readiness)
  implementation-ready | implementation-start
  active-work-items-complete
  phase-capability | scope | contract-boundary
  trace-consistency | verification | testing-coverage
  semantic-handoff
  deployment-plan-ready | deployment-readiness | promotion-criteria | policy-consistency
EOF
}

main() {
  local cmd="${1:-help}"
  shift || true

  case "$cmd" in
    install)
      install_cmd "$@"
      ;;
    add-work-item)
      add_work_item "$@"
      ;;
    start-design)
      start_design "$@"
      ;;
    start-implementation)
      start_implementation "$@"
      ;;
    reopen-implementation)
      reopen_implementation "$@"
      ;;
    authority-repair)
      authority_repair_cmd "$@"
      ;;
    set-active-work-items)
      set_active_work_items "$@"
      ;;
    set-execution-context)
      set_execution_context "$@"
      ;;
    start-testing)
      start_testing "$@"
      ;;
    start-deployment)
      start_deployment "$@"
      ;;
    deploy)
      deploy_change "$@"
      ;;
    complete-change)
      complete_change "$@"
      ;;
    submit-pr)
      submit_pr "$@"
      ;;
    scaffold-project-docs)
      scaffold_project_docs "$@"
      ;;
    generate-project-docs)
      generate_project_docs "$@"
      ;;
    reset-to-requirement)
      reset_to_requirement "$@"
      ;;
    list-versions)
      list_versions "$@"
      ;;
    install-hooks)
      install_hooks "$@"
      ;;
    check-gate)
      check_gate_cmd "$@"
      ;;
    status)
      status_cmd "$@"
      ;;
    completion-report)
      completion_report_cmd "$@"
      ;;
    readset)
      readset_cmd "$@"
      ;;
    materialize-deployment)
      materialize_deployment "$@"
      ;;
    promote-version)
      promote_version "$@"
      ;;
    render-template)
      render_template "$@"
      ;;
    help|-h|--help)
      usage
      ;;
    *)
      die "unknown command: $cmd"
      ;;
  esac
}

main "$@"
