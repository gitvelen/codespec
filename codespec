submit_pr() {
  require_yq
  local stable_version="${1:?usage: codespec submit-pr <stable-version> [--base <branch>] [--draft]}"
  validate_stable_version "$stable_version"
  shift || true

  local base_branch="" draft=false
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --base)
        shift || die 'submit-pr requires a value after --base'
        [ "$#" -gt 0 ] || die 'submit-pr requires a value after --base'
        base_branch="$1"
        ;;
      --draft)
        draft=true
        ;;
      *)
        die "unknown submit-pr option: $1"
        ;;
    esac
    shift || true
  done

  local project_root meta phase status current_branch feature_branch execution_group recorded_stable_version
  project_root="$(find_project_root)"
  meta="$project_root/meta.yaml"
  [ -f "$meta" ] || die "missing meta.yaml"
  require_git_repo "$project_root"
  command -v gh >/dev/null 2>&1 || die 'submit-pr requires gh'
  gh auth status >/dev/null 2>&1 || die 'submit-pr requires authenticated gh'
  git -C "$project_root" remote get-url origin >/dev/null 2>&1 || die 'submit-pr requires origin remote'

  phase="$(yaml_scalar "$meta" phase)"
  status="$(yaml_scalar "$meta" status)"
  [ "$phase" = 'Deployment' ] || die 'submit-pr requires Deployment phase'

  current_branch="$(current_git_branch "$project_root")"
  [ "$current_branch" != 'detached' ] || die 'submit-pr requires a branch checkout'
  [ "$current_branch" != 'none' ] || die 'submit-pr requires a git branch'

  feature_branch="$(yaml_scalar "$meta" feature_branch)"
  execution_group="$(yaml_scalar "$meta" execution_group)"
  if [ "$execution_group" != 'null' ] && [ "$current_branch" != "$feature_branch" ]; then
    die 'submit-pr must run from feature_branch, not an execution branch'
  fi

  if [ -z "$base_branch" ]; then
    base_branch="$(resolve_default_branch "$project_root")"
  fi
  [ "$current_branch" != "$base_branch" ] || die 'submit-pr must not run on the default branch'

  if [ "$status" = 'active' ]; then
    ensure_clean_git_worktree "$project_root"
    ensure_deployed_source_revision_current "$project_root"
    complete_change "$stable_version"
    git -C "$project_root" add meta.yaml
    git -C "$project_root" commit --no-verify -m "chore: complete change $stable_version" >/dev/null
  elif [ "$status" = 'completed' ]; then
    ensure_clean_git_worktree "$project_root"
    recorded_stable_version="$(yaml_scalar "$meta" stable_version)"
    [ "$recorded_stable_version" = "$stable_version" ] || die "submit-pr stable_version mismatch: expected $recorded_stable_version"
    ensure_deployed_source_revision_current "$project_root"
  else
    die 'submit-pr requires active or completed Deployment status'
  fi

  local body_file title gh_args=()
  body_file="$(submit_pr_body_file "$project_root" "$stable_version")"
  title="complete: $stable_version ($(yaml_scalar "$meta" change_id))"
  gh_args=(pr create --base "$base_branch" --head "$current_branch" --title "$title" --body-file "$body_file")
  if [ "$draft" = true ]; then
    gh_args+=(--draft)
  fi

  local submit_status
  set +e
  git -C "$project_root" push -u origin "$current_branch"
  submit_status=$?
  if [ "$submit_status" -eq 0 ]; then
    gh "${gh_args[@]}"
    submit_status=$?
  fi
  set -e
  rm -f "$body_file"
  return "$submit_status"
}

