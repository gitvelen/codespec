migrate_testing_ledger() {
  require_yq
  command -v python3 >/dev/null 2>&1 || die "python3 is required"

  local write_mode=false
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --write)
        write_mode=true
        ;;
      *)
        die "usage: codespec migrate-testing-ledger [--write]"
        ;;
    esac
    shift || true
  done

  local project_root testing_file block
  project_root="$(find_project_root)"
  testing_file="$project_root/testing.md"
  [ -f "$testing_file" ] || die "missing testing.md"

  block="$(migrate_testing_structured_block "$testing_file")"
  if [ "$write_mode" = false ]; then
    printf '%s\n' "$block"
    return
  fi

  BLOCK="$block" python3 - "$testing_file" <<'PY'
import os
import re
import sys
from pathlib import Path

path = Path(sys.argv[1])
text = path.read_text(encoding="utf-8")
block = os.environ["BLOCK"].rstrip() + "\n"
pattern = (
    r"\n?<!-- CODESPEC:TESTING:LEDGER -->\n"
    r"```ya?ml\n"
    r".*?\n"
    r"```\n"
    r"<!-- CODESPEC:TESTING:LEDGER_END -->\n?"
)
replacement = "\n\n" + block
if re.search(pattern, text, flags=re.S):
    text = re.sub(pattern, replacement, text, flags=re.S).rstrip() + "\n"
else:
    text = text.rstrip() + "\n\n" + block
path.write_text(text, encoding="utf-8")
PY
  log "wrote structured testing ledger: $testing_file"
}

