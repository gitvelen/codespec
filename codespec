set_execution_context() {
  require_yq
  local mode="${1:?usage: codespec set-execution-context <single|parallel> <feature-branch> [execution-group]}"
  local feature_branch="${2:?usage: codespec set-execution-context <single|parallel> <feature-branch> [execution-group]}"
  local project_root
  project_root="$(find_project_root)"
  local meta="$project_root/meta.yaml"
  [ -f "$meta" ] || die "missing meta.yaml"

  local git_branch
  git_branch="$(current_git_branch "$project_root")"
  [ "$git_branch" != 'none' ] || die 'set-execution-context requires a git repository'
  [ "$git_branch" != 'detached' ] || die 'set-execution-context requires a named git branch'

  case "$mode" in
    single)
      [ "$#" -eq 2 ] || die 'usage: codespec set-execution-context single <feature-branch>'
      [ "$git_branch" = "$feature_branch" ] || die "single execution context requires current git branch (${git_branch}) to match feature_branch (${feature_branch})"
      meta_update "$meta" ".feature_branch = \"$feature_branch\" | .execution_group = null | .execution_branch = null"
      log "set execution context: single feature=${feature_branch}"
      ;;
    parallel)
      local execution_group="${3:?usage: codespec set-execution-context parallel <feature-branch> <execution-group>}"
      [ "$#" -eq 3 ] || die 'usage: codespec set-execution-context parallel <feature-branch> <execution-group>'
      [ "$execution_group" != 'null' ] || die 'execution-group must be non-null'
      meta_update "$meta" ".feature_branch = \"$feature_branch\" | .execution_group = \"$execution_group\" | .execution_branch = \"$git_branch\""
      log "set execution context: parallel feature=${feature_branch} group=${execution_group} branch=${git_branch}"
      ;;
    *)
      die 'usage: codespec set-execution-context <single|parallel> <feature-branch> [execution-group]'
      ;;
  esac
}

