#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
FRAMEWORK_ROOT="$SCRIPT_DIR"

# shellcheck source=scripts/lib/testing-ledger.sh
. "$FRAMEWORK_ROOT/scripts/lib/testing-ledger.sh"

# shellcheck source=scripts/lib/legacy-wi-audit.sh
. "$FRAMEWORK_ROOT/scripts/lib/legacy-wi-audit.sh"

log() {
  printf '%s\n' "$*"
}

die() {
  printf 'ERROR: %s\n' "$*" >&2
  exit 1
}

require_yq() {
  command -v yq >/dev/null 2>&1 || die "yq is required"
}

yaml_scalar() {
  local file="$1"
  local key="$2"
  yq eval ".${key}" "$file"
}

yaml_list() {
  local file="$1"
  local key="$2"
  yq eval ".${key}[]" "$file" 2>/dev/null || true
}

json_string_array() {
  local first=1
  printf '['
  while [ "$#" -gt 0 ]; do
    if [ "$first" -eq 0 ]; then
      printf ', '
    fi
    printf '%s' "$1" | python3 -c 'import json,sys; print(json.dumps(sys.stdin.read()), end="")'
    first=0
    shift
  done
  printf ']'
}

json_object() {
  printf '{'
  local first=1
  while [ "$#" -gt 0 ]; do
    local key="$1"
    local value="$2"
    if [ "$first" -eq 0 ]; then
      printf ', '
    fi
    printf '%s' "$key" | python3 -c 'import json,sys; print(json.dumps(sys.stdin.read()), end="")'
    printf ': %s' "$value"
    first=0
    shift 2
  done
  printf '}'
}

json_quote() {
  printf '%s' "$1" | python3 -c 'import json,sys; print(json.dumps(sys.stdin.read()), end="")'
}

json_path_entry_object() {
  local path="$1"
  local when_clause="${2:-}"
  local read_hint="${3:-}"
  local args=("path" "$(json_quote "$path")")
  if [ -n "$when_clause" ]; then
    args+=("when" "$(json_quote "$when_clause")")
  fi
  if [ -n "$read_hint" ]; then
    args+=("read_hint" "$(json_quote "$read_hint")")
  fi
  json_object "${args[@]}"
}

json_path_entries() {
  local first=1
  printf '['
  while [ "$#" -gt 0 ]; do
    local path="$1"
    local when_clause="${2:-}"
    local read_hint="${3:-}"
    if [ "$first" -eq 0 ]; then
      printf ', '
    fi
    printf '%s' "$(json_path_entry_object "$path" "$when_clause" "$read_hint")"
    first=0
    shift 3
  done
  printf ']'
}

render_text_entry_line() {
  local path="$1"
  local read_hint="${2:-}"
  if [ -n "$read_hint" ]; then
    printf -- '- %s (%s)\n' "$path" "$read_hint"
  else
    printf -- '- %s\n' "$path"
  fi
}

render_text_triplets() {
  local -n entries_ref="$1"
  local idx
  for ((idx=0; idx<${#entries_ref[@]}; idx+=3)); do
    render_text_entry_line "${entries_ref[idx]}" "${entries_ref[idx+2]}"
  done
}

render_text_entry_choice() {
  local -n entries_ref="$1"
  local idx joined when_clause
  when_clause="${entries_ref[1]:-}"
  joined=""
  for ((idx=0; idx<${#entries_ref[@]}; idx+=3)); do
    if [ -n "$joined" ]; then
      joined+=" or "
    fi
    joined+="${entries_ref[idx]}"
  done
  printf -- '- %s (%s)\n' "$joined" "$when_clause"
}

render_text_string_list() {
  local -n items_ref="$1"
  local item
  for item in "${items_ref[@]}"; do
    printf -- '- %s\n' "$item"
  done
}

json_bool() {
  if [ "$1" = 'true' ]; then
    printf 'true'
  else
    printf 'false'
  fi
}

find_optional_arg() {
  local needle="$1"
  shift
  local arg
  for arg in "$@"; do
    if [ "$arg" = "$needle" ]; then
      return 0
    fi
  done
  return 1
}

find_workspace_root() {
  if [ -n "${CODESPEC_WORKSPACE_ROOT:-}" ] && [ -f "${CODESPEC_WORKSPACE_ROOT}/.codespec/codespec" ]; then
    printf '%s\n' "$CODESPEC_WORKSPACE_ROOT"
    return
  fi

  local candidate
  candidate="$(dirname "$FRAMEWORK_ROOT")"
  if [ -f "$candidate/.codespec/codespec" ]; then
    printf '%s\n' "$candidate"
    return
  fi

  local dir="$PWD"
  while [ "$dir" != "/" ]; do
    if [ -f "$dir/.codespec/codespec" ]; then
      printf '%s\n' "$dir"
      return
    fi
    dir="$(dirname "$dir")"
  done

  die "could not locate workspace root (directory containing .codespec/)"
}

find_project_root() {
  if [ -n "${CODESPEC_PROJECT_ROOT:-}" ]; then
    (cd "$CODESPEC_PROJECT_ROOT" && pwd)
    return
  fi

  local dir
  dir="$PWD"
  while [ "$dir" != "/" ]; do
    if [ -f "$dir/meta.yaml" ]; then
      printf '%s\n' "$dir"
      return
    fi
    dir="$(dirname "$dir")"
  done

  local git_root metas meta_dir
  if git_root="$(git rev-parse --show-toplevel 2>/dev/null)"; then
    if [ -f "$git_root/meta.yaml" ]; then
      printf '%s\n' "$git_root"
      return
    fi

    mapfile -t metas < <(
      git -C "$git_root" ls-files -co --exclude-standard -- 'meta.yaml' '*/meta.yaml' 2>/dev/null |
        grep -vE '(^|/)(\.codespec|versions|project-docs)/' |
        sort -u
    )
    if [ "${#metas[@]}" -eq 1 ]; then
      meta_dir="$(dirname "${metas[0]}")"
      if [ "$meta_dir" = "." ]; then
        printf '%s\n' "$git_root"
      else
        (cd "$git_root/$meta_dir" && pwd)
      fi
      return
    fi

    if [ "${#metas[@]}" -gt 1 ]; then
      local pwd_meta=""
      local meta_path meta_abs
      for meta_path in "${metas[@]}"; do
        meta_dir="$(dirname "$meta_path")"
        if [ "$meta_dir" = "." ]; then
          meta_abs="$git_root"
        else
          meta_abs="$(cd "$git_root/$meta_dir" && pwd)"
        fi
        if [ "$PWD" = "$meta_abs" ] || [[ "$PWD" == "$meta_abs/"* ]]; then
          pwd_meta="$meta_abs"
          break
        fi
      done
      if [ -n "$pwd_meta" ]; then
        printf '%s\n' "$pwd_meta"
        return
      fi
      die "multiple meta.yaml found in git repo; cd into a specific project directory or set CODESPEC_PROJECT_ROOT"
    fi

    printf '%s\n' "$git_root"
    return
  fi

  printf '%s\n' "$PWD"
}

match_path() {
  local file="$1"
  local pattern="$2"
  [ -n "$pattern" ] || return 1
  case "$file" in
    "$pattern") return 0 ;;
    $pattern) return 0 ;;
    *) return 1 ;;
  esac
}

render_template() {
  local src="$1"
  local dest="$2"
  local content
  content="$(<"$src")"
  content="${content//__DATE__/${RENDER_DATE:-}}"
  content="${content//__CHANGE_ID__/${RENDER_CHANGE_ID:-}}"
  content="${content//__BASE_VERSION__/${RENDER_BASE_VERSION:-}}"
  content="${content//__UPDATED_BY__/${RENDER_UPDATED_BY:-}}"
  content="${content//__PHASE__/${RENDER_PHASE:-}}"
  content="${content//__STATUS__/${RENDER_STATUS:-}}"
  content="${content//__IMPLEMENTATION_BASE_REVISION__/${RENDER_IMPLEMENTATION_BASE_REVISION:-null}}"
  content="${content//__DERIVED_FROM__/${RENDER_DERIVED_FROM:-}}"
  printf '%s\n' "$content" > "$dest"
}

validate_stable_version() {
  local stable_version="$1"
  [ -n "$stable_version" ] || die 'Invalid stable version: empty value'
  [[ "$stable_version" =~ ^[A-Za-z0-9._-]+$ ]] || die "Invalid stable version: '$stable_version' (use letters, digits, dot, underscore, or dash)"
  [[ "$stable_version" != *..* ]] || die "Invalid stable version: '$stable_version' must not contain '..'"
}

gate_map_file() {
  local file="$FRAMEWORK_ROOT/templates/gate-map.yaml"
  [ -f "$file" ] || die "missing gate map: templates/gate-map.yaml"
  printf '%s\n' "$file"
}

transition_exists() {
  local transition="$1"
  local file
  file="$(gate_map_file)"
  TRANSITION="$transition" yq eval '.transitions | has(strenv(TRANSITION))' "$file" 2>/dev/null | grep -qx 'true'
}

transition_gate_rows() {
  local transition="$1"
  local include_review="${2:-yes}"
  local file
  file="$(gate_map_file)"
  TRANSITION="$transition" INCLUDE_REVIEW="$include_review" yq eval -r '
    .transitions[strenv(TRANSITION)].gates[]
    | select(strenv(INCLUDE_REVIEW) == "yes" or .gate != "review-quality")
    | [.gate, ((.env // {}) | to_entries | map(.key + "=" + .value) | join(" "))]
    | @tsv
  ' "$file"
}

gate_command_string() {
  local gate="$1"
  local envs="${2:-}"
  if [ -n "$envs" ]; then
    printf '%s codespec check-gate %s\n' "$envs" "$gate"
  else
    printf 'codespec check-gate %s\n' "$gate"
  fi
}

run_mapped_gate() {
  local project_root="$1"
  local gate="$2"
  local envs="${3:-}"
  local env_args=("CODESPEC_PROJECT_ROOT=$project_root")
  local pair
  for pair in $envs; do
    [ -n "$pair" ] || continue
    env_args+=("$pair")
  done
  env "${env_args[@]}" "$FRAMEWORK_ROOT/scripts/check-gate.sh" "$gate"
}

run_transition_gates() {
  local project_root="$1"
  local transition="$2"
  local include_review="${3:-yes}"
  local rows=()
  local row gate envs

  transition_exists "$transition" || die "unknown transition: $transition"
  mapfile -t rows < <(transition_gate_rows "$transition" "$include_review")
  for row in "${rows[@]}"; do
    IFS=$'\t' read -r gate envs <<< "$row"
    [ -n "$gate" ] || continue
    run_mapped_gate "$project_root" "$gate" "$envs"
  done
}

copy_dir_contents() {
  local src="$1"
  local dest="$2"
  mkdir -p "$dest"
  if [ -d "$src" ]; then
    cp -R "$src/." "$dest/"
  fi
}

current_git_branch() {
  local project_root="$1"
  if git -C "$project_root" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    git -C "$project_root" symbolic-ref --quiet --short HEAD 2>/dev/null || printf 'detached'
    return
  fi
  printf 'none'
}

current_git_revision() {
  local project_root="$1"
  if git -C "$project_root" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    git -C "$project_root" rev-parse HEAD
    return
  fi
  printf 'null'
}

require_git_repo() {
  local project_root="$1"
  git -C "$project_root" rev-parse --is-inside-work-tree >/dev/null 2>&1 || die "git repository not found at $project_root"
}

validate_git_revision() {
  local project_root="$1"
  local revision="$2"
  [ -n "$revision" ] || return 1
  [ "$revision" != 'null' ] || return 1
  git -C "$project_root" rev-parse --verify "${revision}^{commit}" >/dev/null 2>&1
}

ensure_clean_git_worktree() {
  local project_root="$1"
  git -C "$project_root" diff --quiet --ignore-submodules -- || die 'submit-pr requires a clean git working tree'
  git -C "$project_root" diff --cached --quiet --ignore-submodules -- || die 'submit-pr requires a clean git working tree'
}

ensure_reset_worktree_clean() {
  local project_root="$1"
  local status_output
  git -C "$project_root" rev-parse --is-inside-work-tree >/dev/null 2>&1 || return 0
  status_output="$(git -C "$project_root" status --porcelain --untracked-files=all)"
  [ -z "$status_output" ] || die 'reset-to-requirement refuses to overwrite a dirty worktree; commit/stash changes or rerun with --force'
}

project_migration_backup_root() {
  local project_root="$1"
  local workspace_root slug
  workspace_root="$(find_workspace_root)"
  slug="$(legacy_wi_project_slug "$(cd "$project_root" && pwd)")"
  printf '%s/.codespec/migration-backups/%s\n' "$workspace_root" "$slug"
}

backup_project_directory() {
  local project_root="$1"
  local rel_dir="$2"
  local backup_name="$3"
  local src="$project_root/$rel_dir"
  [ -d "$src" ] || return 0

  local backup_root base dest suffix
  backup_root="$(project_migration_backup_root "$project_root")"
  mkdir -p "$backup_root"
  base="$backup_root/$backup_name.$(date +%Y%m%d%H%M%S)"
  dest="$base"
  suffix=1
  while [ -e "$dest" ]; do
    dest="$base.$suffix"
    suffix=$((suffix + 1))
  done
  mv "$src" "$dest"
  log "backed up: $rel_dir/ -> $dest"
}

ensure_deployed_source_revision_current() {
  local project_root="$1"
  local deployment_file="$project_root/deployment.md"
  local source_revision file allowed_patterns=(
    "meta.yaml"
    "spec.md"
    "design.md"
    "deployment.md"
    "testing.md"
    "AGENTS.md"
    "CLAUDE.md"
    "contracts/**"
    "spec-appendices/**"
    "design-appendices/**"
    "reviews/**"
    "scripts/codespec-deploy"
    "versions/**"
  )

  [ -f "$deployment_file" ] || die 'submit-pr requires deployment.md'
  source_revision="$(markdown_section_scalar "$deployment_file" '## Execution Evidence' 'source_revision')"
  is_placeholder_value "$source_revision" && die 'deployment.md source_revision is missing'
  validate_git_revision "$project_root" "$source_revision" || die "deployment.md source_revision is not a valid commit: $source_revision"

  while IFS= read -r file; do
    [ -n "$file" ] || continue
    local ok=0
    local pattern
    for pattern in "${allowed_patterns[@]}"; do
      if match_path "$file" "$pattern"; then
        ok=1
        break
      fi
    done
    [ "$ok" -eq 1 ] || die "submit-pr includes source changes after deployed source_revision: $file"
  done < <(git -C "$project_root" diff --name-only --diff-filter=ACMRD "$source_revision..HEAD")
}

resolve_default_branch() {
  local project_root="$1"
  local remote_head
  remote_head="$(git -C "$project_root" symbolic-ref --quiet --short refs/remotes/origin/HEAD 2>/dev/null || true)"
  if [ -n "$remote_head" ]; then
    printf '%s\n' "${remote_head#origin/}"
    return
  fi

  if git -C "$project_root" show-ref --verify --quiet refs/heads/main; then
    printf 'main\n'
    return
  fi

  if git -C "$project_root" show-ref --verify --quiet refs/heads/master; then
    printf 'master\n'
    return
  fi

  die 'could not resolve default branch; pass --base <branch>'
}

extract_markdown_section_text() {
  local file="$1"
  local header="$2"
  awk -v header="$header" '
    function is_header_alias(line, expected) {
      if (line == expected) return 1
      if (expected == "## Summary" && line == "## 1. 需求概览") return 1
      return 0
    }
    is_header_alias($0, header) {
      in_section = 1
      next
    }
    in_section && /^## / {
      exit
    }
    in_section {
      print
    }
  ' "$file"
}

submit_pr_body_file() {
  local project_root="$1"
  local stable_version="$2"
  local meta="$project_root/meta.yaml"
  local deployment="$project_root/deployment.md"
  local spec="$project_root/spec.md"
  local tmp summary acceptance_notes execution_ref deployed_revision source_revision
  tmp="$(mktemp)"
  summary="$(extract_markdown_section_text "$spec" '## Summary' | sed '/^[[:space:]]*$/d' | head -n 3)"
  acceptance_notes="$(markdown_section_scalar "$deployment" '## Acceptance Conclusion' 'notes')"
  execution_ref="$(markdown_section_scalar "$deployment" '## Execution Evidence' 'execution_ref')"
  deployed_revision="$(markdown_section_scalar "$deployment" '## Execution Evidence' 'deployed_revision')"
  source_revision="$(markdown_section_scalar "$deployment" '## Execution Evidence' 'source_revision')"
  cat > "$tmp" <<EOF
## Summary

change_id: $(yaml_scalar "$meta" change_id)
stable_version: $stable_version

${summary:-No summary captured.}

## Acceptance

$acceptance_notes

## Deployment Evidence

- execution_ref: $execution_ref
- deployed_revision: $deployed_revision
- source_revision: $source_revision
EOF
  printf '%s\n' "$tmp"
}

resolve_promoted_base_version() {
  local project_root="$1"
  local current_change_id="$2"
  local versions_dir="$project_root/versions"
  local direct_meta="$versions_dir/$current_change_id/meta.yaml"

  if [ -f "$direct_meta" ] && [ "$(yaml_scalar "$direct_meta" change_id)" = "$current_change_id" ]; then
    printf '%s\n' "$current_change_id"
    return
  fi

  [ -d "$versions_dir" ] || die "versions directory not found: $versions_dir"

  local candidate_lines=""
  local meta_file version_dir version_name archived_change_id promoted_at promoted_flag mtime
  while IFS= read -r -d '' meta_file; do
    version_dir="$(dirname "$meta_file")"
    version_name="$(basename "$version_dir")"
    archived_change_id="$(yaml_scalar "$meta_file" change_id)"
    [ "$archived_change_id" = "$current_change_id" ] || continue

    promoted_at="$(yq eval '.promoted_at // ""' "$meta_file")"
    promoted_flag=0
    if [ -n "$promoted_at" ]; then
      promoted_flag=1
    fi
    mtime="$(stat -c '%Y' "$version_dir")"

    candidate_lines+="$promoted_flag"$'\t'"$promoted_at"$'\t'"$mtime"$'\t'"$version_name"$'\n'
  done < <(find "$versions_dir" -mindepth 2 -maxdepth 2 -name meta.yaml -print0)

  [ -n "$candidate_lines" ] || die "current completed dossier has not been promoted yet (run complete-change <stable-version> first)"

  printf '%s' "$candidate_lines" \
    | sort -t $'\t' -k1,1nr -k2,2r -k3,3nr -k4,4r \
    | head -n 1 \
    | cut -f4
}

meta_update() {
  local meta_file="$1"
  shift
  TODAY="$(date +%F)" UPDATED_BY="codespec-cli" yq eval "$* | .updated_at = env(TODAY) | .updated_by = env(UPDATED_BY)" -i "$meta_file"
}

# Atomic meta update with postcondition verification.
# Backs up meta.yaml, applies updates, runs metadata-consistency, rolls back on failure.
atomic_meta_update() {
  local meta_file="$1"
  shift
  local project_root
  project_root="$(dirname "$meta_file")"
  local backup
  backup="$(mktemp)"
  cp "$meta_file" "$backup"

  set +e
  meta_update "$meta_file" "$@"
  local update_rc=$?
  if [ "$update_rc" -ne 0 ]; then
    cp "$backup" "$meta_file"
    rm -f "$backup"
    die "meta_update failed (rc=${update_rc})"
  fi

  local gate_output gate_rc
  gate_output="$(CODESPEC_PROJECT_ROOT="$project_root" "$FRAMEWORK_ROOT/scripts/check-gate.sh" metadata-consistency 2>&1)"
  gate_rc=$?
  set -e

  if [ "$gate_rc" -ne 0 ]; then
    cp "$backup" "$meta_file"
    rm -f "$backup"
    die "post-update metadata-consistency check failed, rolled back: $gate_output"
  fi
  rm -f "$backup"
}

trim_value() {
  local value="$1"
  value="${value#"${value%%[![:space:]]*}"}"
  value="${value%"${value##*[![:space:]]}"}"
  printf '%s' "$value"
}

is_placeholder_value() {
  local value normalized
  value="$(trim_value "$1")"
  [ -n "$value" ] || return 0

  normalized="$(printf '%s' "$value" | tr '[:upper:]' '[:lower:]' | tr -d "'\"")"
  case "$normalized" in
    null|pending|todo|tbd|placeholder|pass/fail|yyyy-mm-dd|待填写|待补充|待确认)
      return 0
      ;;
  esac

  [[ "$normalized" =~ ^\[[^]]+\]$ ]] && return 0
  return 1
}

markdown_section_scalar() {
  local file="$1"
  local header="$2"
  local key="$3"
  awk -v header="$header" -v key="$key" '
    function is_header_alias(line, expected) {
      if (line == expected) return 1
      if (expected == "## Deployment Plan" && line == "## 1. 发布对象与环境") return 1
      if (expected == "## Execution Evidence" && line == "## 3. 执行证据") return 1
      if (expected == "## Verification Results" && line == "## 4. 运行验证") return 1
      if (expected == "## Acceptance Conclusion" && line == "## 6. 人工验收与收口") return 1
      return 0
    }
    is_header_alias($0, header) {
      in_section = 1
      next
    }
    in_section && /^## / {
      exit
    }
    in_section && $0 ~ "^[[:space:]]*-?[[:space:]]*" key ":[[:space:]]*" {
      line = $0
      sub("^[[:space:]]*-?[[:space:]]*" key ":[[:space:]]*", "", line)
      sub(/[[:space:]]*$/, "", line)
      print line
      exit
    }
  ' "$file"
}

replace_markdown_section() {
  local file="$1"
  local header="$2"
  local replacement="$3"
  local tmp
  tmp="$(mktemp)"

  awk -v header="$header" -v replacement="$replacement" '
    function is_header_alias(line, expected) {
      if (line == expected) return 1
      if (expected == "## Execution Evidence" && line == "## 3. 执行证据") return 1
      if (expected == "## Verification Results" && line == "## 4. 运行验证") return 1
      if (expected == "## Acceptance Conclusion" && line == "## 6. 人工验收与收口") return 1
      return 0
    }
    BEGIN {
      in_section = 0
      replaced = 0
      replacement_lines = split(replacement, lines, /\n/)
    }
    is_header_alias($0, header) {
      print
      for (i = 1; i <= replacement_lines; i++) {
        print lines[i]
      }
      in_section = 1
      replaced = 1
      next
    }
    in_section && /^## / {
      in_section = 0
    }
    !in_section {
      print
    }
    END {
      if (!replaced) {
        exit 2
      }
    }
  ' "$file" > "$tmp" || {
    rm -f "$tmp"
    die "missing section ${header} in ${file}"
  }

  mv "$tmp" "$file"
}

archive_dossier() {
  local stable_version="$1"
  local project_root="$2"
  local target_root="$project_root/versions/$stable_version"
  [ ! -e "$target_root" ] || die "target version already exists: versions/$stable_version"

  mkdir -p "$target_root"
  cp "$project_root/meta.yaml" "$target_root/meta.yaml"
  cp "$project_root/spec.md" "$target_root/spec.md"
  cp "$project_root/design.md" "$target_root/design.md"
  [ -f "$project_root/testing.md" ] && cp "$project_root/testing.md" "$target_root/testing.md"
  [ -f "$project_root/deployment.md" ] && cp "$project_root/deployment.md" "$target_root/deployment.md"
  [ -f "$project_root/CLAUDE.md" ] && cp "$project_root/CLAUDE.md" "$target_root/CLAUDE.md"
  [ -f "$project_root/AGENTS.md" ] && cp "$project_root/AGENTS.md" "$target_root/AGENTS.md"
  copy_dir_contents "$project_root/reviews" "$target_root/reviews"
  copy_dir_contents "$project_root/contracts" "$target_root/contracts"
  copy_dir_contents "$project_root/spec-appendices" "$target_root/spec-appendices"
  copy_dir_contents "$project_root/design-appendices" "$target_root/design-appendices"
  if [ -f "$project_root/scripts/codespec-deploy" ]; then
    mkdir -p "$target_root/scripts"
    cp "$project_root/scripts/codespec-deploy" "$target_root/scripts/codespec-deploy"
  fi

  TODAY="$(date +%F)" \
  STABLE_VERSION="$stable_version" \
  PROMOTED_AT="$(date -u +%Y-%m-%dT%H:%M:%S.%NZ)" \
    yq eval '.status = "completed" | .stable_version = strenv(STABLE_VERSION) | .updated_at = env(TODAY) | .updated_by = "codespec-complete" | .promoted_version = strenv(STABLE_VERSION) | .promoted_at = strenv(PROMOTED_AT)' -i "$target_root/meta.yaml"
}


assert_phase_transition() {
  local current_phase="$1"
  local target_phase="$2"
  local current_status="$3"

  case "$target_phase" in
    Design)
      [ "$current_phase" = 'Requirement' ] || die "cannot move from ${current_phase} to ${target_phase}"
      ;;
    Implementation)
      if [ "$current_phase" = 'Design' ]; then
        return
      fi
      die "cannot move from ${current_phase} to ${target_phase}"
      ;;
    Testing)
      [ "$current_phase" = 'Implementation' ] || die "cannot move from ${current_phase} to ${target_phase}"
      ;;
    Deployment)
      if [ "$current_phase" = 'Deployment' ] && [ "$current_status" = 'completed' ]; then
        return
      fi
      [ "$current_phase" = 'Testing' ] || die "cannot move from ${current_phase} to ${target_phase}"
      ;;
    *)
      die "unsupported target phase: ${target_phase}"
      ;;
  esac
}

contains_exact_line() {
  local needle="$1"
  shift || true
  local item
  for item in "$@"; do
    [ "$item" = "$needle" ] && return 0
  done
  return 1
}

validate_authority_repair_gate() {
  local gate="$1"
  case "$gate" in
    requirement-complete|spec-quality|design-quality|design-readiness|implementation-ready|implementation-start|scope|contract-boundary|trace-consistency|verification|testing-coverage|deployment-plan-ready|deployment-readiness|promotion-criteria)
      ;;
    *)
      die "unsupported authority repair gate: $gate"
      ;;
  esac
}

validate_authority_repair_kind() {
  local kind="$1"
  case "$kind" in
    standard|source-trace)
      ;;
    *)
      die "unsupported authority repair kind: $kind"
      ;;
  esac
}

validate_authority_repair_path() {
  local project_root="$1"
  local phase="$2"
  local kind="$3"
  local path="$4"
  local meta="$project_root/meta.yaml"

  [ -n "$path" ] || die 'authority repair path must be non-empty'
  [[ "$path" != /* ]] || die "authority repair path must be relative: $path"
  [[ "$path" != *..* ]] || die "authority repair path must not contain '..': $path"

  validate_authority_repair_kind "$kind"
  if [ "$kind" = 'source-trace' ]; then
    case "$path" in
      spec.md|spec-appendices/*.md|design.md)
        return 0
        ;;
      *)
        die "source-trace authority repair path is not allowed: $path"
        ;;
    esac
  fi

  case "$path" in
    meta.yaml|spec.md|src/**|src/*|Dockerfile|versions/**|versions/*|authority-repairs/**|authority-repairs/*|spec-appendices/**|spec-appendices/*)
      die "authority repair path is not allowed: $path"
      ;;
  esac

  case "$path" in
    design.md|testing.md)
      return 0
      ;;
    deployment.md)
      case "$phase" in
        Testing|Deployment) return 0 ;;
        *) die "deployment.md authority repair is only allowed in Testing/Deployment phase" ;;
      esac
      ;;
    contracts/*.md)
      if [ -f "$project_root/$path" ] && [ "$(grep '^status:' "$project_root/$path" | awk '{print $2}' || true)" = 'frozen' ]; then
        die "authority repair cannot modify frozen contract: $path"
      fi
      return 0
      ;;
  esac

  die "authority repair path is not allowed: $path"
}

parse_authority_repair_paths_arg() {
  local raw="$1"
  local project_root="$2"
  local phase="$3"
  local kind="$4"
  [ -n "$raw" ] || die 'authority repair requires --paths'

  local item count=0
  IFS=',' read -r -a items <<< "$raw"
  for item in "${items[@]}"; do
    item="$(trim_value "$item")"
    [ -n "$item" ] || continue
    validate_authority_repair_path "$project_root" "$phase" "$kind" "$item"
    printf '%s\n' "$item"
    count=$((count + 1))
  done
  [ "$count" -gt 0 ] || die 'authority repair requires at least one allowed path'
}

next_authority_repair_id() {
  local repair_dir="$1"
  local base candidate suffix
  base="REPAIR-$(date -u +%Y%m%d%H%M%S)"
  candidate="$base"
  suffix=1
  while [ -e "$repair_dir/$candidate.yaml" ]; do
    suffix=$((suffix + 1))
    candidate="${base}-${suffix}"
  done
  printf '%s\n' "$candidate"
}

active_authority_repair_id() {
  local meta="$1"
  yq eval '.active_authority_repair // "null"' "$meta"
}

authority_repair_begin() {
  require_yq
  local gate="${1:?usage: codespec authority-repair begin <gate> --paths <csv> --reason <reason>}"
  shift
  validate_authority_repair_gate "$gate"

  local paths_arg="" reason="" kind="standard"
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --paths)
        [ "$#" -ge 2 ] || die 'authority-repair begin --paths requires a value'
        paths_arg="$2"
        shift 2
        ;;
      --reason)
        [ "$#" -ge 2 ] || die 'authority-repair begin --reason requires a value'
        reason="$2"
        shift 2
        ;;
      --kind)
        [ "$#" -ge 2 ] || die 'authority-repair begin --kind requires a value'
        kind="$2"
        shift 2
        ;;
      *)
        die "unknown authority-repair begin option: $1"
        ;;
    esac
  done

  validate_authority_repair_kind "$kind"
  if [ "$kind" = 'source-trace' ]; then
    case "$gate" in
      requirement-complete|spec-quality|design-quality|trace-consistency) ;;
      *) die "source-trace authority repair does not support gate: $gate" ;;
    esac
  fi
  is_placeholder_value "$reason" && die 'authority repair reason is required'

  local project_root meta phase active repair_dir repair_id repair_file opened_at opened_revision paths=() path
  project_root="$(find_project_root)"
  meta="$project_root/meta.yaml"
  [ -f "$meta" ] || die "missing meta.yaml"
  phase="$(yaml_scalar "$meta" phase)"
  case "$phase" in
    Implementation|Testing|Deployment) ;;
    *) die "authority repair requires Implementation, Testing, or Deployment phase (got: $phase)" ;;
  esac

  active="$(active_authority_repair_id "$meta")"
  [ "$active" = 'null' ] || die "authority repair already active: $active"

  mapfile -t paths < <(parse_authority_repair_paths_arg "$paths_arg" "$project_root" "$phase" "$kind")

  repair_dir="$project_root/authority-repairs"
  mkdir -p "$repair_dir"
  repair_id="$(next_authority_repair_id "$repair_dir")"
  repair_file="$repair_dir/$repair_id.yaml"
  opened_at="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
  opened_revision="$(current_git_revision "$project_root")"

  REPAIR_ID="$repair_id" \
  PHASE="$phase" \
  GATE="$gate" \
  KIND="$kind" \
  REASON="$reason" \
  OPENED_AT="$opened_at" \
  OPENED_REVISION="$opened_revision" \
    yq eval -n '.repair_id = env(REPAIR_ID) | .status = "open" | .phase = env(PHASE) | .gate = env(GATE) | .kind = env(KIND) | .reason = env(REASON) | .allowed_paths = [] | .opened_at = env(OPENED_AT) | .opened_revision = env(OPENED_REVISION) | .closed_at = null | .closed_revision = null | .evidence = null | .gate_result = null | .smoke_result = null' > "$repair_file"

  for path in "${paths[@]}"; do
    PATH_VALUE="$path" yq eval '.allowed_paths += [env(PATH_VALUE)]' -i "$repair_file"
  done

  set +e
  atomic_meta_update "$meta" ".active_authority_repair = \"$repair_id\""
  local update_rc=$?
  set -e
  if [ "$update_rc" -ne 0 ]; then
    rm -f "$repair_file"
    die "failed to activate authority repair: $repair_id"
  fi

  log "started authority repair: $repair_id"
  log "gate: $gate"
  log "kind: $kind"
  log "allowed_paths: ${paths[*]}"
}

spec_requirements_semantic_fingerprint() {
  local file="$1"
  awk '
    /^## Requirements$/ || /^## 4\. 需求与验收$/ {
      in_section = 1
      print
      next
    }
    in_section && /^## / {
      exit
    }
    !in_section {
      next
    }
    /^[[:space:]]*source_ref:[[:space:]]*/ || /^[[:space:]]*-[[:space:]]*source_ref:[[:space:]]*/ {
      next
    }
    /^[[:space:]]*decision_refs:[[:space:]]*/ || /^[[:space:]]*-[[:space:]]*decision_refs:[[:space:]]*/ {
      next
    }
    /^[[:space:]]*-[[:space:]]*DEC-[0-9]{3}[[:space:]]*$/ {
      next
    }
    {
      gsub(/[[:space:]]+$/, "")
      print
    }
  ' "$file" | sha256sum | awk '{print $1}'
}

validate_source_trace_repair_semantics() {
  local project_root="$1"
  local repair_file="$2"
  local opened_revision base_tmp base_hash current_hash
  opened_revision="$(yaml_scalar "$repair_file" opened_revision)"
  [ -n "$opened_revision" ] && [ "$opened_revision" != 'null' ] || die 'source-trace repair requires opened_revision'

  base_tmp="$(mktemp)"
  if ! git -C "$project_root" show "$opened_revision:spec.md" > "$base_tmp" 2>/dev/null; then
    rm -f "$base_tmp"
    die "source-trace repair cannot read opened spec.md at $opened_revision"
  fi

  base_hash="$(spec_requirements_semantic_fingerprint "$base_tmp")"
  current_hash="$(spec_requirements_semantic_fingerprint "$project_root/spec.md")"
  rm -f "$base_tmp"
  [ "$base_hash" = "$current_hash" ] || die 'source-trace repair changed spec.md requirement semantics'
}

authority_repair_close() {
  require_yq
  local evidence=""
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --evidence)
        [ "$#" -ge 2 ] || die 'authority-repair close --evidence requires a value'
        evidence="$2"
        shift 2
        ;;
      *)
        die "unknown authority-repair close option: $1"
        ;;
    esac
  done
  is_placeholder_value "$evidence" && die 'authority repair close requires --evidence'

  local project_root meta repair_id repair_file gate kind gate_output closed_at closed_revision backup_meta backup_repair metadata_output
  local gate_rc metadata_rc
  project_root="$(find_project_root)"
  meta="$project_root/meta.yaml"
  [ -f "$meta" ] || die "missing meta.yaml"
  repair_id="$(active_authority_repair_id "$meta")"
  [ "$repair_id" != 'null' ] || die 'no active authority repair'
  repair_file="$project_root/authority-repairs/$repair_id.yaml"
  [ -f "$repair_file" ] || die "missing authority repair record: authority-repairs/$repair_id.yaml"
  [ "$(yaml_scalar "$repair_file" status)" = 'open' ] || die "authority repair is not open: $repair_id"
  gate="$(yaml_scalar "$repair_file" gate)"
  validate_authority_repair_gate "$gate"
  kind="$(yq eval '.kind // "standard"' "$repair_file")"
  validate_authority_repair_kind "$kind"

  set +e
  gate_output="$(CODESPEC_PROJECT_ROOT="$project_root" CODESPEC_AUTHORITY_REPAIR_CLOSING=1 "$FRAMEWORK_ROOT/scripts/check-gate.sh" "$gate" 2>&1)"
  gate_rc=$?
  set -e
  [ "$gate_rc" -eq 0 ] || die "authority repair close gate failed (${gate}): $gate_output"
  if [ "$kind" = 'source-trace' ]; then
    validate_source_trace_repair_semantics "$project_root" "$repair_file"
  fi

  closed_at="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
  closed_revision="$(current_git_revision "$project_root")"
  backup_meta="$(mktemp)"
  backup_repair="$(mktemp)"
  cp "$meta" "$backup_meta"
  cp "$repair_file" "$backup_repair"

  set +e
  EVIDENCE="$evidence" CLOSED_AT="$closed_at" CLOSED_REVISION="$closed_revision" \
    yq eval '.status = "closed" | .closed_at = env(CLOSED_AT) | .closed_revision = env(CLOSED_REVISION) | .evidence = env(EVIDENCE) | .gate_result = "pass" | .smoke_result = "not-run"' -i "$repair_file"
  metadata_rc=$?
  if [ "$metadata_rc" -eq 0 ]; then
    meta_update "$meta" '.active_authority_repair = null'
    metadata_rc=$?
  fi
  if [ "$metadata_rc" -eq 0 ]; then
    metadata_output="$(CODESPEC_PROJECT_ROOT="$project_root" "$FRAMEWORK_ROOT/scripts/check-gate.sh" metadata-consistency 2>&1)"
    metadata_rc=$?
  else
    metadata_output="authority repair close state update failed"
  fi
  set -e
  if [ "$metadata_rc" -ne 0 ]; then
    cp "$backup_meta" "$meta"
    cp "$backup_repair" "$repair_file"
    rm -f "$backup_meta" "$backup_repair"
    die "metadata-consistency failed while closing authority repair, rolled back: $metadata_output"
  fi

  rm -f "$backup_meta" "$backup_repair"
  log "closed authority repair: $repair_id"
}

authority_repair_status() {
  require_yq
  local project_root meta repair_id
  project_root="$(find_project_root)"
  meta="$project_root/meta.yaml"
  [ -f "$meta" ] || die "missing meta.yaml"
  repair_id="$(active_authority_repair_id "$meta")"
  printf 'active_authority_repair: %s\n' "$repair_id"
  if [ "$repair_id" != 'null' ] && [ -f "$project_root/authority-repairs/$repair_id.yaml" ]; then
    yq eval '.' "$project_root/authority-repairs/$repair_id.yaml"
  fi
}

authority_repair_cmd() {
  local subcmd="${1:-}"
  shift || true
  case "$subcmd" in
    begin)
      authority_repair_begin "$@"
      ;;
    close)
      authority_repair_close "$@"
      ;;
    status)
      authority_repair_status "$@"
      ;;
    *)
      die 'usage: codespec authority-repair <begin|close|status>'
      ;;
  esac
}



materialize_deployment() {
  require_yq
  local project_root
  project_root="$(find_project_root)"
  local target="$project_root/deployment.md"
  [ ! -f "$target" ] || die "deployment.md already exists"
  cp "$FRAMEWORK_ROOT/templates/deployment.md" "$target"
  log "created deployment file: deployment.md"
}

start_design() {
  require_yq
  local project_root
  project_root="$(find_project_root)"
  local meta="$project_root/meta.yaml"
  [ -f "$meta" ] || die "missing meta.yaml"

  local current_phase current_status
  current_phase="$(yaml_scalar "$meta" phase)"
  current_status="$(yaml_scalar "$meta" status)"
  assert_phase_transition "$current_phase" 'Design' "$current_status"

  local workspace_root
  workspace_root="$(find_workspace_root)"

  if [ ! -f "$project_root/testing.md" ]; then
    if [ -f "$workspace_root/.codespec/templates/testing.md" ]; then
      RENDER_PHASE="Design" \
        render_template "$workspace_root/.codespec/templates/testing.md" "$project_root/testing.md"
    else
      die "missing testing.md template: $workspace_root/.codespec/templates/testing.md"
    fi
    log "created testing.md"
  fi

  run_transition_gates "$project_root" start-design >/dev/null

  meta_update "$meta" '.phase = "Design" | .status = "active"'
  log "started Design phase"
}

start_implementation() {
  require_yq
  local project_root
  project_root="$(find_project_root)"
  local meta="$project_root/meta.yaml"
  [ -f "$meta" ] || die "missing meta.yaml"

  local current_phase current_status implementation_base_revision design_quality_checked_at design_quality_revision
  current_phase="$(yaml_scalar "$meta" phase)"
  current_status="$(yaml_scalar "$meta" status)"
  assert_phase_transition "$current_phase" 'Implementation' "$current_status"

  if [ "$current_phase" = 'Implementation' ]; then
    die "already in Implementation phase; use reopen-implementation if you need to re-enter after Testing/Deployment"
  fi

  run_transition_gates "$project_root" start-implementation >/dev/null
  design_quality_checked_at="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
  design_quality_revision="$(current_git_revision "$project_root")"

  implementation_base_revision="$(yaml_scalar "$meta" implementation_base_revision)"
  if [ "$current_phase" != 'Implementation' ] || [ "$implementation_base_revision" = 'null' ] || [ -z "$implementation_base_revision" ]; then
    implementation_base_revision="$(current_git_revision "$project_root")"
  fi
  atomic_meta_update "$meta" ".phase = \"Implementation\" | .status = \"active\" | .implementation_base_revision = \"$implementation_base_revision\" | .gate_evidence.implementation_entry = {\"gate\": \"implementation-ready\", \"status\": \"pass\", \"checked_at\": \"$design_quality_checked_at\", \"checked_revision\": \"$design_quality_revision\"}"
  log "started Implementation phase"
}

start_testing() {
  require_yq
  local project_root
  project_root="$(find_project_root)"
  local meta="$project_root/meta.yaml"
  [ -f "$meta" ] || die "missing meta.yaml"

  local current_phase current_status
  current_phase="$(yaml_scalar "$meta" phase)"
  current_status="$(yaml_scalar "$meta" status)"
  assert_phase_transition "$current_phase" 'Testing' "$current_status"

  run_transition_gates "$project_root" start-testing

  meta_update "$meta" '.phase = "Testing" | .status = "active"'
  log "started Testing phase"
}

start_deployment() {
  require_yq
  local project_root workspace_root
  project_root="$(find_project_root)"
  workspace_root="$(find_workspace_root)"
  local meta="$project_root/meta.yaml"
  [ -f "$meta" ] || die "missing meta.yaml"

  local current_phase current_status deployment_file
  current_phase="$(yaml_scalar "$meta" phase)"
  current_status="$(yaml_scalar "$meta" status)"
  assert_phase_transition "$current_phase" 'Deployment' "$current_status"

  # 如果是 reopen 场景（completed -> active）
  if [ "$current_status" = 'completed' ]; then
    local stable_version change_id archived_meta
    stable_version="$(yaml_scalar "$meta" stable_version)"
    change_id="$(yaml_scalar "$meta" change_id)"

    # 优先使用 stable_version，fallback 到 change_id（兼容旧版本）
    if [ "$stable_version" != 'null' ] && [ -n "$stable_version" ]; then
      archived_meta="$project_root/versions/$stable_version/meta.yaml"
    else
      archived_meta="$project_root/versions/$change_id/meta.yaml"
    fi

    if [ -f "$archived_meta" ]; then
      local archived_change_id meta_before gate_output gate_status
      archived_change_id="$(yaml_scalar "$archived_meta" change_id)"
      [ "$archived_change_id" = "$change_id" ] || die "cannot reopen Deployment: archived meta change_id mismatch at $archived_meta"
      meta_before="$(mktemp)"
      cp "$meta" "$meta_before"
      meta_update "$meta" ".phase = \"Deployment\" | .status = \"active\" | .stable_version = null"
      set +e
      gate_output="$(
        CODESPEC_PROJECT_ROOT="$project_root" "$FRAMEWORK_ROOT/scripts/check-gate.sh" trace-consistency &&
        CODESPEC_PROJECT_ROOT="$project_root" CODESPEC_DIRTY_WORKTREE_IGNORE=meta.yaml "$FRAMEWORK_ROOT/scripts/check-gate.sh" verification
      )"
      gate_status=$?
      set -e
      if [ "$gate_status" -ne 0 ]; then
        cp "$meta_before" "$meta"
        rm -f "$meta_before"
        printf '%s\n' "$gate_output" >&2
        die 'cannot reopen Deployment: verification gates failed'
      fi
      rm -f "$meta_before"
      log "reopened Deployment phase"
      return
    else
      die "cannot reopen Deployment: archived meta not found at $archived_meta"
    fi
  fi

  run_transition_gates "$project_root" start-deployment >/dev/null

  deployment_file="$project_root/deployment.md"
  if [ ! -f "$deployment_file" ]; then
    cp "$FRAMEWORK_ROOT/templates/deployment.md" "$deployment_file"
  fi

  meta_update "$meta" '.phase = "Deployment" | .status = "active"'
  log "started Deployment phase"
}

deploy_change() {
  require_yq
  local project_root
  project_root="$(find_project_root)"
  local meta="$project_root/meta.yaml"
  local deployment_file="$project_root/deployment.md"
  [ -f "$meta" ] || die "missing meta.yaml"
  [ -f "$deployment_file" ] || die 'missing deployment.md'

  local current_phase current_status
  current_phase="$(yaml_scalar "$meta" phase)"
  current_status="$(yaml_scalar "$meta" status)"
  [ "$current_phase" = 'Deployment' ] || die 'deploy requires Deployment phase'
  [ "$current_status" = 'active' ] || die 'deploy requires active Deployment status'

  local target_env
  target_env="$(markdown_section_scalar "$deployment_file" '## Deployment Plan' 'target_env')"
  [ -n "$target_env" ] || die 'deployment.md target_env is missing'
  is_placeholder_value "$target_env" && die 'deployment.md target_env must be set before deploy'
  CODESPEC_PROJECT_ROOT="$project_root" "$FRAMEWORK_ROOT/scripts/check-gate.sh" deployment-plan-ready >/dev/null

  local release_mode
  release_mode="$(markdown_section_scalar "$deployment_file" '## Deployment Plan' 'release_mode')"
  [ -n "$release_mode" ] || release_mode='runtime'

  local deploy_script="$project_root/scripts/codespec-deploy"
  [ -x "$deploy_script" ] || die 'missing executable deploy script: scripts/codespec-deploy'

  local result_file
  result_file="$(mktemp)"
  CODESPEC_PROJECT_ROOT="$project_root" \
  CODESPEC_TARGET_ENV="$target_env" \
  CODESPEC_DEPLOY_RESULT_FILE="$result_file" \
    "$deploy_script"

  local deploy_status execution_ref deployment_method deployed_at deployed_revision source_revision restart_required restart_reason smoke_test runtime_ready runtime_observed_revision runtime_ready_evidence manual_verification_ready
  deploy_status="$(yaml_scalar "$result_file" status)"
  [ "$deploy_status" = 'pass' ] || die "deploy script reported status=${deploy_status}"

  execution_ref="$(yaml_scalar "$result_file" execution_ref)"
  deployment_method="$(yaml_scalar "$result_file" deployment_method)"
  deployed_at="$(yaml_scalar "$result_file" deployed_at)"
  deployed_revision="$(yaml_scalar "$result_file" deployed_revision)"
  source_revision="$(yaml_scalar "$result_file" source_revision)"
  restart_required="$(yaml_scalar "$result_file" restart_required)"
  restart_reason="$(yaml_scalar "$result_file" restart_reason)"
  smoke_test="$(yaml_scalar "$result_file" smoke_test)"
  runtime_ready="$(yaml_scalar "$result_file" runtime_ready)"
  runtime_observed_revision="$(yaml_scalar "$result_file" runtime_observed_revision)"
  runtime_ready_evidence="$(yaml_scalar "$result_file" runtime_ready_evidence)"
  manual_verification_ready="$(yaml_scalar "$result_file" manual_verification_ready)"
  rm -f "$result_file"

  is_placeholder_value "$execution_ref" && die 'deploy result execution_ref is missing'
  is_placeholder_value "$deployment_method" && die 'deploy result deployment_method is missing'
  printf '%s\n' "$deployed_at" | grep -Eq '^[0-9]{4}-[0-9]{2}-[0-9]{2}T' || die 'deploy result deployed_at must be an RFC3339 timestamp'
  is_placeholder_value "$deployed_revision" && die 'deploy result deployed_revision is missing'
  if is_placeholder_value "$source_revision"; then
    source_revision="$(current_git_revision "$project_root")"
  fi
  is_placeholder_value "$restart_reason" && die 'deploy result restart_reason is missing'
  [ "$smoke_test" = 'pass' ] || die 'deploy result smoke_test must be pass'
  [ "$manual_verification_ready" = 'pass' ] || die 'deploy result manual_verification_ready must be pass'
  case "$release_mode" in
    runtime)
      case "$restart_required" in
        yes|no) ;;
        *) die 'deploy result restart_required must be yes or no' ;;
      esac
      [ "$runtime_ready" = 'pass' ] || die 'deploy result runtime_ready must be pass'
      is_placeholder_value "$runtime_observed_revision" && die 'deploy result runtime_observed_revision is missing'
      is_placeholder_value "$runtime_ready_evidence" && die 'deploy result runtime_ready_evidence is missing'
      [ "$deployed_revision" = "$runtime_observed_revision" ] || die 'deploy result runtime_observed_revision must match deployed_revision'
      ;;
    artifact|manual)
      case "$runtime_ready" in
        pass|not-applicable|n/a) ;;
        *) die 'deploy result runtime_ready must be pass or not-applicable for artifact/manual release_mode' ;;
      esac
      is_placeholder_value "$runtime_ready_evidence" && die 'deploy result runtime_ready_evidence is missing'
      ;;
    *)
      die 'deployment.md release_mode must be runtime, artifact, or manual'
      ;;
  esac

  replace_markdown_section "$deployment_file" '## Execution Evidence' "$(cat <<EOF
status: pass
execution_ref: $execution_ref
deployment_method: $deployment_method
deployed_at: $deployed_at
deployed_revision: $deployed_revision
source_revision: $source_revision
restart_required: $restart_required
restart_reason: $restart_reason
runtime_observed_revision: $runtime_observed_revision
runtime_ready_evidence: $runtime_ready_evidence
EOF
)"

  replace_markdown_section "$deployment_file" '## Verification Results' "$(cat <<EOF
smoke_test: $smoke_test
runtime_ready: $runtime_ready
manual_verification_ready: $manual_verification_ready
EOF
)"

  local current_acceptance_status
  current_acceptance_status="$(markdown_section_scalar "$deployment_file" '## Acceptance Conclusion' 'status')"
  if [ "$current_acceptance_status" = 'pass' ] || [ "$current_acceptance_status" = 'fail' ]; then
    log "preserving existing acceptance conclusion (status: $current_acceptance_status)"
  else
    replace_markdown_section "$deployment_file" '## Acceptance Conclusion' "$(cat <<'EOF'
status: pending
notes: pending manual acceptance
approved_by: pending
approved_at: pending
EOF
)"
  fi

  log "deployment executed"
}

