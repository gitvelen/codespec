  [ -f "$meta" ] || die "missing meta.yaml"

  local current_status current_phase
  current_status="$(yaml_scalar "$meta" status)"
  current_phase="$(yaml_scalar "$meta" phase)"

  [ "$current_status" = 'completed' ] || die 'generate-project-docs requires completed status'
  [ "$current_phase" = 'Deployment' ] || die 'generate-project-docs requires Deployment phase'

  [ -f "$project_root/deployment.md" ] || die 'deployment.md not found'

