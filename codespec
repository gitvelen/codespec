#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
FRAMEWORK_ROOT="$SCRIPT_DIR"

log() {
  printf '%s\n' "$*"
}

die() {
  printf 'ERROR: %s\n' "$*" >&2
  exit 1
}

require_yq() {
  command -v yq >/dev/null 2>&1 || die "yq is required"
}

yaml_scalar() {
  local file="$1"
  local key="$2"
  yq eval ".${key}" "$file"
}

yaml_list() {
  local file="$1"
  local key="$2"
  yq eval ".${key}[]" "$file" 2>/dev/null || true
}

json_string_array() {
  local first=1
  printf '['
  while [ "$#" -gt 0 ]; do
    if [ "$first" -eq 0 ]; then
      printf ', '
    fi
    printf '%s' "$1" | python3 -c 'import json,sys; print(json.dumps(sys.stdin.read()), end="")'
    first=0
    shift
  done
  printf ']'
}

json_object() {
  printf '{'
  local first=1
  while [ "$#" -gt 0 ]; do
    local key="$1"
    local value="$2"
    if [ "$first" -eq 0 ]; then
      printf ', '
    fi
    printf '%s' "$key" | python3 -c 'import json,sys; print(json.dumps(sys.stdin.read()), end="")'
    printf ': %s' "$value"
    first=0
    shift 2
  done
  printf '}'
}

json_quote() {
  printf '%s' "$1" | python3 -c 'import json,sys; print(json.dumps(sys.stdin.read()), end="")'
}

json_path_entry_object() {
  local path="$1"
  local when_clause="${2:-}"
  local read_hint="${3:-}"
  local args=("path" "$(json_quote "$path")")
  if [ -n "$when_clause" ]; then
    args+=("when" "$(json_quote "$when_clause")")
  fi
  if [ -n "$read_hint" ]; then
    args+=("read_hint" "$(json_quote "$read_hint")")
  fi
  json_object "${args[@]}"
}

json_path_entries() {
  local first=1
  printf '['
  while [ "$#" -gt 0 ]; do
    local path="$1"
    local when_clause="${2:-}"
    local read_hint="${3:-}"
    if [ "$first" -eq 0 ]; then
      printf ', '
    fi
    printf '%s' "$(json_path_entry_object "$path" "$when_clause" "$read_hint")"
    first=0
    shift 3
  done
  printf ']'
}

render_text_entry_line() {
  local path="$1"
  local read_hint="${2:-}"
  if [ -n "$read_hint" ]; then
    printf -- '- %s (%s)\n' "$path" "$read_hint"
  else
    printf -- '- %s\n' "$path"
  fi
}

render_text_triplets() {
  local -n entries_ref="$1"
  local idx
  for ((idx=0; idx<${#entries_ref[@]}; idx+=3)); do
    render_text_entry_line "${entries_ref[idx]}" "${entries_ref[idx+2]}"
  done
}

render_text_entry_choice() {
  local -n entries_ref="$1"
  local idx joined when_clause
  when_clause="${entries_ref[1]:-}"
  joined=""
  for ((idx=0; idx<${#entries_ref[@]}; idx+=3)); do
    if [ -n "$joined" ]; then
      joined+=" or "
    fi
    joined+="${entries_ref[idx]}"
  done
  printf -- '- %s (%s)\n' "$joined" "$when_clause"
}

render_text_string_list() {
  local -n items_ref="$1"
  local item
  for item in "${items_ref[@]}"; do
    printf -- '- %s\n' "$item"
  done
}

json_bool() {
  if [ "$1" = 'true' ]; then
    printf 'true'
  else
    printf 'false'
  fi
}

find_optional_arg() {
  local needle="$1"
  shift
  local arg
  for arg in "$@"; do
    if [ "$arg" = "$needle" ]; then
      return 0
    fi
  done
  return 1
}

find_workspace_root() {
  if [ -n "${CODESPEC_WORKSPACE_ROOT:-}" ] && [ -f "${CODESPEC_WORKSPACE_ROOT}/.codespec/codespec" ]; then
    printf '%s\n' "$CODESPEC_WORKSPACE_ROOT"
    return
  fi

  local candidate
  candidate="$(dirname "$FRAMEWORK_ROOT")"
  if [ -f "$candidate/.codespec/codespec" ]; then
    printf '%s\n' "$candidate"
    return
  fi

  local dir="$PWD"
  while [ "$dir" != "/" ]; do
    if [ -f "$dir/.codespec/codespec" ]; then
      printf '%s\n' "$dir"
      return
    fi
    dir="$(dirname "$dir")"
  done

  die "could not locate workspace root (directory containing .codespec/)"
}

find_project_root() {
  if [ -n "${CODESPEC_PROJECT_ROOT:-}" ]; then
    if git -C "$CODESPEC_PROJECT_ROOT" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
      git -C "$CODESPEC_PROJECT_ROOT" rev-parse --show-toplevel
      return
    fi
    printf '%s\n' "$CODESPEC_PROJECT_ROOT"
    return
  fi

  if git rev-parse --show-toplevel >/dev/null 2>&1; then
    git rev-parse --show-toplevel
    return
  fi

  printf '%s\n' "$PWD"
}

render_template() {
  local src="$1"
  local dest="$2"
  local content
  content="$(<"$src")"
  content="${content//__DATE__/${RENDER_DATE:-}}"
  content="${content//__CONTAINER__/${RENDER_CONTAINER:-}}"
  content="${content//__CHANGE_ID__/${RENDER_CHANGE_ID:-}}"
  content="${content//__BASE_VERSION__/${RENDER_BASE_VERSION:-}}"
  content="${content//__FEATURE_BRANCH__/${RENDER_FEATURE_BRANCH:-}}"
  content="${content//__EXECUTION_GROUP__/${RENDER_EXECUTION_GROUP:-}}"
  content="${content//__EXECUTION_BRANCH__/${RENDER_EXECUTION_BRANCH:-}}"
  content="${content//__UPDATED_BY__/${RENDER_UPDATED_BY:-}}"
  content="${content//__PHASE__/${RENDER_PHASE:-}}"
  content="${content//__STATUS__/${RENDER_STATUS:-}}"
  content="${content//__FOCUS_WORK_ITEM__/${RENDER_FOCUS_WORK_ITEM:-}}"
  content="${content//__ACTIVE_WORK_ITEMS__/${RENDER_ACTIVE_WORK_ITEMS:-[]}}"
  content="${content//__WI_ID__/${RENDER_WI_ID:-}}"
  content="${content//__DERIVED_FROM__/${RENDER_DERIVED_FROM:-}}"
  printf '%s\n' "$content" > "$dest"
}

copy_dir_contents() {
  local src="$1"
  local dest="$2"
  mkdir -p "$dest"
  if [ -d "$src" ]; then
    cp -R "$src/." "$dest/"
  fi
}

current_git_branch() {
  local project_root="$1"
  if git -C "$project_root" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    git -C "$project_root" symbolic-ref --quiet --short HEAD 2>/dev/null || printf 'detached'
    return
  fi
  printf 'none'
}

branch_alignment_status() {
  local project_root="$1"
  local expected_branch="$2"
  local actual_branch
  actual_branch="$(current_git_branch "$project_root")"

  if [ "$expected_branch" = "null" ]; then
    printf 'not_applicable'
    return
  fi

  [ "$actual_branch" = "$expected_branch" ] && printf 'aligned' || printf 'mismatch'
}

meta_update() {
  local meta_file="$1"
  shift
  TODAY="$(date +%F)" UPDATED_BY="codespec-cli" yq eval "$* | .updated_at = env(TODAY) | .updated_by = env(UPDATED_BY)" -i "$meta_file"
}


assert_phase_transition() {
  local current_phase="$1"
  local target_phase="$2"
  local current_status="$3"

  case "$target_phase" in
    Requirements)
      [ "$current_phase" = 'Proposal' ] || die "cannot move from ${current_phase} to ${target_phase}"
      ;;
    Design)
      [ "$current_phase" = 'Requirements' ] || die "cannot move from ${current_phase} to ${target_phase}"
      ;;
    Implementation)
      [ "$current_phase" = 'Design' ] || die "cannot move from ${current_phase} to ${target_phase}"
      ;;
    Testing)
      [ "$current_phase" = 'Implementation' ] || die "cannot move from ${current_phase} to ${target_phase}"
      ;;
    Deployment)
      if [ "$current_phase" = 'Deployment' ] && [ "$current_status" = 'completed' ]; then
        return
      fi
      [ "$current_phase" = 'Testing' ] || die "cannot move from ${current_phase} to ${target_phase}"
      ;;
    *)
      die "unsupported target phase: ${target_phase}"
      ;;
  esac
}

parse_active_work_items_arg() {
  local raw="$1"
  if [ "$raw" = '[]' ]; then
    printf '[]'
    return
  fi

  local output='['
  local first=1
  local item
  IFS=',' read -r -a items <<< "$raw"
  for item in "${items[@]}"; do
    [ -n "$item" ] || continue
    if [ "$first" -eq 0 ]; then
      output+=', '
    fi
    output+="\"$item\""
    first=0
  done
  output+=']'
  printf '%s' "$output"
}



add_work_item() {
  require_yq
  local wi_id="${1:?usage: codespec add-work-item <WI-ID>}"
  local project_root
  project_root="$(find_project_root)"
  local wi_file="$project_root/work-items/$wi_id.yaml"
  [ ! -f "$wi_file" ] || die "work item already exists: $wi_id"

  RENDER_WI_ID="$wi_id" \
  RENDER_DERIVED_FROM="design.md#work-item-derivation" \
  render_template "$FRAMEWORK_ROOT/templates/work-item.yaml" "$wi_file"

  log "created work item: work-items/$wi_id.yaml"
}

materialize_deployment() {
  require_yq
  local project_root
  project_root="$(find_project_root)"
  local target="$project_root/deployment.md"
  [ ! -f "$target" ] || die "deployment.md already exists"
  cp "$FRAMEWORK_ROOT/templates/deployment.md" "$target"
  log "created deployment file: deployment.md"
}

start_requirements() {
  require_yq
  local project_root
  project_root="$(find_project_root)"
  local meta="$project_root/meta.yaml"
  [ -f "$meta" ] || die "missing meta.yaml"

  local current_phase current_status
  current_phase="$(yaml_scalar "$meta" phase)"
  current_status="$(yaml_scalar "$meta" status)"
  assert_phase_transition "$current_phase" 'Requirements' "$current_status"

  CODESPEC_PROJECT_ROOT="$project_root" CODESPEC_TARGET_PHASE='Requirements' "$FRAMEWORK_ROOT/scripts/check-gate.sh" proposal-maturity >/dev/null
  CODESPEC_PROJECT_ROOT="$project_root" CODESPEC_TARGET_PHASE='Requirements' "$FRAMEWORK_ROOT/scripts/check-gate.sh" review-verdict-present >/dev/null

  meta_update "$meta" '.phase = "Requirements" | .status = "in_progress"'
  log "started Requirements phase"
}

start_design() {
  require_yq
  local project_root
  project_root="$(find_project_root)"
  local meta="$project_root/meta.yaml"
  [ -f "$meta" ] || die "missing meta.yaml"

  local current_phase current_status
  current_phase="$(yaml_scalar "$meta" phase)"
  current_status="$(yaml_scalar "$meta" status)"
  assert_phase_transition "$current_phase" 'Design' "$current_status"

  CODESPEC_PROJECT_ROOT="$project_root" CODESPEC_TARGET_PHASE='Design' "$FRAMEWORK_ROOT/scripts/check-gate.sh" requirements-approval >/dev/null
  CODESPEC_PROJECT_ROOT="$project_root" CODESPEC_TARGET_PHASE='Design' "$FRAMEWORK_ROOT/scripts/check-gate.sh" review-verdict-present >/dev/null

  meta_update "$meta" '.phase = "Design" | .status = "in_progress"'
  log "started Design phase"
}

start_implementation() {
  require_yq
  local wi_id="${1:?usage: codespec start-implementation <WI-ID>}"
  local project_root
  project_root="$(find_project_root)"
  local meta="$project_root/meta.yaml"
  [ -f "$meta" ] || die "missing meta.yaml"
  [ -f "$project_root/work-items/$wi_id.yaml" ] || die "missing work item: work-items/$wi_id.yaml"

  local current_phase current_status active_count
  current_phase="$(yaml_scalar "$meta" phase)"
  current_status="$(yaml_scalar "$meta" status)"
  assert_phase_transition "$current_phase" 'Implementation' "$current_status"

  CODESPEC_PROJECT_ROOT="$project_root" CODESPEC_FOCUS_WI="$wi_id" CODESPEC_TARGET_PHASE='Implementation' "$FRAMEWORK_ROOT/scripts/check-gate.sh" implementation-ready >/dev/null
  CODESPEC_PROJECT_ROOT="$project_root" CODESPEC_TARGET_PHASE='Implementation' "$FRAMEWORK_ROOT/scripts/check-gate.sh" review-verdict-present >/dev/null

  active_count="$(yq eval '.active_work_items | length' "$meta")"
  if [ "$active_count" = '0' ]; then
    meta_update "$meta" ".phase = \"Implementation\" | .status = \"in_progress\" | .focus_work_item = \"$wi_id\" | .active_work_items = [\"$wi_id\"]"
  else
    if ! yq eval '.active_work_items[]' "$meta" 2>/dev/null | grep -Fxq "$wi_id"; then
      meta_update "$meta" ".phase = \"Implementation\" | .status = \"in_progress\" | .focus_work_item = \"$wi_id\" | .active_work_items += [\"$wi_id\"]"
    else
      meta_update "$meta" ".phase = \"Implementation\" | .status = \"in_progress\" | .focus_work_item = \"$wi_id\""
    fi
  fi
  log "started Implementation phase: focus=$wi_id"
}

start_testing() {
  require_yq
  local project_root
  project_root="$(find_project_root)"
  local meta="$project_root/meta.yaml"
  [ -f "$meta" ] || die "missing meta.yaml"

  local current_phase current_status
  current_phase="$(yaml_scalar "$meta" phase)"
  current_status="$(yaml_scalar "$meta" status)"
  assert_phase_transition "$current_phase" 'Testing' "$current_status"

  CODESPEC_PROJECT_ROOT="$project_root" "$FRAMEWORK_ROOT/scripts/check-gate.sh" metadata-consistency >/dev/null
  CODESPEC_PROJECT_ROOT="$project_root" "$FRAMEWORK_ROOT/scripts/check-gate.sh" branch-alignment >/dev/null
  CODESPEC_PROJECT_ROOT="$project_root" "$FRAMEWORK_ROOT/scripts/check-gate.sh" feature-sync >/dev/null
  CODESPEC_PROJECT_ROOT="$project_root" "$FRAMEWORK_ROOT/scripts/check-gate.sh" scope >/dev/null
  CODESPEC_PROJECT_ROOT="$project_root" "$FRAMEWORK_ROOT/scripts/check-gate.sh" contract-boundary >/dev/null
  CODESPEC_PROJECT_ROOT="$project_root" "$FRAMEWORK_ROOT/scripts/check-gate.sh" verification >/dev/null

  meta_update "$meta" '.phase = "Testing" | .status = "in_progress" | .focus_work_item = null | .active_work_items = []'
  log "started Testing phase"
}

start_deployment() {
  require_yq
  local project_root
  project_root="$(find_project_root)"
  local meta="$project_root/meta.yaml"
  [ -f "$meta" ] || die "missing meta.yaml"

  local current_phase current_status deployment_file
  current_phase="$(yaml_scalar "$meta" phase)"
  current_status="$(yaml_scalar "$meta" status)"
  assert_phase_transition "$current_phase" 'Deployment' "$current_status"

  CODESPEC_PROJECT_ROOT="$project_root" "$FRAMEWORK_ROOT/scripts/check-gate.sh" trace-consistency >/dev/null
  CODESPEC_PROJECT_ROOT="$project_root" "$FRAMEWORK_ROOT/scripts/check-gate.sh" verification >/dev/null

  deployment_file="$project_root/deployment.md"
  if [ ! -f "$deployment_file" ]; then
    cp "$FRAMEWORK_ROOT/templates/deployment.md" "$deployment_file"
  fi

  meta_update "$meta" '.phase = "Deployment" | .status = "in_progress" | .focus_work_item = null | .active_work_items = []'
  log "started Deployment phase"
}

complete_change() {
  require_yq
  local project_root
  project_root="$(find_project_root)"
  local meta="$project_root/meta.yaml"
  [ -f "$meta" ] || die "missing meta.yaml"

  local current_phase
  current_phase="$(yaml_scalar "$meta" phase)"
  [ "$current_phase" = 'Deployment' ] || die 'complete-change requires Deployment phase'

  CODESPEC_PROJECT_ROOT="$project_root" "$FRAMEWORK_ROOT/scripts/check-gate.sh" promotion-criteria >/dev/null

  meta_update "$meta" '.status = "completed" | .focus_work_item = null | .active_work_items = []'
  log "completed change"
}

set_active_work_items() {
  require_yq
  local raw="${1:?usage: codespec set-active-work-items <WI-001,WI-002|[]>}"
  local project_root
  project_root="$(find_project_root)"
  local meta="$project_root/meta.yaml"
  [ -f "$meta" ] || die "missing meta.yaml"

  local yaml_array item
  yaml_array="$(parse_active_work_items_arg "$raw")"

  local phase focus_wi
  phase="$(yaml_scalar "$meta" phase)"
  focus_wi="$(yaml_scalar "$meta" focus_work_item)"

  if [ "$phase" = 'Implementation' ] && [ "$yaml_array" = '[]' ] && [ "$focus_wi" != 'null' ]; then
    die 'cannot clear active_work_items while focus_work_item is set in Implementation phase'
  fi
  if [ "$phase" = 'Implementation' ] && [ "$focus_wi" != 'null' ] && [ "$yaml_array" != '[]' ]; then
    printf '%s\n' "$raw" | tr ',' '\n' | grep -Fxq "$focus_wi" || die "focus_work_item ${focus_wi} must be included in active_work_items"
  fi
  if [ "$phase" = 'Testing' ] || [ "$phase" = 'Deployment' ]; then
    [ "$yaml_array" = '[]' ] || die "${phase} phase requires active_work_items = []"
  fi

  meta_update "$meta" ".active_work_items = ${yaml_array}"
  log "updated active work items"
}

promote_version() {
  require_yq
  local stable_version="${1:?usage: codespec promote-version <stable-version>}"
  local workspace_root project_root
  workspace_root="$(find_workspace_root)"
  project_root="$(find_project_root)"
  local meta="$project_root/meta.yaml"
  [ -f "$meta" ] || die "missing meta.yaml"

  CODESPEC_PROJECT_ROOT="$project_root" "$FRAMEWORK_ROOT/scripts/check-gate.sh" promotion >/dev/null

  local target_root="$workspace_root/versions/$stable_version"
  [ ! -e "$target_root" ] || die "target version already exists: versions/$stable_version"

  mkdir -p "$target_root"
  cp "$project_root/meta.yaml" "$target_root/meta.yaml"
  cp "$project_root/spec.md" "$target_root/spec.md"
  cp "$project_root/design.md" "$target_root/design.md"
  [ -f "$project_root/testing.md" ] && cp "$project_root/testing.md" "$target_root/testing.md"
  [ -f "$project_root/deployment.md" ] && cp "$project_root/deployment.md" "$target_root/deployment.md"
  [ -f "$project_root/CLAUDE.md" ] && cp "$project_root/CLAUDE.md" "$target_root/CLAUDE.md"
  [ -f "$project_root/AGENTS.md" ] && cp "$project_root/AGENTS.md" "$target_root/AGENTS.md"
  copy_dir_contents "$project_root/work-items" "$target_root/work-items"
  copy_dir_contents "$project_root/contracts" "$target_root/contracts"
  copy_dir_contents "$project_root/spec-appendices" "$target_root/spec-appendices"
  copy_dir_contents "$project_root/design-appendices" "$target_root/design-appendices"

  if [ -d "$project_root/src" ]; then
    copy_dir_contents "$project_root/src" "$target_root/src"
  fi

  TODAY="$(date +%F)" yq eval '.status = "completed" | .focus_work_item = null | .updated_at = env(TODAY) | .updated_by = "codespec-promote"' -i "$target_root/meta.yaml"

  log "promoted dossier"
  log "source: $project_root"
  log "target: versions/$stable_version"
}

install_hooks() {
  local project_root
  project_root="$(find_project_root)"
  "$FRAMEWORK_ROOT/scripts/install-hooks.sh" "$project_root"
}

status_cmd() {
  require_yq
  local project_root
  project_root="$(find_project_root)"
  local meta="$project_root/meta.yaml"
  [ -f "$meta" ] || die "missing meta.yaml"

  build_readset_model "$project_root"

  local git_branch execution_branch branch_alignment
  git_branch="$(current_git_branch "$project_root")"
  execution_branch="$(yaml_scalar "$meta" execution_branch)"
  branch_alignment="$(branch_alignment_status "$project_root" "$execution_branch")"

  printf 'project_root: %s\n' "$project_root"
  printf 'phase: %s\n' "$(yaml_scalar "$meta" phase)"
  printf 'status: %s\n' "$(yaml_scalar "$meta" status)"
  printf 'focus_work_item: %s\n' "$(yaml_scalar "$meta" focus_work_item)"
  printf 'feature_branch: %s\n' "$(yaml_scalar "$meta" feature_branch)"
  printf 'execution_group: %s\n' "$(yaml_scalar "$meta" execution_group)"
  printf 'execution_branch: %s\n' "$execution_branch"
  printf 'git_branch: %s\n' "$git_branch"
  printf 'branch_alignment: %s\n' "$branch_alignment"
  printf 'phase_capabilities.allowed:\n'
  render_text_string_list READSET_MODEL_PHASE_CAP_ALLOWED
  printf 'phase_capabilities.forbidden:\n'
  render_text_string_list READSET_MODEL_PHASE_CAP_FORBIDDEN
  printf 'authority.phase_policy: %s\n' "$READSET_MODEL_PHASE_POLICY"
}

build_readset_model() {
  local project_root="$1"
  local meta="$project_root/meta.yaml"
  [ -f "$meta" ] || die "missing meta.yaml"

  READSET_MODEL_PHASE="$(yaml_scalar "$meta" phase)"
  READSET_MODEL_FOCUS_WI="$(yaml_scalar "$meta" focus_work_item)"
  READSET_MODEL_WORK_ITEM_PATH='null'
  READSET_MODEL_PHASE_POLICY='../../phase-review-policy.md'
  READSET_MODEL_PHASE_CAP_ALLOWED=()
  READSET_MODEL_PHASE_CAP_FORBIDDEN=()

  READSET_MODEL_ENTRY_FILES=(
    "AGENTS.md" "read exactly one" ""
    "CLAUDE.md" "read exactly one" ""
  )
  READSET_MODEL_MINIMAL_READSET=(
    "../../lessons_learned.md" "" ""
    "../../phase-review-policy.md" "" ""
    "meta.yaml" "" ""
    "spec.md" "" "read to <!-- SKELETON-END --> first"
    "design.md" "" "read Default Read Layer first"
  )
  READSET_MODEL_WORK_ITEM_ENTRY=()
  READSET_MODEL_CONTRACT_REFS=()
  READSET_MODEL_PHASE_DOCS=()
  READSET_MODEL_APPENDIX_SPEC=("spec-appendices/*" "only when default layer is insufficient" "")
  READSET_MODEL_APPENDIX_DESIGN=("design-appendices/*" "only when current slice requires drill-down" "")

  case "$READSET_MODEL_PHASE" in
    Proposal)
      READSET_MODEL_MINIMAL_READSET=(
        "../../lessons_learned.md" "" ""
        "../../phase-review-policy.md" "" ""
        "meta.yaml" "" ""
        "spec.md" "" "read to <!-- SKELETON-END --> first"
      )
      READSET_MODEL_PHASE_CAP_ALLOWED=(
        "authoritative dossier edits"
      )
      READSET_MODEL_PHASE_CAP_FORBIDDEN=(
        "src/** and Dockerfile only"
      )
      ;;
    Requirements)
      READSET_MODEL_PHASE_CAP_ALLOWED=(
        "authoritative dossier edits"
      )
      READSET_MODEL_PHASE_CAP_FORBIDDEN=(
        "src/** and Dockerfile only"
      )
      ;;
  esac

  if [ "$READSET_MODEL_FOCUS_WI" != "null" ] && [ -f "$project_root/work-items/$READSET_MODEL_FOCUS_WI.yaml" ]; then
    READSET_MODEL_WORK_ITEM_PATH="work-items/$READSET_MODEL_FOCUS_WI.yaml"
    READSET_MODEL_WORK_ITEM_ENTRY=("$READSET_MODEL_WORK_ITEM_PATH" "when focus_work_item is set" "")
    while IFS= read -r ref; do
      [ -n "$ref" ] || continue
      [ "$ref" != "null" ] || continue
      READSET_MODEL_CONTRACT_REFS+=("$ref" "when current work item contract_refs is non-empty" "")
    done < <(yaml_list "$project_root/work-items/$READSET_MODEL_FOCUS_WI.yaml" contract_refs)
  fi

  case "$READSET_MODEL_PHASE" in
    Testing)
      READSET_MODEL_PHASE_DOCS+=("testing.md" "during Testing phase" "")
      READSET_MODEL_PHASE_DOCS+=("work-items/*.yaml" "during Testing phase" "")
      ;;
    Deployment)
      READSET_MODEL_PHASE_DOCS+=("testing.md" "during Deployment phase" "")
      READSET_MODEL_PHASE_DOCS+=("deployment.md" "during Deployment phase" "")
      ;;
  esac
}

render_readset_json() {
  printf '{\n'
  printf '  "phase": %s,\n' "$(json_quote "$READSET_MODEL_PHASE")"
  printf '  "entry_files": %s,\n' "$(json_path_entries "${READSET_MODEL_ENTRY_FILES[@]}")"
  printf '  "read_one_entry_file": %s,\n' "$(json_bool true)"
  printf '  "minimal_readset": %s,\n' "$(json_path_entries "${READSET_MODEL_MINIMAL_READSET[@]}")"
  printf '  "phase_capabilities": {\n'
  printf '    "allowed": %s,\n' "$(json_string_array "${READSET_MODEL_PHASE_CAP_ALLOWED[@]}")"
  printf '    "forbidden": %s\n' "$(json_string_array "${READSET_MODEL_PHASE_CAP_FORBIDDEN[@]}")"
  printf '  },\n'
  printf '  "authority": {\n'
  printf '    "phase_policy": %s\n' "$(json_quote "$READSET_MODEL_PHASE_POLICY")"
  printf '  },\n'
  printf '  "focus_work_item": '
  if [ "$READSET_MODEL_FOCUS_WI" = 'null' ]; then
    printf 'null'
  else
    printf '%s' "$(json_quote "$READSET_MODEL_FOCUS_WI")"
  fi
  printf ',\n'
  printf '  "work_item": '
  if [ "$READSET_MODEL_WORK_ITEM_PATH" = 'null' ]; then
    printf 'null'
  else
    printf '%s' "$(json_path_entry_object "${READSET_MODEL_WORK_ITEM_ENTRY[0]}" "${READSET_MODEL_WORK_ITEM_ENTRY[1]}" "${READSET_MODEL_WORK_ITEM_ENTRY[2]}")"
  fi
  printf ',\n'
  printf '  "contract_refs": %s,\n' "$(json_path_entries "${READSET_MODEL_CONTRACT_REFS[@]}")"
  printf '  "phase_docs": %s,\n' "$(json_path_entries "${READSET_MODEL_PHASE_DOCS[@]}")"
  printf '  "appendix_rules": {\n'
  printf '    "spec": %s,\n' "$(json_path_entry_object "${READSET_MODEL_APPENDIX_SPEC[0]}" "${READSET_MODEL_APPENDIX_SPEC[1]}" "${READSET_MODEL_APPENDIX_SPEC[2]}")"
  printf '    "design": %s\n' "$(json_path_entry_object "${READSET_MODEL_APPENDIX_DESIGN[0]}" "${READSET_MODEL_APPENDIX_DESIGN[1]}" "${READSET_MODEL_APPENDIX_DESIGN[2]}")"
  printf '  }\n'
  printf '}\n'
}

render_readset_text() {
  printf 'readset:\n'
  render_text_entry_line '../../lessons_learned.md'
  render_text_entry_line '../../phase-review-policy.md'
  render_text_entry_choice READSET_MODEL_ENTRY_FILES
  render_text_triplets READSET_MODEL_MINIMAL_READSET
  printf 'phase_capabilities.allowed:\n'
  render_text_string_list READSET_MODEL_PHASE_CAP_ALLOWED
  printf 'phase_capabilities.forbidden:\n'
  render_text_string_list READSET_MODEL_PHASE_CAP_FORBIDDEN
  printf 'authority.phase_policy: %s\n' "$READSET_MODEL_PHASE_POLICY"
  if [ "$READSET_MODEL_WORK_ITEM_PATH" != 'null' ]; then
    render_text_triplets READSET_MODEL_WORK_ITEM_ENTRY
    render_text_triplets READSET_MODEL_CONTRACT_REFS
  fi
  render_text_triplets READSET_MODEL_PHASE_DOCS
  render_text_triplets READSET_MODEL_APPENDIX_SPEC
  render_text_triplets READSET_MODEL_APPENDIX_DESIGN
}

readset_cmd() {
  require_yq
  local project_root
  project_root="$(find_project_root)"
  local output_json=false
  if find_optional_arg '--json' "$@"; then
    output_json=true
  fi

  build_readset_model "$project_root"

  if [ "$output_json" = true ]; then
    render_readset_json
    return
  fi

  render_readset_text
}

check_gate_cmd() {
  require_yq
  local gate="${1:?usage: codespec check-gate <name>}"
  exec "$FRAMEWORK_ROOT/scripts/check-gate.sh" "$gate"
}

install_cmd() {
  require_yq
  local target_root="${1:-$PWD}"
  local container="${2:-main}"
  local change_id="${3:-baseline}"
  local base_version="${4:-null}"
  exec "$FRAMEWORK_ROOT/scripts/install.sh" "$target_root" "$container" "$change_id" "$base_version"
}

usage() {
  cat <<'EOF'
Usage:
  codespec install [target_root] [container] [change_id] [base_version]
  codespec add-work-item <WI-ID>
  codespec start-requirements
  codespec start-design
  codespec start-implementation <WI-ID>
  codespec set-active-work-items <WI-001,WI-002|[]>
  codespec start-testing
  codespec start-deployment
  codespec complete-change
  codespec install-hooks
  codespec check-gate <name>
  codespec status
  codespec readset
  codespec materialize-deployment
  codespec promote-version <stable-version>

Gate views:
  spec-completeness -> proposal-maturity + requirements-approval
  design-structure-complete -> design artifacts are structurally complete and aligned with work item derivation
  design-readiness -> alias of design-structure-complete
  implementation-ready -> design-structure-complete + implementation-start
  scope -> staged changes stay within allowed_paths / outside forbidden_paths
  contract-boundary -> contract refs resolve and frozen contracts stay unchanged
  trace-consistency -> REQ->ACC->VO, ACC->WI, approved ACC testing records in Testing/Deployment
  verification -> dependency/current WI pass checks; adds testing-coverage in Testing/Deployment
  promotion -> deployment-readiness + promotion-criteria

Lifecycle commands:
  start-requirements -> Proposal -> Requirements
  start-design -> Requirements -> Design
  start-implementation -> Design -> Implementation and set focus_work_item
  set-active-work-items -> update active_work_items explicitly (design/manual branch execution set; runtime does not provide complete multi-WI union enforcement)
  start-testing -> Implementation -> Testing and clear active work items
  start-deployment -> Testing -> Deployment (or Deployment completed -> Deployment in_progress reopen; auto-materializes deployment.md if missing)
  complete-change -> mark Deployment change completed

Review rule:
  check-gate pass != semantic review pass; phase advancement still requires phase-review-policy/rfr approval

Internal gates:
  branch-alignment | feature-sync | metadata-consistency
  proposal-maturity | requirements-approval | design-structure-complete (alias: design-readiness)
  implementation-ready | implementation-start
  testing-coverage | deployment-readiness | promotion-criteria
EOF
}

main() {
  local cmd="${1:-help}"
  shift || true

  case "$cmd" in
    install)
      install_cmd "$@"
      ;;
    add-work-item)
      add_work_item "$@"
      ;;
    start-requirements)
      start_requirements "$@"
      ;;
    start-design)
      start_design "$@"
      ;;
    start-implementation)
      start_implementation "$@"
      ;;
    set-active-work-items)
      set_active_work_items "$@"
      ;;
    start-testing)
      start_testing "$@"
      ;;
    start-deployment)
      start_deployment "$@"
      ;;
    complete-change)
      complete_change "$@"
      ;;
    install-hooks)
      install_hooks "$@"
      ;;
    check-gate)
      check_gate_cmd "$@"
      ;;
    status)
      status_cmd "$@"
      ;;
    readset)
      readset_cmd "$@"
      ;;
    materialize-deployment)
      materialize_deployment "$@"
      ;;
    promote-version)
      promote_version "$@"
      ;;
    help|-h|--help)
      usage
      ;;
    *)
      die "unknown command: $cmd"
      ;;
  esac
}

main "$@"
